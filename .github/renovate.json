{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automerge": true,
  "ignoreTests": true,
  "packageRules": [
    {
      "matchPackageNames": [
        "string-width",
        "strip-ansi",
        "wrap-ansi",
        "semver",
        "yaml",
        "ws"
      ],
      "ignoreTests": false
    }
  ]
}
