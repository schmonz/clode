+/* Serialized bytecode is canonically LITTLE-ENDIAN: the format the in-tree
+   precompiled bundles and every little-endian host already produce. Writers
+   on big-endian hosts convert on emit; readers on big-endian hosts convert
+   on load; little-endian hosts are byte-identical no-ops. This fulfills the
+   intent documented by the JS_WRITE_OBJ_BSWAP "handled transparently" stub.
+   Operand layouts per format follow the dump decoder (the authoritative
+   reference): u16-class = u16 at +1; npop_u16 = u16 at +1 and +3; u32-class
+   (incl. atom) = u32 at +1; u32x2/atom_label_* = u32 at +1 and +5 (+ u16 at
+   +9 for atom_label_u16); label_u16/atom_u16 = u32 at +1, u16 at +5.
+   bswap is an involution, so ONE helper serves both directions. */
+static void bc_bswap_op_operands(uint8_t *bc_buf, int pos, uint8_t fmt)
+{
+    switch (fmt) {
+    case OP_FMT_u16:
+    case OP_FMT_i16:
+    case OP_FMT_label16:
+    case OP_FMT_npop:
+    case OP_FMT_loc:
+    case OP_FMT_arg:
+    case OP_FMT_var_ref:
+        put_u16(bc_buf + pos + 1, bswap16(get_u16(bc_buf + pos + 1)));
+        break;
+    case OP_FMT_npop_u16:
+        put_u16(bc_buf + pos + 1, bswap16(get_u16(bc_buf + pos + 1)));
+        put_u16(bc_buf + pos + 3, bswap16(get_u16(bc_buf + pos + 3)));
+        break;
+    case OP_FMT_u32:
+    case OP_FMT_i32:
+    case OP_FMT_const:
+    case OP_FMT_label:
+    case OP_FMT_atom:
+    case OP_FMT_atom_u8:
+        put_u32(bc_buf + pos + 1, bswap32(get_u32(bc_buf + pos + 1)));
+        break;
+    case OP_FMT_u32x2:
+    case OP_FMT_atom_label_u8:
+        put_u32(bc_buf + pos + 1, bswap32(get_u32(bc_buf + pos + 1)));
+        put_u32(bc_buf + pos + 5, bswap32(get_u32(bc_buf + pos + 5)));
+        break;
+    case OP_FMT_label_u16:
+    case OP_FMT_atom_u16:
+        put_u32(bc_buf + pos + 1, bswap32(get_u32(bc_buf + pos + 1)));
+        put_u16(bc_buf + pos + 5, bswap16(get_u16(bc_buf + pos + 5)));
+        break;
+    case OP_FMT_atom_label_u16:
+        put_u32(bc_buf + pos + 1, bswap32(get_u32(bc_buf + pos + 1)));
+        put_u32(bc_buf + pos + 5, bswap32(get_u32(bc_buf + pos + 5)));
+        put_u16(bc_buf + pos + 9, bswap16(get_u16(bc_buf + pos + 9)));
+        break;
+    default:
+        break;
+    }
+}
 
