+/* canonical-LE: the compiled regexp is libregexp's OWN bytecode format,
+   embedded (in a function cpool via OP_regexp, or as a serialized JSRegExp)
+   as an opaque 8-bit byte string copied verbatim by JS_WriteString. Its
+   internal u16/u32 fields are read host-order by the lre interpreter, so a
+   little-endian-compiled regexp reads garbage and aborts in
+   lre_exec_backtrack on a big-endian host. Rather than teach a second
+   opcode walker the REOP format, recompile from the pattern on big-endian
+   hosts. Called ONLY on the cross-endian paths (OP_regexp cpool literal +
+   JS_ReadRegExp); `new RegExp` compiles fresh-native and never comes here.
+   Flags live in the canonical-LE header (u16 at RE_HEADER_FLAGS=0); mask off
+   the COMPUTED bit LRE_FLAG_NAMED_GROUPS which lre_compile re-derives from
+   the pattern (feeding it back as input corrupts the compile). Neither arg
+   is consumed. quickjs-ng upstream candidate. */
+static JSValue js_re_recompile_le(JSContext *ctx, JSValueConst pattern,
+                                  JSValueConst le_bc_val)
+{
+    JSString *le_bc = JS_VALUE_GET_STRING(le_bc_val);
+    const uint8_t *hdr = str8(le_bc);
+    int re_flags, re_bytecode_len = 0;
+    char error_msg[64];
+    size_t pat_len;
+    const char *pat_cstr;
+    uint8_t *re_bytecode_buf;
+    JSValue bc_val;
+    JSString *new_bc;
+
+    if (le_bc->is_wide_char || le_bc->len < 8)
+        return JS_ThrowInternalError(ctx, "bad regexp bytecode");
+    /* OP_regexp fires for BOTH deserialized cpool literals (canonical-LE)
+       AND freshly-parsed literals in running code (native-BE) — recompiling
+       the latter would misread its native header flags as LE and drop e.g.
+       the global flag. Discriminate structurally: the RE_HEADER_BYTECODE_LEN
+       u32 must satisfy RE_HEADER_LEN + len <= total only in the CORRECT
+       endianness (the wrong reading is astronomically large). If the native
+       reading is already plausible, the bytecode is native — return it
+       untouched. Only recompile when the little-endian reading is the
+       plausible one. */
+    {
+        uint32_t cap = (uint32_t)le_bc->len - 8;
+        uint32_t len_native = get_u32(hdr + 4);
+        uint32_t len_le = hdr[4] |
+                          (hdr[5] << 8) |
+                          (hdr[6] << 16) |
+                          ((uint32_t)hdr[7] << 24);
+        if (len_native <= cap || !(len_le <= cap))
+            return JS_DupValue(ctx, le_bc_val);  /* already native */
+    }
+    /* Flags are a u16 at RE_HEADER_FLAGS in the canonical-LE header. */
+    re_flags = (hdr[0] | (hdr[1] << 8)) & ~LRE_FLAG_NAMED_GROUPS;
+    pat_cstr = JS_ToCStringLen2(ctx, &pat_len, pattern,
+                               !(re_flags & LRE_FLAG_UNICODE));
+    if (!pat_cstr)
+        return JS_EXCEPTION;
+    re_bytecode_buf = lre_compile(&re_bytecode_len, error_msg, sizeof(error_msg),
+                                  pat_cstr, pat_len, re_flags, ctx);
+    JS_FreeCString(ctx, pat_cstr);
+    if (!re_bytecode_buf)
+        return JS_ThrowInternalError(ctx, "regexp recompile failed: %s", error_msg);
+    bc_val = js_new_string8_len(ctx, (void *)&re_bytecode_buf, sizeof(re_bytecode_buf));
+    if (JS_IsException(bc_val)) {
+        js_free(ctx, re_bytecode_buf);
+        return JS_EXCEPTION;
+    }
+    new_bc = JS_VALUE_GET_STRING(bc_val);
+    new_bc->kind = JS_STRING_KIND_INDIRECT;
+    new_bc->len = re_bytecode_len;
+    return bc_val;
 }
 
