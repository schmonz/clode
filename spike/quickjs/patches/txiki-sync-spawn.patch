diff --git a/src/mod_spawn_sync.c b/src/mod_spawn_sync.c
new file mode 100644
index 0000000..fe8320b
--- /dev/null
+++ b/src/mod_spawn_sync.c
@@ -0,0 +1,711 @@
+/* Synchronous spawn primitive for CommonJS interop (node-shim).
+ * posix_spawn + poll()-drain, main-thread blocking by design. Exposed as
+ * the global `__tjs_spawn_sync`. Mirrors mod_fs_sync.c; upstream candidate. */
+#include "private.h"
+#include "utils.h"
+#include <errno.h>
+#include <fcntl.h>
+#if !defined(_WIN32)
+#include <poll.h>
+#include <signal.h>
+#endif
+/* Tiger floor (spawn-model axis): posix_spawn is 10.5+; below it the
+ * fork/exec sibling further down serves instead. */
+#if defined(__APPLE__)
+# include <AvailabilityMacros.h>
+# if MAC_OS_X_VERSION_MAX_ALLOWED >= 1050 && MAC_OS_X_VERSION_MIN_REQUIRED >= 1050
+#  define TJS__SPAWN_SYNC_HAS_POSIX_SPAWN 1
+# endif
+#elif !defined(_WIN32)
+# define TJS__SPAWN_SYNC_HAS_POSIX_SPAWN 1
+#endif
+#ifdef TJS__SPAWN_SYNC_HAS_POSIX_SPAWN
+#include <spawn.h>
+#endif
+#include <stdlib.h>
+#include <string.h>
+#if !defined(_WIN32)
+#include <sys/wait.h>
+#include <unistd.h>
+#endif
+#include <time.h>
+#if defined(_WIN32)
+#include <windows.h>
+#include <io.h>
+#endif
+
+/* ---- old-darwin floor compat (macOS 10.6 SDK/floor; darwin floor walk
+ * 2026-07-11). Three walls: clock_gettime is 10.12+, O_CLOEXEC is 10.7+,
+ * posix_spawn_file_actions_addchdir_np is 10.15+. ---- */
+#if defined(__APPLE__)
+# include <AvailabilityMacros.h>
+# if MAC_OS_X_VERSION_MAX_ALLOWED >= 101500 && MAC_OS_X_VERSION_MIN_REQUIRED >= 101500
+#  define TJS__SPAWN_SYNC_HAS_ADDCHDIR 1
+# endif
+# if MAC_OS_X_VERSION_MAX_ALLOWED < 101200 || MAC_OS_X_VERSION_MIN_REQUIRED < 101200
+#  include <mach/mach_time.h>
+#  ifndef CLOCK_MONOTONIC
+#   define CLOCK_MONOTONIC 6
+#  endif
+static int tjs__clock_gettime_compat(int clk, struct timespec *ts) {
+    static mach_timebase_info_data_t tb;
+    uint64_t t;
+    (void)clk;
+    if (tb.denom == 0)
+        mach_timebase_info(&tb);
+    t = mach_absolute_time() * tb.numer / tb.denom;
+    ts->tv_sec = t / 1000000000ULL;
+    ts->tv_nsec = t % 1000000000ULL;
+    return 0;
+}
+#  define clock_gettime tjs__clock_gettime_compat
+# endif
+# ifndef O_CLOEXEC
+   /* pre-10.7: no O_CLOEXEC open flag. Safe here: the only O_CLOEXEC open is
+    * the child's /dev/null stdin, dup2'd in and closed right after the one
+    * spawn on this single-threaded path — nothing else can leak it. */
+#  define O_CLOEXEC 0
+# endif
+#else
+# define TJS__SPAWN_SYNC_HAS_ADDCHDIR 1
+#endif
+
+#if !defined(_WIN32)
+extern char **environ;
+#endif
+
+static const char *errno_code(int e) {
+    switch (e) {
+    case ENOENT:  return "ENOENT";
+    case EACCES:  return "EACCES";
+    case EPERM:   return "EPERM";
+    case ENOEXEC: return "ENOEXEC";
+    case E2BIG:   return "E2BIG";
+    case EINVAL:  return "EINVAL";
+    case ESRCH:   return "ESRCH";
+    case EMFILE:  return "EMFILE";
+    default:      return "EUNKNOWN";
+    }
+}
+
+static JSValue throw_errno(JSContext *ctx, int e, const char *op, const char *path) {
+    JSValue err = JS_NewError(ctx);
+    char buf[1152];
+    snprintf(buf, sizeof(buf), "%s, %s '%s'", errno_code(e), op, path ? path : "");
+    JS_DefinePropertyValueStr(ctx, err, "message", JS_NewString(ctx, buf), JS_PROP_C_W_E);
+    JS_DefinePropertyValueStr(ctx, err, "errno", JS_NewInt32(ctx, e), JS_PROP_C_W_E);
+    JS_DefinePropertyValueStr(ctx, err, "code", JS_NewString(ctx, errno_code(e)), JS_PROP_C_W_E);
+    JS_DefinePropertyValueStr(ctx, err, "syscall", JS_NewString(ctx, op), JS_PROP_C_W_E);
+    return JS_Throw(ctx, err);
+}
+
+/* growable byte buffer */
+typedef struct { uint8_t *data; size_t len, cap; } buf_t;
+static int buf_append(buf_t *b, const uint8_t *p, size_t n, size_t max) {
+    if (b->len >= max) return 0;
+    if (b->len + n > max) n = max - b->len;
+    if (n == 0) return 0;
+    if (b->len + n > b->cap) {
+        size_t nc = b->cap ? b->cap : 4096;
+        while (nc < b->len + n) nc *= 2;
+        uint8_t *nd = realloc(b->data, nc);
+        if (!nd) return -1;
+        b->data = nd; b->cap = nc;
+    }
+    memcpy(b->data + b->len, p, n);
+    b->len += n;
+    return 0;
+}
+
+#if !defined(_WIN32)
+static long now_ms(void) {
+    struct timespec ts;
+    clock_gettime(CLOCK_MONOTONIC, &ts);
+    return (long)ts.tv_sec * 1000 + ts.tv_nsec / 1000000;
+}
+
+/* Create a pipe with both ends close-on-exec (portable pipe()+fcntl; the
+ * non-atomic window is safe here because the caller is single-threaded and no
+ * spawn runs before posix_spawn). posix_spawn's file_actions dup2 the wanted
+ * end into the child's 0/1/2, and dup2 clears O_CLOEXEC on the *target* copy,
+ * so the child still gets working stdio; the parent-side ends never leak into
+ * any concurrently-spawned child. */
+static int pipe_cloexec(int fds[2]) {
+    if (pipe(fds) < 0) return -1;
+    if (fcntl(fds[0], F_SETFD, FD_CLOEXEC) < 0 || fcntl(fds[1], F_SETFD, FD_CLOEXEC) < 0) {
+        int e = errno; close(fds[0]); close(fds[1]); fds[0] = fds[1] = -1; errno = e; return -1;
+    }
+    return 0;
+}
+#endif  /* !_WIN32 */
+
+static char **js_string_array(JSContext *ctx, JSValueConst arr, int prepend_argc, const char *prepend) {
+    /* Build a NULL-terminated char** from a JS string[]; if prepend != NULL it
+     * becomes element 0 (argv[0]). Caller frees with free_string_array. */
+    JSValue lenv = JS_GetPropertyStr(ctx, arr, "length");
+    uint32_t n = 0; JS_ToUint32(ctx, &n, lenv); JS_FreeValue(ctx, lenv);
+    char **out = calloc((size_t)n + prepend_argc + 1, sizeof(char *));
+    if (!out) return NULL;
+    size_t i = 0;
+    if (prepend) out[i++] = strdup(prepend);
+    for (uint32_t k = 0; k < n; k++) {
+        JSValue e = JS_GetPropertyUint32(ctx, arr, k);
+        const char *s = JS_ToCString(ctx, e);
+        out[i++] = strdup(s ? s : "");
+        if (s) JS_FreeCString(ctx, s);
+        JS_FreeValue(ctx, e);
+    }
+    out[i] = NULL;
+    return out;
+}
+static void free_string_array(char **a) {
+    if (!a) return;
+    for (char **p = a; *p; p++) free(*p);
+    free(a);
+}
+
+#if !defined(_WIN32)
+static JSValue js_spawn_sync(JSContext *ctx, JSValueConst this_val, int argc, JSValueConst *argv) {
+    const char *file = JS_ToCString(ctx, argv[0]);
+    if (!file) return JS_EXCEPTION;
+    JSValue opts = argv[2];
+
+    char **cargv = js_string_array(ctx, argv[1], 1, file);
+    if (!cargv) { JS_FreeCString(ctx, file); return JS_ThrowOutOfMemory(ctx); }
+    JSValue envv = JS_GetPropertyStr(ctx, opts, "env");
+    char **cenv = JS_IsArray(envv) ? js_string_array(ctx, envv, 0, NULL) : NULL;
+    JS_FreeValue(ctx, envv);
+
+    JSValue cwdv = JS_GetPropertyStr(ctx, opts, "cwd");
+    const char *cwd = JS_IsString(cwdv) ? JS_ToCString(ctx, cwdv) : NULL;
+
+    JSValue inv = JS_GetPropertyStr(ctx, opts, "input");
+    size_t input_len = 0;
+    uint8_t *input = (!JS_IsUndefined(inv) && !JS_IsNull(inv)) ? JS_GetArrayBuffer(ctx, &input_len, inv) : NULL;
+
+    int64_t timeout_ms = 0, max_buffer = 1 << 24;
+    JSValue tv = JS_GetPropertyStr(ctx, opts, "timeoutMs");
+    if (JS_IsNumber(tv)) JS_ToInt64(ctx, &timeout_ms, tv);
+    JS_FreeValue(ctx, tv);
+    JSValue mv = JS_GetPropertyStr(ctx, opts, "maxBuffer");
+    if (JS_IsNumber(mv)) JS_ToInt64(ctx, &max_buffer, mv);
+    JS_FreeValue(ctx, mv);
+    if (timeout_ms < 0) timeout_ms = 0;          /* negative timeout => no timeout */
+    if (max_buffer <= 0) max_buffer = 1 << 24;   /* nonpositive cap => default 16MB */
+
+#if !defined(__APPLE__) && !defined(__GLIBC__)
+    if (cwd) {
+        /* build the error before freeing file (throw_errno copies the message) */
+        JSValue e = throw_errno(ctx, EINVAL, "spawn_sync_cwd_unsupported", file);
+        free_string_array(cargv); free_string_array(cenv);
+        JS_FreeCString(ctx, cwd); JS_FreeValue(ctx, cwdv); JS_FreeValue(ctx, inv); JS_FreeCString(ctx, file);
+        return e;
+    }
+#endif
+
+    int outp[2] = {-1, -1}, errp[2] = {-1, -1}, inp[2] = {-1, -1}, devnull = -1;
+    int use_stdin = (input != NULL);
+    if (pipe_cloexec(outp) < 0 || pipe_cloexec(errp) < 0 ||
+        (use_stdin ? (pipe_cloexec(inp) < 0) : ((devnull = open("/dev/null", O_RDONLY | O_CLOEXEC)) < 0))) {
+        JSValue e = throw_errno(ctx, errno, "pipe", file);
+        for (int i = 0; i < 2; i++) {
+            if (outp[i] >= 0) close(outp[i]);
+            if (errp[i] >= 0) close(errp[i]);
+            if (inp[i] >= 0) close(inp[i]);
+        }
+        if (devnull >= 0) close(devnull);
+        free_string_array(cargv); free_string_array(cenv);
+        if (cwd) JS_FreeCString(ctx, cwd);
+        JS_FreeValue(ctx, cwdv); JS_FreeValue(ctx, inv); JS_FreeCString(ctx, file);
+        return e;
+    }
+
+#ifdef TJS__SPAWN_SYNC_HAS_POSIX_SPAWN
+    posix_spawn_file_actions_t fa;
+    posix_spawn_file_actions_init(&fa);
+    if (use_stdin) {
+        posix_spawn_file_actions_adddup2(&fa, inp[0], 0);
+        posix_spawn_file_actions_addclose(&fa, inp[0]);
+        posix_spawn_file_actions_addclose(&fa, inp[1]);
+    } else {
+        posix_spawn_file_actions_adddup2(&fa, devnull, 0);
+        posix_spawn_file_actions_addclose(&fa, devnull);
+    }
+    posix_spawn_file_actions_adddup2(&fa, outp[1], 1);
+    posix_spawn_file_actions_addclose(&fa, outp[0]);
+    posix_spawn_file_actions_addclose(&fa, outp[1]);
+    posix_spawn_file_actions_adddup2(&fa, errp[1], 2);
+    posix_spawn_file_actions_addclose(&fa, errp[0]);
+    posix_spawn_file_actions_addclose(&fa, errp[1]);
+#if (defined(__APPLE__) && defined(TJS__SPAWN_SYNC_HAS_ADDCHDIR)) || defined(__GLIBC__)
+    /* addchdir_np: since macOS 10.15 / glibc 2.29. Deprecated on macOS 26 for
+     * the POSIX posix_spawn_file_actions_addchdir, but still functional; the
+     * build is -Werror, so suppress the deprecation locally rather than fork
+     * the name per OS version. M4 (NetBSD) re-checks availability. */
+    if (cwd) {
+#if defined(__clang__)
+#pragma clang diagnostic push
+#pragma clang diagnostic ignored "-Wdeprecated-declarations"
+#elif defined(__GNUC__)
+#pragma GCC diagnostic push
+#pragma GCC diagnostic ignored "-Wdeprecated-declarations"
+#endif
+        posix_spawn_file_actions_addchdir_np(&fa, cwd);
+#if defined(__clang__)
+#pragma clang diagnostic pop
+#elif defined(__GNUC__)
+#pragma GCC diagnostic pop
+#endif
+    }
+#endif
+
+    /* POSIX_SPAWN_CLOEXEC_DEFAULT (Apple extension): treat every parent fd as
+     * O_CLOEXEC, so ONLY the fds dup2'd via file_actions above reach the child.
+     * Without it a concurrently in-flight fd — notably libwebsockets' outbound
+     * TCP/TLS socket for a live fetch() — leaks into this sync child; when the
+     * child exits mid-connect the socket teardown corrupts ("closed before
+     * established"), the documented native fd-race (M3b Wall #1). libuv's async
+     * uv_spawn sets exactly this flag, which is why the async path never leaked.
+     * On non-Apple the flag is absent; there the O_CLOEXEC pipes above plus
+     * already-cloexec runtime fds carry the guarantee. */
+    posix_spawnattr_t *attrp = NULL;
+#ifdef POSIX_SPAWN_CLOEXEC_DEFAULT
+    posix_spawnattr_t attr;
+    if (posix_spawnattr_init(&attr) == 0) {
+        if (posix_spawnattr_setflags(&attr, POSIX_SPAWN_CLOEXEC_DEFAULT) == 0)
+            attrp = &attr;
+        else
+            posix_spawnattr_destroy(&attr);
+    }
+#endif
+
+    pid_t pid = 0;
+#if defined(__APPLE__) && !defined(TJS__SPAWN_SYNC_HAS_ADDCHDIR)
+    /* No addchdir_np before macOS 10.15: parent-side chdir dance around the
+     * spawn — safe on the single JS thread this sync spawner runs on. A
+     * failed chdir(cwd) becomes the spawn error (same errno class node
+     * reports for a bad cwd). */
+    char oldcwd[1024];
+    int rc = 0;
+    oldcwd[0] = 0;
+    if (cwd) {
+        if (getcwd(oldcwd, sizeof(oldcwd)) == NULL)
+            oldcwd[0] = 0;
+        if (chdir(cwd) != 0)
+            rc = errno;
+    }
+    if (rc == 0)
+        rc = posix_spawn(&pid, file, &fa, attrp, cargv, cenv ? cenv : environ);
+    if (cwd && oldcwd[0] != 0)
+        chdir(oldcwd);
+#else
+    int rc = posix_spawn(&pid, file, &fa, attrp, cargv, cenv ? cenv : environ);
+#endif
+    if (attrp) posix_spawnattr_destroy(attrp);
+    posix_spawn_file_actions_destroy(&fa);
+#else
+    /* Pre-10.5: fork/exec sibling — same pipes, same poll-drain. The child
+     * dup2s the wanted ends onto 0/1/2 (clearing their close-on-exec on the
+     * copies), chdirs if asked, and execves; every other descriptor is
+     * already close-on-exec. posix_spawn does no PATH search (that is
+     * posix_spawnp), so execve keeps exact parity with the modern path. */
+    pid_t pid = 0;
+    int rc = 0;
+    pid = fork();
+    if (pid < 0) {
+        rc = errno;
+    } else if (pid == 0) {
+        if (cwd && chdir(cwd) != 0)
+            _exit(127);
+        if (dup2(use_stdin ? inp[0] : devnull, 0) < 0 ||
+            dup2(outp[1], 1) < 0 ||
+            dup2(errp[1], 2) < 0)
+            _exit(127);
+        execve(file, cargv, cenv ? cenv : environ);
+        _exit(127);
+    }
+#endif  /* TJS__SPAWN_SYNC_HAS_POSIX_SPAWN */
+    close(outp[1]); close(errp[1]);
+    if (use_stdin) close(inp[0]); else close(devnull);
+
+    JSValue result;
+    if (rc != 0) {
+        close(outp[0]); close(errp[0]);
+        if (use_stdin) close(inp[1]);
+        result = throw_errno(ctx, rc, "spawn", file);
+        goto cleanup;
+    }
+
+    if (use_stdin) {
+        void (*old)(int) = signal(SIGPIPE, SIG_IGN);
+        size_t off = 0;
+        while (off < input_len) {
+            ssize_t w = write(inp[1], input + off, input_len - off);
+            if (w < 0) { if (errno == EINTR) continue; break; }
+            off += (size_t)w;
+        }
+        close(inp[1]);
+        signal(SIGPIPE, old);
+    }
+
+    buf_t ob = {0}, eb = {0};
+    struct pollfd pfds[2] = { { outp[0], POLLIN, 0 }, { errp[0], POLLIN, 0 } };
+    int open_count = 2, timed_out = 0;
+    long start = now_ms();
+    uint8_t rbuf[65536];
+    while (open_count > 0) {
+        int to = -1;
+        if (timeout_ms > 0) {
+            long rem = timeout_ms - (now_ms() - start);
+            if (rem <= 0) { timed_out = 1; break; }
+            to = (int)rem;
+        }
+        int pr = poll(pfds, 2, to);
+        if (pr < 0) { if (errno == EINTR) continue; break; }
+        if (pr == 0) { timed_out = 1; break; }
+        for (int k = 0; k < 2; k++) {
+            if (pfds[k].fd < 0) continue;
+            if (pfds[k].revents & (POLLIN | POLLHUP | POLLERR)) {
+                ssize_t n = read(pfds[k].fd, rbuf, sizeof(rbuf));
+                if (n > 0) {
+                    buf_append(k == 0 ? &ob : &eb, rbuf, (size_t)n, (size_t)max_buffer);
+                    /* DIVERGENCE: a maxBuffer overrun is reported via the SAME
+                     * `timedOut` flag as a real timeout (both kill with SIGKILL).
+                     * Node distinguishes them (a RangeError
+                     * ERR_CHILD_PROCESS_STDIO_MAXBUFFER vs signal=killSignal). The
+                     * shim (Task 2) surfaces the conflated case as an error;
+                     * characterized in test/node-shim-child-process.test.cjs. */
+                    if ((int64_t)(ob.len + eb.len) >= max_buffer) { timed_out = 1; break; }
+                } else if (n < 0 && errno == EINTR) {
+                    continue;  /* interrupted read — retry via the next poll, not EOF */
+                } else {
+                    close(pfds[k].fd); pfds[k].fd = -1; open_count--;
+                }
+            }
+        }
+        if (timed_out) break;
+    }
+    if (pfds[0].fd >= 0) close(pfds[0].fd);
+    if (pfds[1].fd >= 0) close(pfds[1].fd);
+    if (timed_out) kill(pid, SIGKILL);
+
+    int wstatus = 0;
+    while (waitpid(pid, &wstatus, 0) < 0 && errno == EINTR) {}
+    int has_status = WIFEXITED(wstatus), has_sig = WIFSIGNALED(wstatus);
+
+    result = JS_NewObject(ctx);
+    JS_DefinePropertyValueStr(ctx, result, "pid", JS_NewInt32(ctx, pid), JS_PROP_C_W_E);
+    JS_DefinePropertyValueStr(ctx, result, "status",
+        (has_status && !timed_out) ? JS_NewInt32(ctx, WEXITSTATUS(wstatus)) : JS_NULL, JS_PROP_C_W_E);
+    /* DIVERGENCE: on timeout/maxBuffer the child is always killed with SIGKILL
+     * (reported here as the signal); Node defaults to SIGTERM then escalates. */
+    JS_DefinePropertyValueStr(ctx, result, "signal",
+        has_sig ? JS_NewInt32(ctx, WTERMSIG(wstatus)) : (timed_out ? JS_NewInt32(ctx, SIGKILL) : JS_NULL), JS_PROP_C_W_E);
+    JS_DefinePropertyValueStr(ctx, result, "stdout",
+        JS_NewArrayBufferCopy(ctx, ob.data ? ob.data : (const uint8_t *)"", ob.len), JS_PROP_C_W_E);
+    JS_DefinePropertyValueStr(ctx, result, "stderr",
+        JS_NewArrayBufferCopy(ctx, eb.data ? eb.data : (const uint8_t *)"", eb.len), JS_PROP_C_W_E);
+    JS_DefinePropertyValueStr(ctx, result, "timedOut", JS_NewBool(ctx, timed_out), JS_PROP_C_W_E);
+    free(ob.data); free(eb.data);
+
+cleanup:
+    free_string_array(cargv); free_string_array(cenv);
+    if (cwd) JS_FreeCString(ctx, cwd);
+    JS_FreeValue(ctx, cwdv); JS_FreeValue(ctx, inv);
+    JS_FreeCString(ctx, file);
+    return result;
+}
+
+/* kill(2) passthrough: __tjs_kill(pid, sig). sig is a signal NUMBER (0 = the
+ * POSIX liveness probe node's process.kill(pid, 0) exposes — tjs.kill cannot
+ * express it, its name-only parser rejects "0") or a signal NAME resolved by
+ * the same tjs_getsignum tjs.kill uses. Negative pid = process group, exactly
+ * kill(2). Throws the node error shape ({code:'ESRCH',...}) on failure. */
+static JSValue js_kill_sync(JSContext *ctx, JSValueConst this_val, int argc, JSValueConst *argv) {
+    int32_t pid, sig;
+    if (JS_ToInt32(ctx, &pid, argv[0]))
+        return JS_EXCEPTION;
+    if (JS_IsNumber(argv[1])) {
+        if (JS_ToInt32(ctx, &sig, argv[1]))
+            return JS_EXCEPTION;
+    } else {
+        const char *sig_str = JS_ToCString(ctx, argv[1]);
+        if (!sig_str)
+            return JS_EXCEPTION;
+        sig = tjs_getsignum(sig_str);
+        JS_FreeCString(ctx, sig_str);
+        if (sig == -1)
+            return JS_ThrowTypeError(ctx, "spawn_sync.kill: unknown signal");
+    }
+    if (kill((pid_t)pid, sig) != 0)
+        return throw_errno(ctx, errno, "kill", NULL);
+    return JS_UNDEFINED;
+}
+#endif  /* !_WIN32 */
+
+#if defined(_WIN32)
+/* ---- Win32 sync spawn: CreateProcess + overlapped-pipe drain. The
+ * spawn-model axis's third value (posix_spawn / fork-exec / CreateProcess). ---- */
+
+/* argv -> one command line, MS C runtime quoting rules (quote args with
+ * spaces/tabs/quotes; escape inner quotes and the backslash run before one). */
+static void append_quoted(buf_t *cl, const char *arg) {
+    size_t len = strlen(arg);
+    int needs_quote = (len == 0) || strpbrk(arg, " \t\"") != NULL;
+    if (!needs_quote) { buf_append(cl, (const uint8_t *)arg, len, (size_t)-1); return; }
+    buf_append(cl, (const uint8_t *)"\"", 1, (size_t)-1);
+    for (size_t i = 0;; i++) {
+        size_t nbs = 0;
+        while (i < len && arg[i] == '\\') { nbs++; i++; }
+        if (i == len) {
+            for (size_t k = 0; k < nbs * 2; k++) buf_append(cl, (const uint8_t *)"\\", 1, (size_t)-1);
+            break;
+        } else if (arg[i] == '"') {
+            for (size_t k = 0; k < nbs * 2 + 1; k++) buf_append(cl, (const uint8_t *)"\\", 1, (size_t)-1);
+            buf_append(cl, (const uint8_t *)"\"", 1, (size_t)-1);
+        } else {
+            for (size_t k = 0; k < nbs; k++) buf_append(cl, (const uint8_t *)"\\", 1, (size_t)-1);
+            buf_append(cl, (const uint8_t *)&arg[i], 1, (size_t)-1);
+        }
+    }
+    buf_append(cl, (const uint8_t *)"\"", 1, (size_t)-1);
+}
+
+/* env string[] "K=V" -> the double-NUL-terminated block CreateProcess wants. */
+static char *build_env_block(char **cenv) {
+    if (!cenv) return NULL;
+    size_t total = 1;  /* trailing NUL of the block */
+    for (char **p = cenv; *p; p++) total += strlen(*p) + 1;
+    char *blk = malloc(total < 2 ? 2 : total);
+    if (!blk) return NULL;
+    size_t off = 0;
+    for (char **p = cenv; *p; p++) { size_t n = strlen(*p) + 1; memcpy(blk + off, *p, n); off += n; }
+    blk[off] = '\0';
+    return blk;
+}
+
+/* An overlapped-capable parent read-end: named-pipe server (overlapped, NOT
+ * inheritable) + client CreateFile write-end (inheritable, goes to the child).
+ * CreatePipe's anonymous pipes cannot do overlapped reads — hence this. */
+static volatile LONG g_pipe_serial = 0;
+static int make_overlapped_pipe(HANDLE *rd_out, HANDLE *wr_out) {
+    char name[128];
+    LONG serial = InterlockedIncrement(&g_pipe_serial);
+    snprintf(name, sizeof(name), "\\\\.\\pipe\\tjs_sync.%lu.%lu.%lu",
+             (unsigned long)GetCurrentProcessId(), (unsigned long)serial,
+             (unsigned long)GetTickCount());
+    SECURITY_ATTRIBUTES sa_srv;
+    sa_srv.nLength = sizeof(sa_srv); sa_srv.lpSecurityDescriptor = NULL; sa_srv.bInheritHandle = FALSE;
+    HANDLE rd = CreateNamedPipeA(name, PIPE_ACCESS_INBOUND | FILE_FLAG_OVERLAPPED,
+                                 PIPE_TYPE_BYTE | PIPE_WAIT, 1, 65536, 65536, 0, &sa_srv);
+    if (rd == INVALID_HANDLE_VALUE) return -1;
+    SECURITY_ATTRIBUTES sa_cli;
+    sa_cli.nLength = sizeof(sa_cli); sa_cli.lpSecurityDescriptor = NULL; sa_cli.bInheritHandle = TRUE;
+    HANDLE wr = CreateFileA(name, GENERIC_WRITE, 0, &sa_cli, OPEN_EXISTING,
+                            FILE_ATTRIBUTE_NORMAL, NULL);
+    if (wr == INVALID_HANDLE_VALUE) { CloseHandle(rd); return -1; }
+    *rd_out = rd; *wr_out = wr;
+    return 0;
+}
+
+/* Complete a signaled overlapped read, append, re-arm. Sets *done at EOF /
+ * broken pipe; sets *overflow when the accumulator hits max_buffer. */
+static void spawn_win_complete(HANDLE h, OVERLAPPED *ov, uint8_t *b, buf_t *acc,
+                               int64_t max_buffer, int *pending, int *done, int *overflow) {
+    DWORD n = 0;
+    BOOL ok = GetOverlappedResult(h, ov, &n, FALSE);
+    if (ok && n > 0) {
+        buf_append(acc, b, n, (size_t)max_buffer);
+        if ((int64_t)acc->len >= max_buffer) { *overflow = 1; *pending = 0; *done = 1; return; }
+    } else if (!ok) {
+        DWORD e = GetLastError();
+        if (e == ERROR_IO_INCOMPLETE) return;  /* spurious: leave pending */
+        *pending = 0; *done = 1; return;        /* broken pipe / EOF / error */
+    } else { *pending = 0; *done = 1; return; } /* ok && n==0 -> EOF */
+    ResetEvent(ov->hEvent);
+    BOOL r = ReadFile(h, b, 65536, NULL, ov);
+    if (r || GetLastError() == ERROR_IO_PENDING) { *pending = 1; }
+    else { *pending = 0; *done = 1; }
+}
+
+static JSValue js_spawn_sync(JSContext *ctx, JSValueConst this_val, int argc, JSValueConst *argv) {
+    const char *file = JS_ToCString(ctx, argv[0]);
+    if (!file) return JS_EXCEPTION;
+    JSValue opts = argv[2];
+
+    char **cargv = js_string_array(ctx, argv[1], 1, file);
+    if (!cargv) { JS_FreeCString(ctx, file); return JS_ThrowOutOfMemory(ctx); }
+    JSValue envv = JS_GetPropertyStr(ctx, opts, "env");
+    char **cenv = JS_IsArray(envv) ? js_string_array(ctx, envv, 0, NULL) : NULL;
+    JS_FreeValue(ctx, envv);
+
+    JSValue cwdv = JS_GetPropertyStr(ctx, opts, "cwd");
+    const char *cwd = JS_IsString(cwdv) ? JS_ToCString(ctx, cwdv) : NULL;
+
+    JSValue inv = JS_GetPropertyStr(ctx, opts, "input");
+    size_t input_len = 0;
+    uint8_t *input = (!JS_IsUndefined(inv) && !JS_IsNull(inv)) ? JS_GetArrayBuffer(ctx, &input_len, inv) : NULL;
+    int use_stdin = (input != NULL);
+
+    int64_t timeout_ms = 0, max_buffer = 1 << 24;
+    JSValue tv = JS_GetPropertyStr(ctx, opts, "timeoutMs");
+    if (JS_IsNumber(tv)) JS_ToInt64(ctx, &timeout_ms, tv);
+    JS_FreeValue(ctx, tv);
+    JSValue mv = JS_GetPropertyStr(ctx, opts, "maxBuffer");
+    if (JS_IsNumber(mv)) JS_ToInt64(ctx, &max_buffer, mv);
+    JS_FreeValue(ctx, mv);
+    if (timeout_ms < 0) timeout_ms = 0;
+    if (max_buffer <= 0) max_buffer = 1 << 24;
+
+    /* command line */
+    buf_t cl = {0};
+    for (char **p = cargv; *p; p++) { if (p != cargv) buf_append(&cl, (const uint8_t *)" ", 1, (size_t)-1); append_quoted(&cl, *p); }
+    buf_append(&cl, (const uint8_t *)"\0", 1, (size_t)-1);  /* CreateProcessA needs a writable NUL-terminated string */
+    char *envblk = build_env_block(cenv);
+
+    HANDLE out_rd = NULL, out_wr = NULL, err_rd = NULL, err_wr = NULL;
+    HANDLE in_rd = NULL, in_wr = NULL, nul_rd = INVALID_HANDLE_VALUE;
+    JSValue result;
+    if (make_overlapped_pipe(&out_rd, &out_wr) < 0 || make_overlapped_pipe(&err_rd, &err_wr) < 0) {
+        errno = EMFILE; result = throw_errno(ctx, errno, "pipe", file); goto cleanup;
+    }
+    if (use_stdin) {
+        SECURITY_ATTRIBUTES sa; sa.nLength = sizeof(sa); sa.lpSecurityDescriptor = NULL; sa.bInheritHandle = TRUE;
+        if (!CreatePipe(&in_rd, &in_wr, &sa, 0)) { errno = EMFILE; result = throw_errno(ctx, errno, "pipe", file); goto cleanup; }
+        SetHandleInformation(in_wr, HANDLE_FLAG_INHERIT, 0);
+    } else {
+        SECURITY_ATTRIBUTES sa; sa.nLength = sizeof(sa); sa.lpSecurityDescriptor = NULL; sa.bInheritHandle = TRUE;
+        nul_rd = CreateFileA("NUL", GENERIC_READ, FILE_SHARE_READ, &sa, OPEN_EXISTING, 0, NULL);
+    }
+
+    STARTUPINFOA si; ZeroMemory(&si, sizeof(si)); si.cb = sizeof(si);
+    si.dwFlags = STARTF_USESTDHANDLES;
+    si.hStdInput = use_stdin ? in_rd : nul_rd;
+    si.hStdOutput = out_wr;
+    si.hStdError = err_wr;
+    PROCESS_INFORMATION pi; ZeroMemory(&pi, sizeof(pi));
+    BOOL created = CreateProcessA(NULL, (char *)cl.data, NULL, NULL, TRUE,
+                                  0 /* ANSI env block, no special flags */, envblk, cwd, &si, &pi);
+    /* parent no longer needs the child-side ends */
+    if (out_wr) { CloseHandle(out_wr); out_wr = NULL; }
+    if (err_wr) { CloseHandle(err_wr); err_wr = NULL; }
+    if (in_rd) { CloseHandle(in_rd); in_rd = NULL; }
+    if (nul_rd != INVALID_HANDLE_VALUE) { CloseHandle(nul_rd); nul_rd = INVALID_HANDLE_VALUE; }
+    if (!created) {
+        DWORD e = GetLastError();
+        errno = (e == ERROR_FILE_NOT_FOUND || e == ERROR_PATH_NOT_FOUND) ? ENOENT : EINVAL;
+        result = throw_errno(ctx, errno, "spawn", file);
+        goto cleanup;
+    }
+
+    if (use_stdin) {
+        size_t off = 0;
+        while (off < input_len) {
+            DWORD wn = 0;
+            if (!WriteFile(in_wr, input + off, (DWORD)(input_len - off), &wn, NULL)) break;
+            off += wn;
+        }
+        CloseHandle(in_wr); in_wr = NULL;
+    }
+
+    buf_t ob = {0}, eb = {0};
+    uint8_t bo[65536], be[65536];
+    OVERLAPPED ov_out; ZeroMemory(&ov_out, sizeof(ov_out)); ov_out.hEvent = CreateEventA(NULL, TRUE, FALSE, NULL);
+    OVERLAPPED ov_err; ZeroMemory(&ov_err, sizeof(ov_err)); ov_err.hEvent = CreateEventA(NULL, TRUE, FALSE, NULL);
+    int out_pending = 0, out_done = 0, err_pending = 0, err_done = 0, overflow = 0, timed_out = 0, proc_exited = 0;
+    /* initial arm */
+    if (ReadFile(out_rd, bo, sizeof(bo), NULL, &ov_out) || GetLastError() == ERROR_IO_PENDING) out_pending = 1; else out_done = 1;
+    if (ReadFile(err_rd, be, sizeof(be), NULL, &ov_err) || GetLastError() == ERROR_IO_PENDING) err_pending = 1; else err_done = 1;
+
+    DWORD start = GetTickCount();
+    while (!out_done || !err_done) {
+        HANDLE waits[3]; int nwait = 0, idx_out = -1, idx_err = -1, idx_proc = -1;
+        if (out_pending) { idx_out = nwait; waits[nwait++] = ov_out.hEvent; }
+        if (err_pending) { idx_err = nwait; waits[nwait++] = ov_err.hEvent; }
+        if (!proc_exited) { idx_proc = nwait; waits[nwait++] = pi.hProcess; }
+        if (nwait == 0) break;
+        DWORD to = INFINITE;
+        if (timeout_ms > 0) {
+            DWORD el = GetTickCount() - start;
+            if (el >= (DWORD)timeout_ms) { timed_out = 1; break; }
+            to = (DWORD)timeout_ms - el;
+        }
+        DWORD w = WaitForMultipleObjects((DWORD)nwait, waits, FALSE, to);
+        if (w == WAIT_TIMEOUT) { timed_out = 1; break; }
+        int which = (int)(w - WAIT_OBJECT_0);
+        if (which == idx_out) spawn_win_complete(out_rd, &ov_out, bo, &ob, max_buffer, &out_pending, &out_done, &overflow);
+        else if (which == idx_err) spawn_win_complete(err_rd, &ov_err, be, &eb, max_buffer, &err_pending, &err_done, &overflow);
+        else if (which == idx_proc) proc_exited = 1;
+        if (overflow) { timed_out = 1; break; }
+    }
+    if (timed_out) TerminateProcess(pi.hProcess, 1);
+    CloseHandle(ov_out.hEvent); CloseHandle(ov_err.hEvent);
+
+    WaitForSingleObject(pi.hProcess, INFINITE);
+    DWORD code = 0; GetExitCodeProcess(pi.hProcess, &code);
+
+    result = JS_NewObject(ctx);
+    JS_DefinePropertyValueStr(ctx, result, "pid", JS_NewInt32(ctx, (int)pi.dwProcessId), JS_PROP_C_W_E);
+    JS_DefinePropertyValueStr(ctx, result, "status",
+        timed_out ? JS_NULL : JS_NewInt32(ctx, (int)code), JS_PROP_C_W_E);
+    JS_DefinePropertyValueStr(ctx, result, "signal", JS_NULL, JS_PROP_C_W_E);
+    JS_DefinePropertyValueStr(ctx, result, "stdout",
+        JS_NewArrayBufferCopy(ctx, ob.data ? ob.data : (const uint8_t *)"", ob.len), JS_PROP_C_W_E);
+    JS_DefinePropertyValueStr(ctx, result, "stderr",
+        JS_NewArrayBufferCopy(ctx, eb.data ? eb.data : (const uint8_t *)"", eb.len), JS_PROP_C_W_E);
+    JS_DefinePropertyValueStr(ctx, result, "timedOut", JS_NewBool(ctx, timed_out), JS_PROP_C_W_E);
+    free(ob.data); free(eb.data);
+    CloseHandle(pi.hProcess); CloseHandle(pi.hThread);
+
+cleanup:
+    if (out_rd) CloseHandle(out_rd);
+    if (err_rd) CloseHandle(err_rd);
+    if (out_wr) CloseHandle(out_wr);
+    if (err_wr) CloseHandle(err_wr);
+    if (in_wr) CloseHandle(in_wr);
+    if (in_rd) CloseHandle(in_rd);
+    if (nul_rd != INVALID_HANDLE_VALUE) CloseHandle(nul_rd);
+    free(cl.data); free(envblk);
+    free_string_array(cargv); free_string_array(cenv);
+    if (cwd) JS_FreeCString(ctx, cwd);
+    JS_FreeValue(ctx, cwdv); JS_FreeValue(ctx, inv);
+    JS_FreeCString(ctx, file);
+    return result;
+}
+
+/* Minimal Win32 kill: signal 0 = liveness probe (OpenProcess), otherwise
+ * TerminateProcess. Node's process.kill on Windows terminates regardless of
+ * the named signal; ESRCH when the pid is gone. */
+static JSValue js_kill_sync(JSContext *ctx, JSValueConst this_val, int argc, JSValueConst *argv) {
+    int32_t pid, sig = 0;
+    if (JS_ToInt32(ctx, &pid, argv[0])) return JS_EXCEPTION;
+    if (JS_IsNumber(argv[1])) { if (JS_ToInt32(ctx, &sig, argv[1])) return JS_EXCEPTION; }
+    HANDLE h = OpenProcess(sig == 0 ? PROCESS_QUERY_LIMITED_INFORMATION : PROCESS_TERMINATE,
+                           FALSE, (DWORD)pid);
+    if (!h) { errno = ESRCH; return throw_errno(ctx, errno, "kill", NULL); }
+    JSValue ret = JS_UNDEFINED;
+    if (sig != 0 && !TerminateProcess(h, 1)) { errno = EPERM; ret = throw_errno(ctx, errno, "kill", NULL); }
+    CloseHandle(h);
+    return ret;
+}
+#endif  /* _WIN32 */
+
+static const JSCFunctionListEntry spawn_sync_funcs[] = {
+    JS_CFUNC_DEF("spawn", 3, js_spawn_sync),
+    JS_CFUNC_DEF("kill", 2, js_kill_sync),
+};
+
+void tjs__mod_spawn_sync_init(JSContext *ctx, JSValue ns) {
+    (void)ns;
+    JSValue global = JS_GetGlobalObject(ctx);
+    JSValue obj = JS_NewObject(ctx);
+    JS_SetPropertyFunctionList(ctx, obj, spawn_sync_funcs, countof(spawn_sync_funcs));
+    /* Expose the single entry directly as the callable global for ergonomics:
+     * __tjs_spawn_sync(file, args, opts). */
+    JSValue fn = JS_GetPropertyStr(ctx, obj, "spawn");
+    JS_DefinePropertyValueStr(ctx, global, "__tjs_spawn_sync", fn, JS_PROP_C_W_E);
+    JSValue kfn = JS_GetPropertyStr(ctx, obj, "kill");
+    JS_DefinePropertyValueStr(ctx, global, "__tjs_kill", kfn, JS_PROP_C_W_E);
+    JS_FreeValue(ctx, obj);
+    JS_FreeValue(ctx, global);
+}
