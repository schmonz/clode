+// grade.mjs — grade a wurl-built tjs against the frozen golden manifest.
+// Usage: node grade.mjs <path-to-tjs>
+//
+// Rules (ada-ectomy Phase 2, IDNA L1'):
+//  - every case NOT tagged nonAsciiHost must match the golden EXACTLY;
+//  - tagged cases may REJECT where golden succeeds (parse: throws;
+//    setters/host-setter: forgiving no-op leaving the URL at its pre-setter
+//    state — verified by re-probing the built tjs) but must NEVER
+//    value-diverge from the golden.
+import { spawnSync } from 'node:child_process';
+import fs from 'node:fs';
+import path from 'node:path';
+
+const repo = '/Users/schmonz/Documents/shared-trees/clode';
+const tjs = process.argv[2];
+if (!tjs) { console.error('usage: node grade.mjs <tjs>'); process.exit(2); }
+
+const golden = JSON.parse(fs.readFileSync(path.join(repo, 'test/fixtures/url/golden-tjs-url.json'), 'utf8'));
+const r = spawnSync(tjs, ['run', path.join(repo, 'test/fixtures/url/urlchar-tjs-main.mjs')], {
+  encoding: 'utf8', maxBuffer: 64 * 1024 * 1024, timeout: 120000,
+});
+if (r.status !== 0) { console.error('tjs runner failed:', r.status, r.stderr?.slice(0, 4000)); process.exit(1); }
+const mine = JSON.parse(r.stdout);
+
+const eq = (a, b) => JSON.stringify(a) === JSON.stringify(b);
+
+// probe helper: run snippets under the built tjs
+function probe(script) {
+  const p = spawnSync(tjs, ['eval', script], { encoding: 'utf8', maxBuffer: 16 * 1024 * 1024 });
+  return p.stdout.trim();
+}
+
+const stats = {};
+const failures = [];
+const acceptedRejects = [];
+
+for (const sec of Object.keys(golden)) {
+  stats[sec] = { total: golden[sec].length, match: 0, acceptReject: 0, fail: 0 };
+  if (!mine[sec] || mine[sec].length !== golden[sec].length) {
+    console.error(`section ${sec}: case count mismatch`);
+    process.exit(1);
+  }
+  for (let i = 0; i < golden[sec].length; i++) {
+    const g = golden[sec][i];
+    const m = mine[sec][i];
+    if (eq(g, m)) { stats[sec].match++; continue; }
+    const tagged = g.nonAsciiHost === true;
+    let ok = false;
+    let kind = '';
+    if (tagged && sec === 'parse') {
+      // acceptable: we throw where golden succeeded
+      ok = g.result !== 'throws' && m.result === 'throws' &&
+           m.canParse === false && m.staticParseNull === true &&
+           eq({ ...g, result: 0, canParse: 0, staticParseNull: 0 },
+              { ...m, result: 0, canParse: 0, staticParseNull: 0 });
+      kind = 'parse-throws';
+    } else if (tagged && sec === 'toascii') {
+      // acceptable: viaURL throws where golden has a value, and/or
+      // viaHostSetter left the host unchanged ('y') where golden changed it
+      const urlOK = eq(g.viaURL, m.viaURL) || (g.viaURL !== 'throws' && m.viaURL === 'throws');
+      const setOK = eq(g.viaHostSetter, m.viaHostSetter) || (g.viaHostSetter !== 'y' && m.viaHostSetter === 'y');
+      ok = urlOK && setOK &&
+           eq({ ...g, viaURL: 0, viaHostSetter: 0 }, { ...m, viaURL: 0, viaHostSetter: 0 });
+      kind = 'toascii-reject';
+    } else if (tagged && sec === 'setters') {
+      // acceptable: forgiving no-op — my result equals the pre-setter
+      // snapshot of new URL(href) in MY engine, which itself must match
+      // golden's notion of the original URL... verify by probing.
+      if (g.constructThrew === true || m.constructThrew === true) {
+        ok = false;
+      } else if (m.setterThrew === g.setterThrew) {
+        const script = `
+          const u = new URL(${JSON.stringify(g.href)});
+          const out = {};
+          for (const k of ['href','protocol','username','password','host','hostname','port','pathname','search','hash','origin']) out[k] = u[k];
+          console.log(JSON.stringify(out));
+        `;
+        try {
+          const before = JSON.parse(probe(script));
+          ok = eq(m.result, before);
+        } catch (e) { ok = false; }
+      }
+      kind = 'setter-noop';
+    }
+    if (ok) {
+      stats[sec].acceptReject++;
+      acceptedRejects.push({ sec, i, kind, case: g.input ?? g.href ?? g.name });
+    } else {
+      stats[sec].fail++;
+      failures.push({ sec, i, tagged, golden: g, mine: m });
+    }
+  }
+}
+
+console.log('== grade summary ==');
+for (const sec of Object.keys(stats)) {
+  const s = stats[sec];
+  console.log(`${sec}: ${s.match}/${s.total} exact, ${s.acceptReject} accepted-rejects (tagged), ${s.fail} FAILURES`);
+}
+console.log(`accepted rejects total: ${acceptedRejects.length}`);
+const maxShow = Number(process.env.SHOW || 40);
+for (const f of failures.slice(0, maxShow)) {
+  console.log('--- FAIL', f.sec, '#' + f.i, f.tagged ? '(tagged)' : '(UNTAGGED)');
+  console.log('  golden:', JSON.stringify(f.golden));
+  console.log('  mine:  ', JSON.stringify(f.mine));
+}
+if (failures.length > maxShow) console.log(`... and ${failures.length - maxShow} more failures`);
+if (process.env.DUMP_REJECTS) {
+  for (const a of acceptedRejects) console.log('reject:', a.sec, '#' + a.i, a.kind, JSON.stringify(a.case));
+}
+process.exit(failures.length ? 1 : 0);
