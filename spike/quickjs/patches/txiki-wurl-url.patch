+/*
+ * wurl_common.h — internal shared helpers for the wurl URL implementation.
+ * Not part of the public (ada_c.h) surface.
+ */
+#ifndef WURL_COMMON_H
+#define WURL_COMMON_H
+
+#include <stdbool.h>
+#include <stddef.h>
+#include <stdint.h>
+
+/* growable byte buffer; p is kept NUL-terminated (NUL not counted in len) */
+typedef struct {
+    char *p;
+    size_t len;
+    size_t cap;
+} wbuf;
+
+void wbuf_init(wbuf *b);
+void wbuf_free(wbuf *b);
+void wbuf_clear(wbuf *b);
+void wbuf_reserve(wbuf *b, size_t extra);
+void wbuf_push(wbuf *b, char c);
+void wbuf_append(wbuf *b, const char *s, size_t n);
+void wbuf_append_cstr(wbuf *b, const char *s);
+/* steal the buffer as a malloc'd NUL-terminated string ("" if empty) */
+char *wbuf_steal(wbuf *b, size_t *len_out);
+
+/* owned, NUL-terminated string; {NULL,0} means "null" (distinct from "") */
+typedef struct {
+    char *p;
+    size_t len;
+} wstr;
+
+void wstr_free(wstr *s);
+void wstr_set(wstr *s, const char *mem, size_t n);   /* copies */
+void wstr_set_null(wstr *s);
+void wstr_set_empty(wstr *s);
+void wstr_copy(wstr *dst, const wstr *src);          /* null-preserving */
+
+/* WHATWG percent-encode sets */
+enum {
+    WURL_SET_C0 = 0,
+    WURL_SET_FRAGMENT,
+    WURL_SET_QUERY,
+    WURL_SET_SPECIAL_QUERY,
+    WURL_SET_PATH,
+    WURL_SET_USERINFO,
+    WURL_SET_COMPONENT,
+    WURL_SET_FORM,
+};
+
+bool wurl_needs_encoding(uint8_t c, int set);
+/* append c to b, percent-encoding it if it is in set */
+void wurl_enc_append(wbuf *b, uint8_t c, int set);
+/* append n bytes, percent-encoding per set */
+void wurl_enc_append_n(wbuf *b, const char *s, size_t n, int set);
+/* percent-decode s into b (raw bytes; malformed %XX passes through) */
+void wurl_percent_decode(wbuf *b, const char *s, size_t n);
+
+/* strict UTF-8: decode the codepoint at *i, advance *i; returns false on
+ * invalid input (overlong, surrogate, > U+10FFFF, truncated) */
+bool wurl_utf8_next(const uint8_t *s, size_t len, size_t *i, uint32_t *cp);
+
+#endif /* WURL_COMMON_H */
diff --git a/deps/wurl/wurl_params.c b/deps/wurl/wurl_params.c
new file mode 100644
index 0000000..4056c34
--- /dev/null
+++ b/deps/wurl/wurl_params.c
@@ -0,0 +1,546 @@
+/*
+ * wurl_params.c — URLSearchParams as byte-string pair operations
+ * (application/x-www-form-urlencoded parse/serialize), implementing the
+ * ada_c.h search-params API subset that txiki.js src/url.c consumes.
+ *
+ * Keys and values are stored as RAW BYTES (percent-decoded), and
+ * percent-encoded back on serialize — invalid UTF-8 round-trips unchanged
+ * (golden finding F3). Parsing strips ONE leading '?' (like ada; combined
+ * with url.c's own strip this reproduces golden finding F2). Sorting is
+ * stable and keyed on UTF-16 code units, not bytes.
+ */
+#include "ada_c.h"
+#include "wurl_common.h"
+
+#include <stdlib.h>
+#include <string.h>
+
+typedef struct {
+    char *k;
+    size_t klen;
+    char *v;
+    size_t vlen;
+} wpair;
+
+typedef struct {
+    wpair *items;
+    size_t n;
+    size_t cap;
+} wparams;
+
+static void params_reserve(wparams *p, size_t extra) {
+    if (p->n + extra <= p->cap) {
+        return;
+    }
+    size_t cap = p->cap ? p->cap : 8;
+    while (cap < p->n + extra) {
+        cap *= 2;
+    }
+    wpair *ni = realloc(p->items, cap * sizeof(wpair));
+    if (!ni) {
+        abort();
+    }
+    p->items = ni;
+    p->cap = cap;
+}
+
+static char *dup_bytes(const char *s, size_t n) {
+    char *p = malloc(n + 1);
+    if (!p) {
+        abort();
+    }
+    if (n) {
+        memcpy(p, s, n);
+    }
+    p[n] = '\0';
+    return p;
+}
+
+static void params_push(wparams *p, const char *k, size_t klen, const char *v,
+                        size_t vlen) {
+    params_reserve(p, 1);
+    p->items[p->n].k = dup_bytes(k, klen);
+    p->items[p->n].klen = klen;
+    p->items[p->n].v = dup_bytes(v, vlen);
+    p->items[p->n].vlen = vlen;
+    p->n++;
+}
+
+static void params_clear(wparams *p) {
+    for (size_t i = 0; i < p->n; i++) {
+        free(p->items[i].k);
+        free(p->items[i].v);
+    }
+    p->n = 0;
+}
+
+/* decode one form-urlencoded token ('+' -> space, then percent-decode) */
+static void form_decode(wbuf *out, const char *s, size_t n) {
+    wbuf plus;
+    wbuf_init(&plus);
+    for (size_t i = 0; i < n; i++) {
+        wbuf_push(&plus, s[i] == '+' ? ' ' : s[i]);
+    }
+    wurl_percent_decode(out, plus.p ? plus.p : "", plus.len);
+    wbuf_free(&plus);
+}
+
+static void params_init_from(wparams *p, const char *input, size_t len) {
+    /* strip ONE leading '?' (ada does this in initialize(); url.c already
+     * stripped one itself — reproducing golden finding F2) */
+    if (len > 0 && input[0] == '?') {
+        input++;
+        len--;
+    }
+    size_t start = 0;
+    for (size_t i = 0; i <= len; i++) {
+        if (i == len || input[i] == '&') {
+            if (i > start) {
+                const char *seq = input + start;
+                size_t seqlen = i - start;
+                size_t eq = seqlen;
+                for (size_t j = 0; j < seqlen; j++) {
+                    if (seq[j] == '=') {
+                        eq = j;
+                        break;
+                    }
+                }
+                wbuf k;
+                wbuf v;
+                wbuf_init(&k);
+                wbuf_init(&v);
+                form_decode(&k, seq, eq);
+                if (eq < seqlen) {
+                    form_decode(&v, seq + eq + 1, seqlen - eq - 1);
+                }
+                params_push(p, k.p ? k.p : "", k.len, v.p ? v.p : "", v.len);
+                wbuf_free(&k);
+                wbuf_free(&v);
+            }
+            start = i + 1;
+        }
+    }
+}
+
+/* form-urlencoded serialize: space -> '+', form set percent-encoded */
+static void form_encode(wbuf *out, const char *s, size_t n) {
+    for (size_t i = 0; i < n; i++) {
+        uint8_t c = (uint8_t)s[i];
+        if (c == ' ') {
+            wbuf_push(out, '+');
+        } else {
+            wurl_enc_append(out, c, WURL_SET_FORM);
+        }
+    }
+}
+
+/* ---- UTF-16 code-unit comparison for sort ---- */
+
+/* decode the next UTF-16 code unit from UTF-8-ish bytes; lone/invalid bytes
+ * yield U+FFFD (one per byte). state carries a pending low surrogate. */
+typedef struct {
+    const uint8_t *s;
+    size_t len;
+    size_t i;
+    uint32_t pending; /* 0 = none, else the low surrogate to emit next */
+} u16stream;
+
+static bool u16_next(u16stream *st, uint32_t *unit) {
+    if (st->pending) {
+        *unit = st->pending;
+        st->pending = 0;
+        return true;
+    }
+    if (st->i >= st->len) {
+        return false;
+    }
+    uint32_t cp;
+    size_t before = st->i;
+    if (!wurl_utf8_next(st->s, st->len, &st->i, &cp)) {
+        /* WTF-8 surrogate encodings (ED A0..BF ..) decode to the raw
+         * surrogate code unit; anything else invalid -> U+FFFD per byte */
+        if (st->i == before && before + 2 < st->len &&
+            st->s[before] == 0xed && (st->s[before + 1] & 0xe0) == 0xa0 &&
+            (st->s[before + 2] & 0xc0) == 0x80) {
+            cp = 0xd000 | ((uint32_t)(st->s[before + 1] & 0x3f) << 6) |
+                 (st->s[before + 2] & 0x3f);
+            st->i = before + 3;
+            *unit = cp;
+            return true;
+        }
+        st->i = before + 1;
+        *unit = 0xfffd;
+        return true;
+    }
+    if (cp >= 0x10000) {
+        cp -= 0x10000;
+        *unit = 0xd800 + (cp >> 10);
+        st->pending = 0xdc00 + (cp & 0x3ff);
+        return true;
+    }
+    *unit = cp;
+    return true;
+}
+
+static int key_cmp_u16(const wpair *a, const wpair *b) {
+    u16stream sa = { (const uint8_t *)a->k, a->klen, 0, 0 };
+    u16stream sb = { (const uint8_t *)b->k, b->klen, 0, 0 };
+    for (;;) {
+        uint32_t ua;
+        uint32_t ub;
+        bool ha = u16_next(&sa, &ua);
+        bool hb = u16_next(&sb, &ub);
+        if (!ha && !hb) {
+            return 0;
+        }
+        if (!ha) {
+            return -1;
+        }
+        if (!hb) {
+            return 1;
+        }
+        if (ua != ub) {
+            return ua < ub ? -1 : 1;
+        }
+    }
+}
+
+/* ---- ada_c API ---- */
+
+ada_url_search_params ada_parse_search_params(const char *input, size_t length) {
+    wparams *p = calloc(1, sizeof(wparams));
+    if (!p) {
+        abort();
+    }
+    params_init_from(p, input ? input : "", input ? length : 0);
+    return p;
+}
+
+void ada_free_search_params(ada_url_search_params result) {
+    wparams *p = result;
+    if (p) {
+        params_clear(p);
+        free(p->items);
+        free(p);
+    }
+}
+
+size_t ada_search_params_size(ada_url_search_params result) {
+    wparams *p = result;
+    return p->n;
+}
+
+void ada_search_params_sort(ada_url_search_params result) {
+    wparams *p = result;
+    /* stable insertion sort keyed on UTF-16 code units */
+    for (size_t i = 1; i < p->n; i++) {
+        wpair cur = p->items[i];
+        size_t j = i;
+        while (j > 0 && key_cmp_u16(&p->items[j - 1], &cur) > 0) {
+            p->items[j] = p->items[j - 1];
+            j--;
+        }
+        p->items[j] = cur;
+    }
+}
+
+ada_owned_string ada_search_params_to_string(ada_url_search_params result) {
+    wparams *p = result;
+    wbuf b;
+    wbuf_init(&b);
+    for (size_t i = 0; i < p->n; i++) {
+        if (i > 0) {
+            wbuf_push(&b, '&');
+        }
+        form_encode(&b, p->items[i].k, p->items[i].klen);
+        wbuf_push(&b, '=');
+        form_encode(&b, p->items[i].v, p->items[i].vlen);
+    }
+    ada_owned_string s;
+    s.length = b.len;
+    s.data = wbuf_steal(&b, NULL);
+    return s;
+}
+
+void ada_search_params_append(ada_url_search_params result, const char *key,
+                              size_t key_length, const char *value,
+                              size_t value_length) {
+    wparams *p = result;
+    params_push(p, key ? key : "", key_length, value ? value : "", value_length);
+}
+
+static bool pair_key_eq(const wpair *pr, const char *key, size_t key_length) {
+    return pr->klen == key_length &&
+           (key_length == 0 || memcmp(pr->k, key, key_length) == 0);
+}
+
+static bool pair_value_eq(const wpair *pr, const char *value, size_t value_length) {
+    return pr->vlen == value_length &&
+           (value_length == 0 || memcmp(pr->v, value, value_length) == 0);
+}
+
+void ada_search_params_set(ada_url_search_params result, const char *key,
+                           size_t key_length, const char *value,
+                           size_t value_length) {
+    wparams *p = result;
+    size_t w = 0;
+    bool found = false;
+    for (size_t i = 0; i < p->n; i++) {
+        if (pair_key_eq(&p->items[i], key, key_length)) {
+            if (!found) {
+                found = true;
+                free(p->items[i].v);
+                p->items[i].v = dup_bytes(value ? value : "", value_length);
+                p->items[i].vlen = value_length;
+                p->items[w++] = p->items[i];
+            } else {
+                free(p->items[i].k);
+                free(p->items[i].v);
+            }
+        } else {
+            p->items[w++] = p->items[i];
+        }
+    }
+    p->n = w;
+    if (!found) {
+        params_push(p, key ? key : "", key_length, value ? value : "",
+                    value_length);
+    }
+}
+
+void ada_search_params_remove(ada_url_search_params result, const char *key,
+                              size_t key_length) {
+    wparams *p = result;
+    size_t w = 0;
+    for (size_t i = 0; i < p->n; i++) {
+        if (pair_key_eq(&p->items[i], key, key_length)) {
+            free(p->items[i].k);
+            free(p->items[i].v);
+        } else {
+            p->items[w++] = p->items[i];
+        }
+    }
+    p->n = w;
+}
+
+void ada_search_params_remove_value(ada_url_search_params result,
+                                    const char *key, size_t key_length,
+                                    const char *value, size_t value_length) {
+    wparams *p = result;
+    size_t w = 0;
+    for (size_t i = 0; i < p->n; i++) {
+        if (pair_key_eq(&p->items[i], key, key_length) &&
+            pair_value_eq(&p->items[i], value, value_length)) {
+            free(p->items[i].k);
+            free(p->items[i].v);
+        } else {
+            p->items[w++] = p->items[i];
+        }
+    }
+    p->n = w;
+}
+
+bool ada_search_params_has(ada_url_search_params result, const char *key,
+                           size_t key_length) {
+    wparams *p = result;
+    for (size_t i = 0; i < p->n; i++) {
+        if (pair_key_eq(&p->items[i], key, key_length)) {
+            return true;
+        }
+    }
+    return false;
+}
+
+bool ada_search_params_has_value(ada_url_search_params result, const char *key,
+                                 size_t key_length, const char *value,
+                                 size_t value_length) {
+    wparams *p = result;
+    for (size_t i = 0; i < p->n; i++) {
+        if (pair_key_eq(&p->items[i], key, key_length) &&
+            pair_value_eq(&p->items[i], value, value_length)) {
+            return true;
+        }
+    }
+    return false;
+}
+
+ada_string ada_search_params_get(ada_url_search_params result, const char *key,
+                                 size_t key_length) {
+    wparams *p = result;
+    for (size_t i = 0; i < p->n; i++) {
+        if (pair_key_eq(&p->items[i], key, key_length)) {
+            ada_string s = { p->items[i].v, p->items[i].vlen };
+            return s;
+        }
+    }
+    ada_string s = { NULL, 0 };
+    return s;
+}
+
+/* ---- ada_strings (borrowed views snapshot) ---- */
+
+typedef struct {
+    ada_string *arr;
+    size_t n;
+} wstrings;
+
+ada_strings ada_search_params_get_all(ada_url_search_params result,
+                                      const char *key, size_t key_length) {
+    wparams *p = result;
+    wstrings *out = calloc(1, sizeof(wstrings));
+    if (!out) {
+        abort();
+    }
+    size_t count = 0;
+    for (size_t i = 0; i < p->n; i++) {
+        if (pair_key_eq(&p->items[i], key, key_length)) {
+            count++;
+        }
+    }
+    if (count) {
+        out->arr = malloc(count * sizeof(ada_string));
+        if (!out->arr) {
+            abort();
+        }
+        for (size_t i = 0; i < p->n; i++) {
+            if (pair_key_eq(&p->items[i], key, key_length)) {
+                out->arr[out->n].data = p->items[i].v;
+                out->arr[out->n].length = p->items[i].vlen;
+                out->n++;
+            }
+        }
+    }
+    return out;
+}
+
+void ada_free_strings(ada_strings result) {
+    wstrings *s = result;
+    if (s) {
+        free(s->arr);
+        free(s);
+    }
+}
+
+size_t ada_strings_size(ada_strings result) {
+    wstrings *s = result;
+    return s->n;
+}
+
+ada_string ada_strings_get(ada_strings result, size_t index) {
+    wstrings *s = result;
+    if (index >= s->n) {
+        ada_string e = { NULL, 0 };
+        return e;
+    }
+    return s->arr[index];
+}
+
+void ada_search_params_reset(ada_url_search_params result, const char *input,
+                             size_t length) {
+    wparams *p = result;
+    params_clear(p);
+    params_init_from(p, input ? input : "", input ? length : 0);
+}
+
+/* ---- iterators (index over the live list; url.c materializes immediately
+ * and performs no mutation while iterating) ---- */
+
+typedef struct {
+    wparams *p;
+    size_t i;
+} wsp_iter;
+
+static wsp_iter *iter_new(wparams *p) {
+    wsp_iter *it = malloc(sizeof(wsp_iter));
+    if (!it) {
+        abort();
+    }
+    it->p = p;
+    it->i = 0;
+    return it;
+}
+
+ada_url_search_params_keys_iter ada_search_params_get_keys(
+    ada_url_search_params result) {
+    return iter_new(result);
+}
+
+ada_url_search_params_values_iter ada_search_params_get_values(
+    ada_url_search_params result) {
+    return iter_new(result);
+}
+
+ada_url_search_params_entries_iter ada_search_params_get_entries(
+    ada_url_search_params result) {
+    return iter_new(result);
+}
+
+void ada_free_search_params_keys_iter(ada_url_search_params_keys_iter result) {
+    free(result);
+}
+
+void ada_free_search_params_values_iter(
+    ada_url_search_params_values_iter result) {
+    free(result);
+}
+
+void ada_free_search_params_entries_iter(
+    ada_url_search_params_entries_iter result) {
+    free(result);
+}
+
+bool ada_search_params_keys_iter_has_next(
+    ada_url_search_params_keys_iter result) {
+    wsp_iter *it = result;
+    return it->i < it->p->n;
+}
+
+bool ada_search_params_values_iter_has_next(
+    ada_url_search_params_values_iter result) {
+    wsp_iter *it = result;
+    return it->i < it->p->n;
+}
+
+bool ada_search_params_entries_iter_has_next(
+    ada_url_search_params_entries_iter result) {
+    wsp_iter *it = result;
+    return it->i < it->p->n;
+}
+
+ada_string ada_search_params_keys_iter_next(
+    ada_url_search_params_keys_iter result) {
+    wsp_iter *it = result;
+    ada_string s = { NULL, 0 };
+    if (it->i < it->p->n) {
+        s.data = it->p->items[it->i].k;
+        s.length = it->p->items[it->i].klen;
+        it->i++;
+    }
+    return s;
+}
+
+ada_string ada_search_params_values_iter_next(
+    ada_url_search_params_values_iter result) {
+    wsp_iter *it = result;
+    ada_string s = { NULL, 0 };
+    if (it->i < it->p->n) {
+        s.data = it->p->items[it->i].v;
+        s.length = it->p->items[it->i].vlen;
+        it->i++;
+    }
+    return s;
+}
+
+ada_string_pair ada_search_params_entries_iter_next(
+    ada_url_search_params_entries_iter result) {
+    wsp_iter *it = result;
+    ada_string_pair pr = { { NULL, 0 }, { NULL, 0 } };
+    if (it->i < it->p->n) {
+        pr.key.data = it->p->items[it->i].k;
+        pr.key.length = it->p->items[it->i].klen;
+        pr.value.data = it->p->items[it->i].v;
+        pr.value.length = it->p->items[it->i].vlen;
+        it->i++;
+    }
+    return pr;
+}
diff --git a/deps/wurl/wurl_url.c b/deps/wurl/wurl_url.c
new file mode 100644
index 0000000..c3d42c7
--- /dev/null
+++ b/deps/wurl/wurl_url.c
@@ -0,0 +1,1913 @@
+/*
+ * wurl_url.c — plain-C WHATWG URL: basic-URL state machine, host parsing
+ * (domain + IDNA L1', IPv4, IPv6, opaque), serialization, and the ada_c.h
+ * URL-object API subset that txiki.js src/url.c consumes.
+ *
+ * Contract: reproduce the behavior frozen in the clode repo's
+ * test/fixtures/url/golden-tjs-url.json (vendored ada 3.4.2). See
+ * spike/quickjs/results/ada-ectomy-contract.md.
+ *
+ * IDNA level: L1' — ASCII lowercasing + RFC 3492 punycode + a generated
+ * allow-bitmap (idna_allow.h). A codepoint outside the bitmap is rejected
+ * LOUDLY (parse failure), never silently mis-parsed. Full UTS-46 (L2) is a
+ * later phase; its seams are wurl_idna_allowed() (replace bitmap with
+ * mapping table lookup + NFC via quickjs-ng libunicode) and
+ * domain_label_to_ascii() below.
+ */
+#include "ada_c.h"
+#include "idna_allow.h"
+#include "wurl_common.h"
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+
+/* ================= URL record ================= */
+
+typedef struct wurl {
+    bool valid;
+    bool has_host;
+    bool path_opaque;
+    int32_t port; /* -1 = null */
+    wstr scheme;  /* lowercase, no ':' */
+    wstr username;
+    wstr password;
+    wstr host; /* serialized; meaningful iff has_host */
+    wstr path; /* serialized: "" | "/a/b" (list form) or raw (opaque) */
+    wstr query;    /* p==NULL -> null */
+    wstr fragment; /* p==NULL -> null */
+    wbuf scratch;  /* backs borrowed getter views */
+} wurl;
+
+static void wurl_record_init(wurl *u) {
+    memset(u, 0, sizeof(*u));
+    u->port = -1;
+    wstr_set_empty(&u->scheme);
+    wstr_set_empty(&u->username);
+    wstr_set_empty(&u->password);
+    wstr_set_empty(&u->path);
+    /* host/query/fragment start null */
+    wbuf_init(&u->scratch);
+}
+
+static void wurl_record_clear(wurl *u) {
+    wstr_free(&u->scheme);
+    wstr_free(&u->username);
+    wstr_free(&u->password);
+    wstr_free(&u->host);
+    wstr_free(&u->path);
+    wstr_free(&u->query);
+    wstr_free(&u->fragment);
+    wbuf_free(&u->scratch);
+}
+
+/* ================= special schemes ================= */
+
+typedef struct {
+    const char *name;
+    size_t len;
+    int32_t port;
+} scheme_entry;
+
+static const scheme_entry SPECIAL[] = {
+    { "http", 4, 80 },  { "https", 5, 443 }, { "ws", 2, 80 },
+    { "wss", 3, 443 },  { "ftp", 3, 21 },    { "file", 4, -1 },
+};
+
+static const scheme_entry *special_lookup(const char *s, size_t n) {
+    for (size_t i = 0; i < sizeof(SPECIAL) / sizeof(SPECIAL[0]); i++) {
+        if (SPECIAL[i].len == n && memcmp(SPECIAL[i].name, s, n) == 0) {
+            return &SPECIAL[i];
+        }
+    }
+    return NULL;
+}
+
+static bool is_special_url(const wurl *u) {
+    return special_lookup(u->scheme.p, u->scheme.len) != NULL;
+}
+
+static bool scheme_is(const wurl *u, const char *name) {
+    return u->scheme.p && strcmp(u->scheme.p, name) == 0;
+}
+
+static int32_t default_port(const char *s, size_t n) {
+    const scheme_entry *e = special_lookup(s, n);
+    return e ? e->port : -1;
+}
+
+static bool includes_credentials(const wurl *u) {
+    return u->username.len > 0 || u->password.len > 0;
+}
+
+/* "cannot have a username/password/port": host null or empty, or file */
+static bool cannot_have_credentials_or_port(const wurl *u) {
+    return !u->has_host || u->host.len == 0 || scheme_is(u, "file");
+}
+
+/* ================= small char helpers ================= */
+
+static bool is_alpha(uint8_t c) {
+    return (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z');
+}
+
+static bool is_digit(uint8_t c) {
+    return c >= '0' && c <= '9';
+}
+
+static bool is_alnum(uint8_t c) {
+    return is_alpha(c) || is_digit(c);
+}
+
+static uint8_t to_lower(uint8_t c) {
+    return (c >= 'A' && c <= 'Z') ? (uint8_t)(c + 32) : c;
+}
+
+static bool is_windows_drive(const char *s, size_t n) {
+    return n == 2 && is_alpha((uint8_t)s[0]) && (s[1] == ':' || s[1] == '|');
+}
+
+static bool is_normalized_windows_drive(const char *s, size_t n) {
+    return n == 2 && is_alpha((uint8_t)s[0]) && s[1] == ':';
+}
+
+/* input[i..] starts with a Windows drive letter */
+static bool starts_with_windows_drive(const char *s, size_t i, size_t n) {
+    if (i + 2 > n) {
+        return false;
+    }
+    if (!is_alpha((uint8_t)s[i]) || (s[i + 1] != ':' && s[i + 1] != '|')) {
+        return false;
+    }
+    if (i + 2 == n) {
+        return true;
+    }
+    char c = s[i + 2];
+    return c == '/' || c == '\\' || c == '?' || c == '#';
+}
+
+/* first path segment of a serialized (non-opaque) path "/seg/..." */
+static bool first_seg_is_normalized_drive(const wstr *path) {
+    if (path->len < 3 || path->p[0] != '/') {
+        return false;
+    }
+    size_t end = 1;
+    while (end < path->len && path->p[end] != '/') {
+        end++;
+    }
+    return is_normalized_windows_drive(path->p + 1, end - 1);
+}
+
+/* shorten url's path (remove last segment), file drive guard */
+static void shorten_path(wurl *u) {
+    if (scheme_is(u, "file") && u->path.len == 3 &&
+        is_normalized_windows_drive(u->path.p + 1, 2)) {
+        return;
+    }
+    if (u->path.len == 0) {
+        return;
+    }
+    size_t i = u->path.len;
+    while (i > 0 && u->path.p[i - 1] != '/') {
+        i--;
+    }
+    if (i > 0) {
+        i--; /* drop the '/' too */
+    }
+    wstr_set(&u->path, u->path.p, i);
+}
+
+/* append one (already percent-encoded) segment to a list-form path */
+static void path_append_segment(wurl *u, const char *seg, size_t n) {
+    wbuf b;
+    wbuf_init(&b);
+    wbuf_append(&b, u->path.p, u->path.len);
+    wbuf_push(&b, '/');
+    wbuf_append(&b, seg, n);
+    size_t len;
+    char *p = wbuf_steal(&b, &len);
+    free(u->path.p);
+    u->path.p = p;
+    u->path.len = len;
+}
+
+/* ================= punycode (RFC 3492) ================= */
+
+#define PUNY_BASE 36
+#define PUNY_TMIN 1
+#define PUNY_TMAX 26
+#define PUNY_SKEW 38
+#define PUNY_DAMP 700
+#define PUNY_INITIAL_BIAS 72
+#define PUNY_INITIAL_N 128
+
+static uint32_t puny_adapt(uint32_t delta, uint32_t numpoints, bool firsttime) {
+    delta = firsttime ? delta / PUNY_DAMP : delta / 2;
+    delta += delta / numpoints;
+    uint32_t k = 0;
+    while (delta > ((PUNY_BASE - PUNY_TMIN) * PUNY_TMAX) / 2) {
+        delta /= PUNY_BASE - PUNY_TMIN;
+        k += PUNY_BASE;
+    }
+    return k + ((PUNY_BASE - PUNY_TMIN + 1) * delta) / (delta + PUNY_SKEW);
+}
+
+static char puny_digit_char(uint32_t d) {
+    return (char)(d < 26 ? 'a' + d : '0' + (d - 26));
+}
+
+static int puny_digit_val(uint8_t c) {
+    if (c >= 'a' && c <= 'z') {
+        return c - 'a';
+    }
+    if (c >= 'A' && c <= 'Z') {
+        return c - 'A';
+    }
+    if (c >= '0' && c <= '9') {
+        return c - '0' + 26;
+    }
+    return -1;
+}
+
+/* encode cps[0..n) -> out (without the "xn--" prefix); false on overflow */
+static bool puny_encode(const uint32_t *cps, size_t ncps, wbuf *out) {
+    uint32_t n = PUNY_INITIAL_N;
+    uint32_t delta = 0;
+    uint32_t bias = PUNY_INITIAL_BIAS;
+    size_t b = 0;
+    for (size_t i = 0; i < ncps; i++) {
+        if (cps[i] < 0x80) {
+            wbuf_push(out, (char)cps[i]);
+            b++;
+        }
+    }
+    size_t h = b;
+    if (b > 0) {
+        wbuf_push(out, '-');
+    }
+    while (h < ncps) {
+        uint32_t m = 0x110000;
+        for (size_t i = 0; i < ncps; i++) {
+            if (cps[i] >= n && cps[i] < m) {
+                m = cps[i];
+            }
+        }
+        if ((uint64_t)(m - n) * (h + 1) > 0xffffffffu - delta) {
+            return false;
+        }
+        delta += (m - n) * (uint32_t)(h + 1);
+        n = m;
+        for (size_t i = 0; i < ncps; i++) {
+            uint32_t c = cps[i];
+            if (c < n) {
+                if (++delta == 0) {
+                    return false;
+                }
+            } else if (c == n) {
+                uint32_t q = delta;
+                for (uint32_t k = PUNY_BASE;; k += PUNY_BASE) {
+                    uint32_t t = k <= bias ? PUNY_TMIN
+                                           : (k >= bias + PUNY_TMAX ? PUNY_TMAX : k - bias);
+                    if (q < t) {
+                        break;
+                    }
+                    wbuf_push(out, puny_digit_char(t + (q - t) % (PUNY_BASE - t)));
+                    q = (q - t) / (PUNY_BASE - t);
+                }
+                wbuf_push(out, puny_digit_char(q));
+                bias = puny_adapt(delta, (uint32_t)(h + 1), h == b);
+                delta = 0;
+                h++;
+            }
+        }
+        delta++;
+        n++;
+    }
+    return true;
+}
+
+/* decode s[0..n) (without "xn--") into a malloc'd cp array; false on error */
+static bool puny_decode(const char *s, size_t n, uint32_t **out_cps, size_t *out_n) {
+    size_t cap = n + 1;
+    uint32_t *cps = malloc(cap * sizeof(uint32_t));
+    if (!cps) {
+        abort();
+    }
+    size_t ncps = 0;
+    size_t in = 0;
+    /* basic code points: up to the LAST delimiter '-' */
+    size_t delim = (size_t)-1;
+    for (size_t i = 0; i < n; i++) {
+        if (s[i] == '-') {
+            delim = i;
+        }
+    }
+    if (delim != (size_t)-1) {
+        for (size_t i = 0; i < delim; i++) {
+            if ((uint8_t)s[i] >= 0x80) {
+                free(cps);
+                return false;
+            }
+            cps[ncps++] = (uint8_t)s[i];
+        }
+        in = delim + 1;
+    }
+    uint32_t i = 0;
+    uint32_t nn = PUNY_INITIAL_N;
+    uint32_t bias = PUNY_INITIAL_BIAS;
+    while (in < n) {
+        uint32_t oldi = i;
+        uint32_t w = 1;
+        for (uint32_t k = PUNY_BASE;; k += PUNY_BASE) {
+            if (in >= n) {
+                free(cps);
+                return false;
+            }
+            int d = puny_digit_val((uint8_t)s[in++]);
+            if (d < 0) {
+                free(cps);
+                return false;
+            }
+            if ((uint64_t)d * w > 0xffffffffu - i) {
+                free(cps);
+                return false;
+            }
+            i += (uint32_t)d * w;
+            uint32_t t = k <= bias ? PUNY_TMIN
+                                   : (k >= bias + PUNY_TMAX ? PUNY_TMAX : k - bias);
+            if ((uint32_t)d < t) {
+                break;
+            }
+            if ((uint64_t)w * (PUNY_BASE - t) > 0xffffffffu) {
+                free(cps);
+                return false;
+            }
+            w *= PUNY_BASE - t;
+        }
+        bias = puny_adapt(i - oldi, (uint32_t)(ncps + 1), oldi == 0);
+        if (i / (ncps + 1) > 0x10ffff - nn) {
+            free(cps);
+            return false;
+        }
+        nn += i / (uint32_t)(ncps + 1);
+        i %= (uint32_t)(ncps + 1);
+        if (nn > 0x10ffff) {
+            free(cps);
+            return false;
+        }
+        if (ncps + 1 > cap) {
+            cap = cap * 2 + 4;
+            uint32_t *np = realloc(cps, cap * sizeof(uint32_t));
+            if (!np) {
+                abort();
+            }
+            cps = np;
+        }
+        memmove(cps + i + 1, cps + i, (ncps - i) * sizeof(uint32_t));
+        cps[i] = nn;
+        ncps++;
+        i++;
+    }
+    *out_cps = cps;
+    *out_n = ncps;
+    return true;
+}
+
+/* ================= IDNA L1' ================= */
+
+static bool wurl_idna_allowed(uint32_t cp) {
+    if (cp < 0x80) {
+        return true; /* ASCII handled by callers */
+    }
+    if (cp < 0x10000) {
+        return (wurl_idna_allow_bmp[cp >> 3] & (1u << (cp & 7))) != 0;
+    }
+    size_t lo = 0;
+    size_t hi = WURL_IDNA_ALLOW_ASTRAL_COUNT;
+    while (lo < hi) {
+        size_t mid = (lo + hi) / 2;
+        if (cp < wurl_idna_allow_astral[mid][0]) {
+            hi = mid;
+        } else if (cp > wurl_idna_allow_astral[mid][1]) {
+            lo = mid + 1;
+        } else {
+            return true;
+        }
+    }
+    return false;
+}
+
+/*
+ * Convert one label (bytes, valid UTF-8) to its ASCII form, appending to
+ * out. L1' rules:
+ *  - all-ASCII label: lowercase; "xn--" labels are punycode-decoded,
+ *    every decoded codepoint must be admissible (bitmap; ASCII must be
+ *    already-lowercase, no '.'), and must re-encode to the identical label
+ *    (round-trip check), else loud failure;
+ *  - label with non-ASCII: ASCII letters lowercased, every non-ASCII
+ *    codepoint must be in the allow-bitmap (else loud failure), then
+ *    punycode-encode as "xn--...".
+ * L2 TODO seam: replace with full UTS-46 map + NFC + validity.
+ */
+static bool domain_label_to_ascii(const char *s, size_t n, wbuf *out) {
+    bool ascii = true;
+    for (size_t i = 0; i < n; i++) {
+        if ((uint8_t)s[i] >= 0x80) {
+            ascii = false;
+            break;
+        }
+    }
+    if (ascii) {
+        size_t start = out->len;
+        for (size_t i = 0; i < n; i++) {
+            wbuf_push(out, (char)to_lower((uint8_t)s[i]));
+        }
+        char *label = out->p + start;
+        if (n >= 4 && memcmp(label, "xn--", 4) == 0) {
+            /* validate the punycode */
+            uint32_t *cps = NULL;
+            size_t ncps = 0;
+            if (!puny_decode(label + 4, n - 4, &cps, &ncps)) {
+                return false;
+            }
+            bool has_non_ascii = false;
+            for (size_t i = 0; i < ncps; i++) {
+                uint32_t cp = cps[i];
+                if (cp < 0x80) {
+                    if ((cp >= 'A' && cp <= 'Z') || cp == '.') {
+                        free(cps);
+                        return false;
+                    }
+                } else {
+                    has_non_ascii = true;
+                    if (!wurl_idna_allowed(cp)) {
+                        free(cps);
+                        return false;
+                    }
+                }
+            }
+            /* decoding to pure ASCII is invalid (would not round-trip
+             * through ToUnicode) */
+            if (!has_non_ascii) {
+                free(cps);
+                return false;
+            }
+            /* round-trip: re-encoding must reproduce the label exactly */
+            wbuf re;
+            wbuf_init(&re);
+            bool ok = puny_encode(cps, ncps, &re);
+            free(cps);
+            if (!ok || re.len != n - 4 || memcmp(re.p, label + 4, n - 4) != 0) {
+                wbuf_free(&re);
+                return false;
+            }
+            wbuf_free(&re);
+        }
+        return true;
+    }
+
+    /* a label that begins with "xn--" (ASCII-case-insensitively) but is not
+     * all-ASCII cannot be punycode-decoded: loud failure (matches ada) */
+    if (n >= 4 && to_lower((uint8_t)s[0]) == 'x' && to_lower((uint8_t)s[1]) == 'n' &&
+        s[2] == '-' && s[3] == '-') {
+        return false;
+    }
+
+    /* non-ASCII label: decode, admit, punycode */
+    uint32_t *cps = malloc((n + 1) * sizeof(uint32_t));
+    if (!cps) {
+        abort();
+    }
+    size_t ncps = 0;
+    size_t i = 0;
+    while (i < n) {
+        uint32_t cp;
+        if (!wurl_utf8_next((const uint8_t *)s, n, &i, &cp)) {
+            free(cps);
+            return false; /* unreachable: caller validated UTF-8 */
+        }
+        if (cp < 0x80) {
+            cp = to_lower((uint8_t)cp);
+        } else if (!wurl_idna_allowed(cp)) {
+            free(cps);
+            return false;
+        }
+        cps[ncps++] = cp;
+    }
+    wbuf_append_cstr(out, "xn--");
+    bool ok = puny_encode(cps, ncps, out);
+    free(cps);
+    return ok;
+}
+
+/* domain to ASCII (beStrict=false); input = percent-decoded bytes */
+static bool domain_to_ascii(const char *s, size_t n, wbuf *out) {
+    /* whole-domain UTF-8 validation (ada fails on invalid UTF-8) */
+    {
+        size_t i = 0;
+        uint32_t cp;
+        while (i < n) {
+            if (!wurl_utf8_next((const uint8_t *)s, n, &i, &cp)) {
+                return false;
+            }
+        }
+    }
+    size_t start = 0;
+    bool first = true;
+    size_t begin_len = out->len;
+    for (size_t i = 0; i <= n; i++) {
+        if (i == n || s[i] == '.') {
+            if (!first) {
+                wbuf_push(out, '.');
+            }
+            first = false;
+            if (!domain_label_to_ascii(s + start, i - start, out)) {
+                return false;
+            }
+            start = i + 1;
+        }
+    }
+    if (out->len == begin_len) {
+        return false; /* empty result is a validation error */
+    }
+    return true;
+}
+
+/* ================= IPv4 ================= */
+
+/* returns -1 on failure, else the parsed value (<= 0xffffffff or a
+ * sentinel larger than any passing value) */
+static int64_t parse_ipv4_number(const char *s, size_t n) {
+    if (n == 0) {
+        return -1;
+    }
+    int radix = 10;
+    if (n >= 2 && s[0] == '0' && (s[1] == 'x' || s[1] == 'X')) {
+        radix = 16;
+        s += 2;
+        n -= 2;
+    } else if (n >= 2 && s[0] == '0') {
+        radix = 8;
+        s += 1;
+        n -= 1;
+    }
+    if (n == 0) {
+        return 0;
+    }
+    uint64_t v = 0;
+    for (size_t i = 0; i < n; i++) {
+        int d;
+        uint8_t c = (uint8_t)s[i];
+        if (c >= '0' && c <= '9') {
+            d = c - '0';
+        } else if (radix == 16 && c >= 'a' && c <= 'f') {
+            d = c - 'a' + 10;
+        } else if (radix == 16 && c >= 'A' && c <= 'F') {
+            d = c - 'A' + 10;
+        } else {
+            return -1;
+        }
+        if (d >= radix) {
+            return -1;
+        }
+        v = v * (uint64_t)radix + (uint64_t)d;
+        if (v > 0x1ffffffffull) {
+            v = 0x1ffffffffull; /* clamp above any passing threshold */
+        }
+    }
+    return (int64_t)v;
+}
+
+static bool domain_ends_in_number(const char *s, size_t n) {
+    /* find last non-empty-after-trailing-dot part */
+    size_t end = n;
+    if (end > 0 && s[end - 1] == '.') {
+        end--;
+        if (end == 0) {
+            return false; /* input was "." (single empty part) */
+        }
+    }
+    size_t start = end;
+    while (start > 0 && s[start - 1] != '.') {
+        start--;
+    }
+    size_t len = end - start;
+    if (len == 0) {
+        return false;
+    }
+    bool all_digits = true;
+    for (size_t i = start; i < end; i++) {
+        if (!is_digit((uint8_t)s[i])) {
+            all_digits = false;
+            break;
+        }
+    }
+    if (all_digits) {
+        return true;
+    }
+    return parse_ipv4_number(s + start, len) >= 0;
+}
+
+static bool parse_ipv4(const char *s, size_t n, wbuf *out) {
+    /* split on '.'; a single trailing empty part is dropped */
+    if (n > 0 && s[n - 1] == '.') {
+        n--;
+    }
+    const char *parts[6];
+    size_t plens[6];
+    size_t nparts = 0;
+    size_t start = 0;
+    for (size_t i = 0; i <= n; i++) {
+        if (i == n || s[i] == '.') {
+            if (nparts >= 5) {
+                return false; /* > 4 parts fails anyway */
+            }
+            parts[nparts] = s + start;
+            plens[nparts] = i - start;
+            nparts++;
+            start = i + 1;
+        }
+    }
+    if (nparts > 4) {
+        return false;
+    }
+    int64_t nums[4];
+    for (size_t i = 0; i < nparts; i++) {
+        nums[i] = parse_ipv4_number(parts[i], plens[i]);
+        if (nums[i] < 0) {
+            return false;
+        }
+    }
+    for (size_t i = 0; i + 1 < nparts; i++) {
+        if (nums[i] > 255) {
+            return false;
+        }
+    }
+    uint64_t limit = 1;
+    for (size_t i = 0; i < 5 - nparts; i++) {
+        limit *= 256;
+    }
+    if ((uint64_t)nums[nparts - 1] >= limit) {
+        return false;
+    }
+    uint32_t ipv4 = (uint32_t)nums[nparts - 1];
+    for (size_t i = 0; i + 1 < nparts; i++) {
+        ipv4 += (uint32_t)(nums[i] << (8 * (3 - i)));
+    }
+    char tmp[16];
+    snprintf(tmp, sizeof(tmp), "%u.%u.%u.%u", (ipv4 >> 24) & 0xff,
+             (ipv4 >> 16) & 0xff, (ipv4 >> 8) & 0xff, ipv4 & 0xff);
+    wbuf_append_cstr(out, tmp);
+    return true;
+}
+
+/* ================= IPv6 ================= */
+
+static int hex_digit(uint8_t c) {
+    if (c >= '0' && c <= '9') {
+        return c - '0';
+    }
+    if (c >= 'a' && c <= 'f') {
+        return c - 'a' + 10;
+    }
+    if (c >= 'A' && c <= 'F') {
+        return c - 'A' + 10;
+    }
+    return -1;
+}
+
+static bool parse_ipv6(const char *s, size_t n, uint16_t address[8]) {
+    memset(address, 0, 16);
+    int piece_index = 0;
+    int compress = -1;
+    size_t p = 0;
+
+    if (p < n && s[p] == ':') {
+        if (p + 1 >= n || s[p + 1] != ':') {
+            return false;
+        }
+        p += 2;
+        piece_index = 1;
+        compress = 1;
+    }
+    while (p < n) {
+        if (piece_index == 8) {
+            return false;
+        }
+        if (s[p] == ':') {
+            if (compress != -1) {
+                return false;
+            }
+            p++;
+            piece_index++;
+            compress = piece_index;
+            continue;
+        }
+        uint32_t value = 0;
+        int length = 0;
+        while (length < 4 && p < n && hex_digit((uint8_t)s[p]) >= 0) {
+            value = value * 0x10 + (uint32_t)hex_digit((uint8_t)s[p]);
+            p++;
+            length++;
+        }
+        if (p < n && s[p] == '.') {
+            if (length == 0) {
+                return false;
+            }
+            p -= (size_t)length;
+            if (piece_index > 6) {
+                return false;
+            }
+            int numbers_seen = 0;
+            while (p < n) {
+                int ipv4_piece = -1;
+                if (numbers_seen > 0) {
+                    if (s[p] == '.' && numbers_seen < 4) {
+                        p++;
+                    } else {
+                        return false;
+                    }
+                }
+                if (p >= n || !is_digit((uint8_t)s[p])) {
+                    return false;
+                }
+                while (p < n && is_digit((uint8_t)s[p])) {
+                    int d = s[p] - '0';
+                    if (ipv4_piece == -1) {
+                        ipv4_piece = d;
+                    } else if (ipv4_piece == 0) {
+                        return false;
+                    } else {
+                        ipv4_piece = ipv4_piece * 10 + d;
+                    }
+                    if (ipv4_piece > 255) {
+                        return false;
+                    }
+                    p++;
+                }
+                address[piece_index] =
+                    (uint16_t)(address[piece_index] * 0x100 + ipv4_piece);
+                numbers_seen++;
+                if (numbers_seen == 2 || numbers_seen == 4) {
+                    piece_index++;
+                }
+            }
+            if (numbers_seen != 4) {
+                return false;
+            }
+            break;
+        } else if (p < n && s[p] == ':') {
+            p++;
+            if (p >= n) {
+                return false;
+            }
+        } else if (p < n) {
+            return false;
+        }
+        address[piece_index] = (uint16_t)value;
+        piece_index++;
+    }
+    if (compress != -1) {
+        int swaps = piece_index - compress;
+        piece_index = 7;
+        while (piece_index != 0 && swaps > 0) {
+            uint16_t t = address[piece_index];
+            address[piece_index] = address[compress + swaps - 1];
+            address[compress + swaps - 1] = t;
+            piece_index--;
+            swaps--;
+        }
+    } else if (piece_index != 8) {
+        return false;
+    }
+    return true;
+}
+
+static void serialize_ipv6(const uint16_t address[8], wbuf *out) {
+    /* find first longest run (>= 2) of zero pieces */
+    int best_start = -1;
+    int best_len = 0;
+    int cur_start = -1;
+    int cur_len = 0;
+    for (int i = 0; i < 8; i++) {
+        if (address[i] == 0) {
+            if (cur_start < 0) {
+                cur_start = i;
+                cur_len = 0;
+            }
+            cur_len++;
+            if (cur_len > best_len) {
+                best_len = cur_len;
+                best_start = cur_start;
+            }
+        } else {
+            cur_start = -1;
+            cur_len = 0;
+        }
+    }
+    if (best_len < 2) {
+        best_start = -1;
+    }
+    char tmp[8];
+    bool ignore0 = false;
+    for (int i = 0; i < 8; i++) {
+        if (ignore0 && address[i] == 0) {
+            continue;
+        }
+        ignore0 = false;
+        if (i == best_start) {
+            wbuf_append_cstr(out, i == 0 ? "::" : ":");
+            ignore0 = true;
+            continue;
+        }
+        snprintf(tmp, sizeof(tmp), "%x", address[i]);
+        wbuf_append_cstr(out, tmp);
+        if (i != 7) {
+            wbuf_push(out, ':');
+        }
+    }
+}
+
+/* ================= host parser ================= */
+
+static bool is_forbidden_host_cp(uint8_t c) {
+    return c == 0x00 || c == 0x09 || c == 0x0a || c == 0x0d || c == ' ' ||
+           c == '#' || c == '/' || c == ':' || c == '<' || c == '>' ||
+           c == '?' || c == '@' || c == '[' || c == '\\' || c == ']' ||
+           c == '^' || c == '|';
+}
+
+static bool is_forbidden_domain_cp(uint8_t c) {
+    return is_forbidden_host_cp(c) || c < 0x20 || c == '%' || c == 0x7f;
+}
+
+/* parse host; is_opaque = "isNotSpecial" in the spec */
+static bool parse_host(const char *s, size_t n, bool is_opaque, wstr *out) {
+    if (n > 0 && s[0] == '[') {
+        if (s[n - 1] != ']') {
+            return false;
+        }
+        uint16_t address[8];
+        if (!parse_ipv6(s + 1, n - 2, address)) {
+            return false;
+        }
+        wbuf b;
+        wbuf_init(&b);
+        wbuf_push(&b, '[');
+        serialize_ipv6(address, &b);
+        wbuf_push(&b, ']');
+        size_t len;
+        char *p = wbuf_steal(&b, &len);
+        free(out->p);
+        out->p = p;
+        out->len = len;
+        return true;
+    }
+    if (is_opaque) {
+        /* opaque host */
+        for (size_t i = 0; i < n; i++) {
+            if (is_forbidden_host_cp((uint8_t)s[i])) {
+                return false;
+            }
+        }
+        wbuf b;
+        wbuf_init(&b);
+        wurl_enc_append_n(&b, s, n, WURL_SET_C0);
+        size_t len;
+        char *p = wbuf_steal(&b, &len);
+        free(out->p);
+        out->p = p;
+        out->len = len;
+        return true;
+    }
+    /* domain */
+    wbuf dec;
+    wbuf_init(&dec);
+    wurl_percent_decode(&dec, s, n);
+    wbuf ascii;
+    wbuf_init(&ascii);
+    if (!domain_to_ascii(dec.p, dec.len, &ascii)) {
+        wbuf_free(&dec);
+        wbuf_free(&ascii);
+        return false;
+    }
+    wbuf_free(&dec);
+    for (size_t i = 0; i < ascii.len; i++) {
+        if (is_forbidden_domain_cp((uint8_t)ascii.p[i])) {
+            wbuf_free(&ascii);
+            return false;
+        }
+    }
+    if (domain_ends_in_number(ascii.p, ascii.len)) {
+        wbuf v4;
+        wbuf_init(&v4);
+        bool ok = parse_ipv4(ascii.p, ascii.len, &v4);
+        wbuf_free(&ascii);
+        if (!ok) {
+            wbuf_free(&v4);
+            return false;
+        }
+        size_t len;
+        char *p = wbuf_steal(&v4, &len);
+        free(out->p);
+        out->p = p;
+        out->len = len;
+        return true;
+    }
+    size_t len;
+    char *p = wbuf_steal(&ascii, &len);
+    free(out->p);
+    out->p = p;
+    out->len = len;
+    return true;
+}
+
+/* ================= basic URL parser state machine ================= */
+
+enum {
+    ST_NONE = 0,
+    ST_SCHEME_START,
+    ST_SCHEME,
+    ST_NO_SCHEME,
+    ST_SPECIAL_RELATIVE_OR_AUTHORITY,
+    ST_PATH_OR_AUTHORITY,
+    ST_RELATIVE,
+    ST_RELATIVE_SLASH,
+    ST_SPECIAL_AUTHORITY_SLASHES,
+    ST_SPECIAL_AUTHORITY_IGNORE_SLASHES,
+    ST_AUTHORITY,
+    ST_HOST,
+    ST_HOSTNAME, /* only as override marker; runs as ST_HOST */
+    ST_PORT,
+    ST_FILE,
+    ST_FILE_SLASH,
+    ST_FILE_HOST,
+    ST_PATH_START,
+    ST_PATH,
+    ST_OPAQUE_PATH,
+    ST_QUERY,
+    ST_FRAGMENT,
+};
+
+static bool is_single_dot(const char *s, size_t n) {
+    if (n == 1 && s[0] == '.') {
+        return true;
+    }
+    return n == 3 && s[0] == '%' && s[1] == '2' && (s[2] == 'e' || s[2] == 'E');
+}
+
+static bool is_double_dot(const char *s, size_t n) {
+    if (n == 2 && s[0] == '.' && s[1] == '.') {
+        return true;
+    }
+    if (n == 4 && is_single_dot(s, 1) && is_single_dot(s + 1, 3)) {
+        return true; /* ".%2e" */
+    }
+    if (n == 4 && is_single_dot(s, 3) && is_single_dot(s + 3, 1)) {
+        return true; /* "%2e." */
+    }
+    return n == 6 && is_single_dot(s, 3) && is_single_dot(s + 3, 3);
+}
+
+/*
+ * The WHATWG basic URL parser. `override` is ST_NONE or one of
+ * ST_SCHEME_START / ST_HOST / ST_HOSTNAME / ST_PORT / ST_PATH_START /
+ * ST_QUERY / ST_FRAGMENT. Mutates url in place (spec semantics: with an
+ * override, failure may occur only before any mutation of the overridden
+ * component). Returns false on parse failure.
+ */
+static bool basic_parse(wurl *url, const char *raw, size_t rawlen,
+                        const wurl *base, int override) {
+    /* --- input preprocessing --- */
+    wbuf in;
+    wbuf_init(&in);
+    {
+        size_t b = 0;
+        size_t e = rawlen;
+        if (override == ST_NONE) {
+            while (b < e && (uint8_t)raw[b] <= 0x20) {
+                b++;
+            }
+            while (e > b && (uint8_t)raw[e - 1] <= 0x20) {
+                e--;
+            }
+        }
+        for (size_t i = b; i < e; i++) {
+            uint8_t c = (uint8_t)raw[i];
+            if (c != 0x09 && c != 0x0a && c != 0x0d) {
+                wbuf_push(&in, (char)c);
+            }
+        }
+    }
+    const char *s = in.p ? in.p : "";
+    size_t n = in.len;
+
+    int state = override == ST_NONE ? ST_SCHEME_START
+                                    : (override == ST_HOSTNAME ? ST_HOST : override);
+    wbuf buf;
+    wbuf_init(&buf);
+    bool at_sign_seen = false;
+    bool inside_brackets = false;
+    bool password_token_seen = false;
+    bool ok = true;
+
+#define FAIL()            \
+    do {                  \
+        ok = false;       \
+        goto done;        \
+    } while (0)
+#define RETURN_OK()       \
+    do {                  \
+        goto done;        \
+    } while (0)
+
+    for (ptrdiff_t i = 0; i <= (ptrdiff_t)n; i++) {
+        int c = (i < (ptrdiff_t)n) ? (uint8_t)s[i] : -1;
+        switch (state) {
+            case ST_SCHEME_START: {
+                if (c >= 0 && is_alpha((uint8_t)c)) {
+                    wbuf_push(&buf, (char)to_lower((uint8_t)c));
+                    state = ST_SCHEME;
+                } else if (override == ST_NONE) {
+                    state = ST_NO_SCHEME;
+                    i--;
+                } else {
+                    FAIL();
+                }
+                break;
+            }
+            case ST_SCHEME: {
+                if (c >= 0 && (is_alnum((uint8_t)c) || c == '+' || c == '-' || c == '.')) {
+                    wbuf_push(&buf, (char)to_lower((uint8_t)c));
+                } else if (c == ':') {
+                    if (override != ST_NONE) {
+                        bool url_special = is_special_url(url);
+                        bool buf_special = special_lookup(buf.p, buf.len) != NULL;
+                        if (url_special != buf_special) {
+                            RETURN_OK();
+                        }
+                        if ((includes_credentials(url) || url->port != -1) &&
+                            buf.len == 4 && memcmp(buf.p, "file", 4) == 0) {
+                            RETURN_OK();
+                        }
+                        if (scheme_is(url, "file") && url->has_host && url->host.len == 0) {
+                            RETURN_OK();
+                        }
+                    }
+                    wstr_set(&url->scheme, buf.p, buf.len);
+                    if (override != ST_NONE) {
+                        if (url->port != -1 &&
+                            url->port == default_port(url->scheme.p, url->scheme.len)) {
+                            url->port = -1;
+                        }
+                        RETURN_OK();
+                    }
+                    wbuf_clear(&buf);
+                    if (scheme_is(url, "file")) {
+                        state = ST_FILE;
+                    } else if (is_special_url(url) && base && base->scheme.p &&
+                               url->scheme.len == base->scheme.len &&
+                               memcmp(url->scheme.p, base->scheme.p, url->scheme.len) == 0) {
+                        state = ST_SPECIAL_RELATIVE_OR_AUTHORITY;
+                    } else if (is_special_url(url)) {
+                        state = ST_SPECIAL_AUTHORITY_SLASHES;
+                    } else if ((size_t)(i + 1) < n && s[i + 1] == '/') {
+                        state = ST_PATH_OR_AUTHORITY;
+                        i++;
+                    } else {
+                        url->path_opaque = true;
+                        wstr_set_empty(&url->path);
+                        state = ST_OPAQUE_PATH;
+                    }
+                } else if (override == ST_NONE) {
+                    wbuf_clear(&buf);
+                    state = ST_NO_SCHEME;
+                    i = -1; /* start over */
+                } else {
+                    FAIL();
+                }
+                break;
+            }
+            case ST_NO_SCHEME: {
+                if (!base || (base->path_opaque && c != '#')) {
+                    FAIL();
+                }
+                if (base->path_opaque && c == '#') {
+                    wstr_copy(&url->scheme, &base->scheme);
+                    wstr_copy(&url->path, &base->path);
+                    url->path_opaque = true;
+                    wstr_copy(&url->query, &base->query);
+                    wstr_set_empty(&url->fragment);
+                    state = ST_FRAGMENT;
+                } else if (!scheme_is(base, "file")) {
+                    state = ST_RELATIVE;
+                    i--;
+                } else {
+                    state = ST_FILE;
+                    i--;
+                }
+                break;
+            }
+            case ST_SPECIAL_RELATIVE_OR_AUTHORITY: {
+                if (c == '/' && (size_t)(i + 1) < n && s[i + 1] == '/') {
+                    state = ST_SPECIAL_AUTHORITY_IGNORE_SLASHES;
+                    i++;
+                } else {
+                    state = ST_RELATIVE;
+                    i--;
+                }
+                break;
+            }
+            case ST_PATH_OR_AUTHORITY: {
+                if (c == '/') {
+                    state = ST_AUTHORITY;
+                } else {
+                    state = ST_PATH;
+                    i--;
+                }
+                break;
+            }
+            case ST_RELATIVE: {
+                /* base is non-null and not file (asserted by no-scheme) */
+                wstr_copy(&url->scheme, &base->scheme);
+                if (c == '/' || (is_special_url(url) && c == '\\')) {
+                    state = ST_RELATIVE_SLASH;
+                } else {
+                    wstr_copy(&url->username, &base->username);
+                    wstr_copy(&url->password, &base->password);
+                    url->has_host = base->has_host;
+                    wstr_copy(&url->host, &base->host);
+                    url->port = base->port;
+                    wstr_copy(&url->path, &base->path);
+                    url->path_opaque = base->path_opaque;
+                    wstr_copy(&url->query, &base->query);
+                    if (c == '?') {
+                        wstr_set_empty(&url->query);
+                        state = ST_QUERY;
+                    } else if (c == '#') {
+                        wstr_set_empty(&url->fragment);
+                        state = ST_FRAGMENT;
+                    } else if (c != -1) {
+                        wstr_set_null(&url->query);
+                        shorten_path(url);
+                        state = ST_PATH;
+                        i--;
+                    }
+                }
+                break;
+            }
+            case ST_RELATIVE_SLASH: {
+                if (is_special_url(url) && (c == '/' || c == '\\')) {
+                    state = ST_SPECIAL_AUTHORITY_IGNORE_SLASHES;
+                } else if (c == '/') {
+                    state = ST_AUTHORITY;
+                } else {
+                    wstr_copy(&url->username, &base->username);
+                    wstr_copy(&url->password, &base->password);
+                    url->has_host = base->has_host;
+                    wstr_copy(&url->host, &base->host);
+                    url->port = base->port;
+                    state = ST_PATH;
+                    i--;
+                }
+                break;
+            }
+            case ST_SPECIAL_AUTHORITY_SLASHES: {
+                if (c == '/' && (size_t)(i + 1) < n && s[i + 1] == '/') {
+                    state = ST_SPECIAL_AUTHORITY_IGNORE_SLASHES;
+                    i++;
+                } else {
+                    state = ST_SPECIAL_AUTHORITY_IGNORE_SLASHES;
+                    i--;
+                }
+                break;
+            }
+            case ST_SPECIAL_AUTHORITY_IGNORE_SLASHES: {
+                if (c != '/' && c != '\\') {
+                    state = ST_AUTHORITY;
+                    i--;
+                }
+                break;
+            }
+            case ST_AUTHORITY: {
+                if (c == '@') {
+                    if (at_sign_seen) {
+                        wbuf pre;
+                        wbuf_init(&pre);
+                        wbuf_append_cstr(&pre, "%40");
+                        wbuf_append(&pre, buf.p, buf.len);
+                        wbuf_free(&buf);
+                        buf = pre;
+                    }
+                    at_sign_seen = true;
+                    wbuf u;
+                    wbuf_init(&u);
+                    wbuf_append(&u, url->username.p, url->username.len);
+                    wbuf pw;
+                    wbuf_init(&pw);
+                    wbuf_append(&pw, url->password.p, url->password.len);
+                    for (size_t j = 0; j < buf.len; j++) {
+                        uint8_t cc = (uint8_t)buf.p[j];
+                        if (cc == ':' && !password_token_seen) {
+                            password_token_seen = true;
+                            continue;
+                        }
+                        wurl_enc_append(password_token_seen ? &pw : &u, cc,
+                                        WURL_SET_USERINFO);
+                    }
+                    wstr_set(&url->username, u.p ? u.p : "", u.len);
+                    wstr_set(&url->password, pw.p ? pw.p : "", pw.len);
+                    wbuf_free(&u);
+                    wbuf_free(&pw);
+                    wbuf_clear(&buf);
+                } else if (c == -1 || c == '/' || c == '?' || c == '#' ||
+                           (is_special_url(url) && c == '\\')) {
+                    if (at_sign_seen && buf.len == 0) {
+                        FAIL();
+                    }
+                    i -= (ptrdiff_t)buf.len + 1;
+                    wbuf_clear(&buf);
+                    state = ST_HOST;
+                } else {
+                    wbuf_push(&buf, (char)c);
+                }
+                break;
+            }
+            case ST_HOST: {
+                if (override != ST_NONE && scheme_is(url, "file")) {
+                    i--;
+                    state = ST_FILE_HOST;
+                } else if (c == ':' && !inside_brackets) {
+                    if (buf.len == 0) {
+                        FAIL();
+                    }
+                    if (override == ST_HOSTNAME) {
+                        FAIL();
+                    }
+                    if (!parse_host(buf.p ? buf.p : "", buf.len,
+                                    !is_special_url(url), &url->host)) {
+                        FAIL();
+                    }
+                    url->has_host = true;
+                    wbuf_clear(&buf);
+                    state = ST_PORT;
+                } else if (c == -1 || c == '/' || c == '?' || c == '#' ||
+                           (is_special_url(url) && c == '\\')) {
+                    i--;
+                    if (is_special_url(url) && buf.len == 0) {
+                        FAIL();
+                    }
+                    if (override != ST_NONE && buf.len == 0 &&
+                        (includes_credentials(url) || url->port != -1)) {
+                        RETURN_OK();
+                    }
+                    if (!parse_host(buf.p ? buf.p : "", buf.len,
+                                    !is_special_url(url), &url->host)) {
+                        FAIL();
+                    }
+                    url->has_host = true;
+                    wbuf_clear(&buf);
+                    state = ST_PATH_START;
+                    if (override != ST_NONE) {
+                        RETURN_OK();
+                    }
+                } else {
+                    if (c == '[') {
+                        inside_brackets = true;
+                    } else if (c == ']') {
+                        inside_brackets = false;
+                    }
+                    wbuf_push(&buf, (char)c);
+                }
+                break;
+            }
+            case ST_PORT: {
+                if (c >= 0 && is_digit((uint8_t)c)) {
+                    wbuf_push(&buf, (char)c);
+                } else if (c == -1 || c == '/' || c == '?' || c == '#' ||
+                           (is_special_url(url) && c == '\\') ||
+                           override != ST_NONE) {
+                    if (buf.len > 0) {
+                        uint64_t port = 0;
+                        for (size_t j = 0; j < buf.len; j++) {
+                            port = port * 10 + (uint64_t)(buf.p[j] - '0');
+                            if (port > 0xffff) {
+                                break;
+                            }
+                        }
+                        if (port > 0xffff) {
+                            FAIL();
+                        }
+                        int32_t dp = default_port(url->scheme.p, url->scheme.len);
+                        url->port = ((int32_t)port == dp) ? -1 : (int32_t)port;
+                        wbuf_clear(&buf);
+                    }
+                    if (override != ST_NONE) {
+                        RETURN_OK();
+                    }
+                    state = ST_PATH_START;
+                    i--;
+                } else {
+                    FAIL();
+                }
+                break;
+            }
+            case ST_FILE: {
+                wstr_set(&url->scheme, "file", 4);
+                url->has_host = true;
+                wstr_set_empty(&url->host);
+                if (c == '/' || c == '\\') {
+                    state = ST_FILE_SLASH;
+                } else if (base && scheme_is(base, "file")) {
+                    url->has_host = base->has_host;
+                    wstr_copy(&url->host, &base->host);
+                    wstr_copy(&url->path, &base->path);
+                    url->path_opaque = base->path_opaque;
+                    wstr_copy(&url->query, &base->query);
+                    if (c == '?') {
+                        wstr_set_empty(&url->query);
+                        state = ST_QUERY;
+                    } else if (c == '#') {
+                        wstr_set_empty(&url->fragment);
+                        state = ST_FRAGMENT;
+                    } else if (c != -1) {
+                        wstr_set_null(&url->query);
+                        if (!starts_with_windows_drive(s, (size_t)i, n)) {
+                            shorten_path(url);
+                        } else {
+                            wstr_set_empty(&url->path);
+                        }
+                        state = ST_PATH;
+                        i--;
+                    }
+                } else {
+                    state = ST_PATH;
+                    i--;
+                }
+                break;
+            }
+            case ST_FILE_SLASH: {
+                if (c == '/' || c == '\\') {
+                    state = ST_FILE_HOST;
+                } else {
+                    if (base && scheme_is(base, "file")) {
+                        url->has_host = base->has_host;
+                        wstr_copy(&url->host, &base->host);
+                        if (!starts_with_windows_drive(s, (size_t)i, n) &&
+                            first_seg_is_normalized_drive(&base->path)) {
+                            path_append_segment(url, base->path.p + 1, 2);
+                        }
+                    }
+                    state = ST_PATH;
+                    i--;
+                }
+                break;
+            }
+            case ST_FILE_HOST: {
+                if (c == -1 || c == '/' || c == '\\' || c == '?' || c == '#') {
+                    i--;
+                    if (override == ST_NONE && is_windows_drive(buf.p ? buf.p : "", buf.len)) {
+                        state = ST_PATH;
+                        /* buffer intentionally retained */
+                    } else if (buf.len == 0) {
+                        url->has_host = true;
+                        wstr_set_empty(&url->host);
+                        if (override != ST_NONE) {
+                            RETURN_OK();
+                        }
+                        state = ST_PATH_START;
+                    } else {
+                        if (!parse_host(buf.p, buf.len, false, &url->host)) {
+                            FAIL();
+                        }
+                        url->has_host = true;
+                        if (url->host.len == 9 &&
+                            memcmp(url->host.p, "localhost", 9) == 0) {
+                            wstr_set_empty(&url->host);
+                        }
+                        if (override != ST_NONE) {
+                            RETURN_OK();
+                        }
+                        wbuf_clear(&buf);
+                        state = ST_PATH_START;
+                    }
+                } else {
+                    wbuf_push(&buf, (char)c);
+                }
+                break;
+            }
+            case ST_PATH_START: {
+                if (is_special_url(url)) {
+                    state = ST_PATH;
+                    if (c != '/' && c != '\\') {
+                        i--;
+                    }
+                } else if (override == ST_NONE && c == '?') {
+                    wstr_set_empty(&url->query);
+                    state = ST_QUERY;
+                } else if (override == ST_NONE && c == '#') {
+                    wstr_set_empty(&url->fragment);
+                    state = ST_FRAGMENT;
+                } else if (c != -1) {
+                    state = ST_PATH;
+                    if (c != '/') {
+                        i--;
+                    }
+                } else if (override != ST_NONE && !url->has_host) {
+                    path_append_segment(url, "", 0);
+                }
+                break;
+            }
+            case ST_PATH: {
+                if (c == -1 || c == '/' || (is_special_url(url) && c == '\\') ||
+                    (override == ST_NONE && (c == '?' || c == '#'))) {
+                    bool seg_slash = (c == '/') || (is_special_url(url) && c == '\\');
+                    if (is_double_dot(buf.p ? buf.p : "", buf.len)) {
+                        shorten_path(url);
+                        if (!seg_slash) {
+                            path_append_segment(url, "", 0);
+                        }
+                    } else if (is_single_dot(buf.p ? buf.p : "", buf.len)) {
+                        if (!seg_slash) {
+                            path_append_segment(url, "", 0);
+                        }
+                    } else {
+                        if (scheme_is(url, "file") && url->path.len == 0 &&
+                            is_windows_drive(buf.p ? buf.p : "", buf.len)) {
+                            buf.p[1] = ':';
+                        }
+                        path_append_segment(url, buf.p ? buf.p : "", buf.len);
+                    }
+                    wbuf_clear(&buf);
+                    if (c == '?') {
+                        wstr_set_empty(&url->query);
+                        state = ST_QUERY;
+                    } else if (c == '#') {
+                        wstr_set_empty(&url->fragment);
+                        state = ST_FRAGMENT;
+                    }
+                } else {
+                    wurl_enc_append(&buf, (uint8_t)c, WURL_SET_PATH);
+                }
+                break;
+            }
+            case ST_OPAQUE_PATH: {
+                if (c == '?') {
+                    wstr_set_empty(&url->query);
+                    state = ST_QUERY;
+                } else if (c == '#') {
+                    wstr_set_empty(&url->fragment);
+                    state = ST_FRAGMENT;
+                } else if (c != -1) {
+                    wbuf t;
+                    wbuf_init(&t);
+                    wbuf_append(&t, url->path.p, url->path.len);
+                    /* a space immediately before '?' or '#' is encoded */
+                    if (c == ' ' && (size_t)(i + 1) < n &&
+                        (s[i + 1] == '?' || s[i + 1] == '#')) {
+                        wbuf_append_cstr(&t, "%20");
+                    } else {
+                        wurl_enc_append(&t, (uint8_t)c, WURL_SET_C0);
+                    }
+                    size_t len;
+                    char *p = wbuf_steal(&t, &len);
+                    free(url->path.p);
+                    url->path.p = p;
+                    url->path.len = len;
+                }
+                break;
+            }
+            case ST_QUERY: {
+                if ((override == ST_NONE && c == '#') || c == -1) {
+                    if (c == '#') {
+                        wstr_set_empty(&url->fragment);
+                        state = ST_FRAGMENT;
+                    }
+                } else if (c != -1) {
+                    wbuf t;
+                    wbuf_init(&t);
+                    wbuf_append(&t, url->query.p, url->query.len);
+                    wurl_enc_append(&t, (uint8_t)c,
+                                    is_special_url(url) ? WURL_SET_SPECIAL_QUERY
+                                                        : WURL_SET_QUERY);
+                    size_t len;
+                    char *p = wbuf_steal(&t, &len);
+                    free(url->query.p);
+                    url->query.p = p;
+                    url->query.len = len;
+                }
+                break;
+            }
+            case ST_FRAGMENT: {
+                if (c != -1) {
+                    wbuf t;
+                    wbuf_init(&t);
+                    wbuf_append(&t, url->fragment.p, url->fragment.len);
+                    wurl_enc_append(&t, (uint8_t)c, WURL_SET_FRAGMENT);
+                    size_t len;
+                    char *p = wbuf_steal(&t, &len);
+                    free(url->fragment.p);
+                    url->fragment.p = p;
+                    url->fragment.len = len;
+                }
+                break;
+            }
+            default:
+                FAIL();
+        }
+    }
+
+done:
+    wbuf_free(&buf);
+    wbuf_free(&in);
+    return ok;
+#undef FAIL
+#undef RETURN_OK
+}
+
+/* ================= serialization ================= */
+
+static void serialize_href(const wurl *u, wbuf *out) {
+    wbuf_append(out, u->scheme.p, u->scheme.len);
+    wbuf_push(out, ':');
+    if (u->has_host) {
+        wbuf_append_cstr(out, "//");
+        if (includes_credentials(u)) {
+            wbuf_append(out, u->username.p, u->username.len);
+            if (u->password.len > 0) {
+                wbuf_push(out, ':');
+                wbuf_append(out, u->password.p, u->password.len);
+            }
+            wbuf_push(out, '@');
+        }
+        wbuf_append(out, u->host.p, u->host.len);
+        if (u->port != -1) {
+            char tmp[8];
+            snprintf(tmp, sizeof(tmp), ":%d", u->port);
+            wbuf_append_cstr(out, tmp);
+        }
+    } else if (!u->path_opaque && u->path.len >= 2 && u->path.p[0] == '/' &&
+               u->path.p[1] == '/') {
+        wbuf_append_cstr(out, "/.");
+    }
+    wbuf_append(out, u->path.p, u->path.len);
+    if (u->query.p) {
+        wbuf_push(out, '?');
+        wbuf_append(out, u->query.p, u->query.len);
+    }
+    if (u->fragment.p) {
+        wbuf_push(out, '#');
+        wbuf_append(out, u->fragment.p, u->fragment.len);
+    }
+}
+
+static void serialize_origin(const wurl *u, wbuf *out, bool allow_blob) {
+    if (scheme_is(u, "http") || scheme_is(u, "https") || scheme_is(u, "ws") ||
+        scheme_is(u, "wss") || scheme_is(u, "ftp")) {
+        wbuf_append(out, u->scheme.p, u->scheme.len);
+        wbuf_append_cstr(out, "://");
+        wbuf_append(out, u->host.p, u->host.len);
+        if (u->port != -1) {
+            char tmp[8];
+            snprintf(tmp, sizeof(tmp), ":%d", u->port);
+            wbuf_append_cstr(out, tmp);
+        }
+        return;
+    }
+    if (allow_blob && scheme_is(u, "blob")) {
+        wurl tmp;
+        wurl_record_init(&tmp);
+        if (basic_parse(&tmp, u->path.p ? u->path.p : "", u->path.len, NULL,
+                        ST_NONE) &&
+            (scheme_is(&tmp, "http") || scheme_is(&tmp, "https"))) {
+            serialize_origin(&tmp, out, false);
+            wurl_record_clear(&tmp);
+            return;
+        }
+        wurl_record_clear(&tmp);
+    }
+    wbuf_append_cstr(out, "null");
+}
+
+/* ================= ada_c URL API ================= */
+
+static wurl *new_invalid(void) {
+    wurl *u = malloc(sizeof(wurl));
+    if (!u) {
+        abort();
+    }
+    wurl_record_init(u);
+    u->valid = false;
+    return u;
+}
+
+ada_url ada_parse(const char *input, size_t length) {
+    wurl *u = new_invalid();
+    u->valid = basic_parse(u, input ? input : "", input ? length : 0, NULL, ST_NONE);
+    return u;
+}
+
+ada_url ada_parse_with_base(const char *input, size_t input_length,
+                            const char *base, size_t base_length) {
+    wurl *u = new_invalid();
+    wurl b;
+    wurl_record_init(&b);
+    if (basic_parse(&b, base ? base : "", base ? base_length : 0, NULL, ST_NONE)) {
+        b.valid = true;
+        u->valid = basic_parse(u, input ? input : "", input ? input_length : 0,
+                               &b, ST_NONE);
+    }
+    wurl_record_clear(&b);
+    return u;
+}
+
+bool ada_can_parse(const char *input, size_t length) {
+    wurl u;
+    wurl_record_init(&u);
+    bool ok = basic_parse(&u, input ? input : "", input ? length : 0, NULL, ST_NONE);
+    wurl_record_clear(&u);
+    return ok;
+}
+
+bool ada_can_parse_with_base(const char *input, size_t input_length,
+                             const char *base, size_t base_length) {
+    wurl b;
+    wurl_record_init(&b);
+    bool ok = basic_parse(&b, base ? base : "", base ? base_length : 0, NULL, ST_NONE);
+    if (ok) {
+        wurl u;
+        wurl_record_init(&u);
+        ok = basic_parse(&u, input ? input : "", input ? input_length : 0, &b, ST_NONE);
+        wurl_record_clear(&u);
+    }
+    wurl_record_clear(&b);
+    return ok;
+}
+
+void ada_free(ada_url result) {
+    wurl *u = result;
+    if (u) {
+        wurl_record_clear(u);
+        free(u);
+    }
+}
+
+void ada_free_owned_string(ada_owned_string owned) {
+    free((void *)owned.data);
+}
+
+bool ada_is_valid(ada_url result) {
+    wurl *u = result;
+    return u && u->valid;
+}
+
+static ada_string view(const char *p, size_t len) {
+    ada_string s = { p ? p : "", len };
+    return s;
+}
+
+static ada_string scratch_view(wurl *u) {
+    return view(u->scratch.p, u->scratch.len);
+}
+
+ada_string ada_get_href(ada_url result) {
+    wurl *u = result;
+    wbuf_clear(&u->scratch);
+    serialize_href(u, &u->scratch);
+    return scratch_view(u);
+}
+
+ada_string ada_get_protocol(ada_url result) {
+    wurl *u = result;
+    wbuf_clear(&u->scratch);
+    wbuf_append(&u->scratch, u->scheme.p, u->scheme.len);
+    wbuf_push(&u->scratch, ':');
+    return scratch_view(u);
+}
+
+ada_string ada_get_username(ada_url result) {
+    wurl *u = result;
+    return view(u->username.p, u->username.len);
+}
+
+ada_string ada_get_password(ada_url result) {
+    wurl *u = result;
+    return view(u->password.p, u->password.len);
+}
+
+ada_string ada_get_host(ada_url result) {
+    wurl *u = result;
+    if (!u->has_host) {
+        return view("", 0);
+    }
+    if (u->port == -1) {
+        return view(u->host.p, u->host.len);
+    }
+    wbuf_clear(&u->scratch);
+    wbuf_append(&u->scratch, u->host.p, u->host.len);
+    char tmp[8];
+    snprintf(tmp, sizeof(tmp), ":%d", u->port);
+    wbuf_append_cstr(&u->scratch, tmp);
+    return scratch_view(u);
+}
+
+ada_string ada_get_hostname(ada_url result) {
+    wurl *u = result;
+    if (!u->has_host) {
+        return view("", 0);
+    }
+    return view(u->host.p, u->host.len);
+}
+
+ada_string ada_get_port(ada_url result) {
+    wurl *u = result;
+    if (u->port == -1) {
+        return view("", 0);
+    }
+    wbuf_clear(&u->scratch);
+    char tmp[8];
+    snprintf(tmp, sizeof(tmp), "%d", u->port);
+    wbuf_append_cstr(&u->scratch, tmp);
+    return scratch_view(u);
+}
+
+ada_string ada_get_pathname(ada_url result) {
+    wurl *u = result;
+    return view(u->path.p, u->path.len);
+}
+
+ada_string ada_get_search(ada_url result) {
+    wurl *u = result;
+    if (!u->query.p || u->query.len == 0) {
+        return view("", 0);
+    }
+    wbuf_clear(&u->scratch);
+    wbuf_push(&u->scratch, '?');
+    wbuf_append(&u->scratch, u->query.p, u->query.len);
+    return scratch_view(u);
+}
+
+ada_string ada_get_hash(ada_url result) {
+    wurl *u = result;
+    if (!u->fragment.p || u->fragment.len == 0) {
+        return view("", 0);
+    }
+    wbuf_clear(&u->scratch);
+    wbuf_push(&u->scratch, '#');
+    wbuf_append(&u->scratch, u->fragment.p, u->fragment.len);
+    return scratch_view(u);
+}
+
+ada_owned_string ada_get_origin(ada_url result) {
+    wurl *u = result;
+    wbuf b;
+    wbuf_init(&b);
+    serialize_origin(u, &b, true);
+    ada_owned_string s;
+    s.length = b.len;
+    s.data = wbuf_steal(&b, NULL);
+    return s;
+}
+
+/* --- setters --- */
+
+bool ada_set_href(ada_url result, const char *input, size_t length) {
+    wurl *u = result;
+    wurl fresh;
+    wurl_record_init(&fresh);
+    if (!basic_parse(&fresh, input ? input : "", input ? length : 0, NULL, ST_NONE)) {
+        wurl_record_clear(&fresh);
+        return false;
+    }
+    fresh.valid = true;
+    wurl_record_clear(u);
+    *u = fresh;
+    return true;
+}
+
+bool ada_set_protocol(ada_url result, const char *input, size_t length) {
+    wurl *u = result;
+    wbuf b;
+    wbuf_init(&b);
+    wbuf_append(&b, input ? input : "", length);
+    wbuf_push(&b, ':');
+    bool ok = basic_parse(u, b.p, b.len, NULL, ST_SCHEME_START);
+    wbuf_free(&b);
+    return ok;
+}
+
+bool ada_set_username(ada_url result, const char *input, size_t length) {
+    wurl *u = result;
+    if (cannot_have_credentials_or_port(u)) {
+        return false;
+    }
+    wbuf b;
+    wbuf_init(&b);
+    wurl_enc_append_n(&b, input ? input : "", length, WURL_SET_USERINFO);
+    free(u->username.p);
+    u->username.len = b.len;
+    u->username.p = wbuf_steal(&b, NULL);
+    return true;
+}
+
+bool ada_set_password(ada_url result, const char *input, size_t length) {
+    wurl *u = result;
+    if (cannot_have_credentials_or_port(u)) {
+        return false;
+    }
+    wbuf b;
+    wbuf_init(&b);
+    wurl_enc_append_n(&b, input ? input : "", length, WURL_SET_USERINFO);
+    free(u->password.p);
+    u->password.len = b.len;
+    u->password.p = wbuf_steal(&b, NULL);
+    return true;
+}
+
+bool ada_set_host(ada_url result, const char *input, size_t length) {
+    wurl *u = result;
+    if (u->path_opaque) {
+        return false;
+    }
+    return basic_parse(u, input ? input : "", length, NULL, ST_HOST);
+}
+
+bool ada_set_hostname(ada_url result, const char *input, size_t length) {
+    wurl *u = result;
+    if (u->path_opaque) {
+        return false;
+    }
+    return basic_parse(u, input ? input : "", length, NULL, ST_HOSTNAME);
+}
+
+bool ada_set_port(ada_url result, const char *input, size_t length) {
+    wurl *u = result;
+    if (cannot_have_credentials_or_port(u)) {
+        return false;
+    }
+    if (length == 0) {
+        u->port = -1;
+        return true;
+    }
+    return basic_parse(u, input, length, NULL, ST_PORT);
+}
+
+bool ada_set_pathname(ada_url result, const char *input, size_t length) {
+    wurl *u = result;
+    if (u->path_opaque) {
+        return false;
+    }
+    wstr_set_empty(&u->path);
+    return basic_parse(u, input ? input : "", length, NULL, ST_PATH_START);
+}
+
+/* strip trailing U+0020 from an opaque path when query & fragment are null */
+static void potentially_strip_trailing_spaces(wurl *u) {
+    if (!u->path_opaque || u->fragment.p || u->query.p) {
+        return;
+    }
+    size_t len = u->path.len;
+    while (len > 0 && u->path.p[len - 1] == ' ') {
+        len--;
+    }
+    if (len != u->path.len) {
+        wstr_set(&u->path, u->path.p, len);
+    }
+}
+
+void ada_set_search(ada_url result, const char *input, size_t length) {
+    wurl *u = result;
+    if (length == 0) {
+        wstr_set_null(&u->query);
+        potentially_strip_trailing_spaces(u);
+        return;
+    }
+    const char *s = input;
+    if (s[0] == '?') {
+        s++;
+        length--;
+    }
+    wstr_set_empty(&u->query);
+    basic_parse(u, s, length, NULL, ST_QUERY);
+}
+
+void ada_set_hash(ada_url result, const char *input, size_t length) {
+    wurl *u = result;
+    if (length == 0) {
+        wstr_set_null(&u->fragment);
+        potentially_strip_trailing_spaces(u);
+        return;
+    }
+    const char *s = input;
+    if (s[0] == '#') {
+        s++;
+        length--;
+    }
+    wstr_set_empty(&u->fragment);
+    basic_parse(u, s, length, NULL, ST_FRAGMENT);
+}
+
+void ada_clear_search(ada_url result) {
+    wurl *u = result;
+    wstr_set_null(&u->query);
+}
