diff --git a/deps/wurl/wurl_common.c b/deps/wurl/wurl_common.c
new file mode 100644
index 0000000..1f4019c
--- /dev/null
+++ b/deps/wurl/wurl_common.c
@@ -0,0 +1,278 @@
+/*
+ * wurl_common.c — buffers, percent-encoding sets, UTF-8 helpers.
+ */
+#include "wurl_common.h"
+
+#include <stdlib.h>
+#include <string.h>
+
+/* ---- wbuf ---------------------------------------------------------- */
+
+void wbuf_init(wbuf *b) {
+    b->p = NULL;
+    b->len = 0;
+    b->cap = 0;
+}
+
+void wbuf_free(wbuf *b) {
+    free(b->p);
+    wbuf_init(b);
+}
+
+void wbuf_clear(wbuf *b) {
+    b->len = 0;
+    if (b->p) {
+        b->p[0] = '\0';
+    }
+}
+
+void wbuf_reserve(wbuf *b, size_t extra) {
+    size_t need = b->len + extra + 1;
+    if (need <= b->cap) {
+        return;
+    }
+    size_t cap = b->cap ? b->cap : 32;
+    while (cap < need) {
+        cap *= 2;
+    }
+    char *np = realloc(b->p, cap);
+    if (!np) {
+        abort();
+    }
+    b->p = np;
+    b->cap = cap;
+}
+
+void wbuf_push(wbuf *b, char c) {
+    wbuf_reserve(b, 1);
+    b->p[b->len++] = c;
+    b->p[b->len] = '\0';
+}
+
+void wbuf_append(wbuf *b, const char *s, size_t n) {
+    if (n == 0) {
+        wbuf_reserve(b, 0);
+        b->p[b->len] = '\0';
+        return;
+    }
+    wbuf_reserve(b, n);
+    memcpy(b->p + b->len, s, n);
+    b->len += n;
+    b->p[b->len] = '\0';
+}
+
+void wbuf_append_cstr(wbuf *b, const char *s) {
+    wbuf_append(b, s, strlen(s));
+}
+
+char *wbuf_steal(wbuf *b, size_t *len_out) {
+    wbuf_reserve(b, 0); /* ensure allocated + NUL */
+    char *p = b->p;
+    if (len_out) {
+        *len_out = b->len;
+    }
+    wbuf_init(b);
+    return p;
+}
+
+/* ---- wstr ---------------------------------------------------------- */
+
+void wstr_free(wstr *s) {
+    free(s->p);
+    s->p = NULL;
+    s->len = 0;
+}
+
+void wstr_set(wstr *s, const char *mem, size_t n) {
+    char *np = malloc(n + 1);
+    if (!np) {
+        abort();
+    }
+    if (n) {
+        memcpy(np, mem, n);
+    }
+    np[n] = '\0';
+    free(s->p);
+    s->p = np;
+    s->len = n;
+}
+
+void wstr_set_null(wstr *s) {
+    free(s->p);
+    s->p = NULL;
+    s->len = 0;
+}
+
+void wstr_set_empty(wstr *s) {
+    wstr_set(s, "", 0);
+}
+
+void wstr_copy(wstr *dst, const wstr *src) {
+    if (src->p == NULL) {
+        wstr_set_null(dst);
+    } else {
+        wstr_set(dst, src->p, src->len);
+    }
+}
+
+/* ---- percent-encode sets (https://url.spec.whatwg.org/#percent-encoded-bytes)
+ *
+ * Expressed as predicates rather than generated tables: each set is the
+ * previous plus a handful of named code points, exactly as the spec lists
+ * them, so the definition is reviewable against the spec text at a glance.
+ * (The one data-driven table in wurl — the IDNA allow-bitmap — has a
+ * generator; see gen-idna-allow.mjs.)
+ * ---------------------------------------------------------------------- */
+
+static bool in_c0(uint8_t c) {
+    return c < 0x20 || c > 0x7e;
+}
+
+static bool in_fragment(uint8_t c) {
+    return in_c0(c) || c == ' ' || c == '"' || c == '<' || c == '>' || c == '`';
+}
+
+static bool in_query(uint8_t c) {
+    return in_c0(c) || c == ' ' || c == '"' || c == '#' || c == '<' || c == '>';
+}
+
+static bool in_special_query(uint8_t c) {
+    return in_query(c) || c == '\'';
+}
+
+static bool in_path(uint8_t c) {
+    return in_query(c) || c == '?' || c == '^' || c == '`' || c == '{' || c == '}';
+}
+
+static bool in_userinfo(uint8_t c) {
+    return in_path(c) || c == '/' || c == ':' || c == ';' || c == '=' || c == '@' ||
+           (c >= '[' && c <= ']') /* [ \ ] */ || c == '|';
+}
+
+static bool in_component(uint8_t c) {
+    return in_userinfo(c) || c == '$' || c == '%' || c == '&' || c == '+' || c == ',';
+}
+
+static bool in_form(uint8_t c) {
+    return in_component(c) || c == '!' || (c >= '\'' && c <= ')') /* ' ( ) */ || c == '~';
+}
+
+bool wurl_needs_encoding(uint8_t c, int set) {
+    switch (set) {
+        case WURL_SET_C0:
+            return in_c0(c);
+        case WURL_SET_FRAGMENT:
+            return in_fragment(c);
+        case WURL_SET_QUERY:
+            return in_query(c);
+        case WURL_SET_SPECIAL_QUERY:
+            return in_special_query(c);
+        case WURL_SET_PATH:
+            return in_path(c);
+        case WURL_SET_USERINFO:
+            return in_userinfo(c);
+        case WURL_SET_COMPONENT:
+            return in_component(c);
+        case WURL_SET_FORM:
+            return in_form(c);
+        default:
+            return true;
+    }
+}
+
+static const char HEX[] = "0123456789ABCDEF";
+
+void wurl_enc_append(wbuf *b, uint8_t c, int set) {
+    if (wurl_needs_encoding(c, set)) {
+        wbuf_reserve(b, 3);
+        b->p[b->len++] = '%';
+        b->p[b->len++] = HEX[c >> 4];
+        b->p[b->len++] = HEX[c & 0xf];
+        b->p[b->len] = '\0';
+    } else {
+        wbuf_push(b, (char)c);
+    }
+}
+
+void wurl_enc_append_n(wbuf *b, const char *s, size_t n, int set) {
+    for (size_t i = 0; i < n; i++) {
+        wurl_enc_append(b, (uint8_t)s[i], set);
+    }
+}
+
+static int hexval(uint8_t c) {
+    if (c >= '0' && c <= '9') {
+        return c - '0';
+    }
+    if (c >= 'a' && c <= 'f') {
+        return c - 'a' + 10;
+    }
+    if (c >= 'A' && c <= 'F') {
+        return c - 'A' + 10;
+    }
+    return -1;
+}
+
+void wurl_percent_decode(wbuf *b, const char *s, size_t n) {
+    for (size_t i = 0; i < n; i++) {
+        if (s[i] == '%' && i + 2 < n) {
+            int hi = hexval((uint8_t)s[i + 1]);
+            int lo = hexval((uint8_t)s[i + 2]);
+            if (hi >= 0 && lo >= 0) {
+                wbuf_push(b, (char)((hi << 4) | lo));
+                i += 2;
+                continue;
+            }
+        }
+        wbuf_push(b, s[i]);
+    }
+}
+
+/* ---- strict UTF-8 --------------------------------------------------- */
+
+bool wurl_utf8_next(const uint8_t *s, size_t len, size_t *i, uint32_t *cp) {
+    size_t k = *i;
+    if (k >= len) {
+        return false;
+    }
+    uint8_t c = s[k];
+    if (c < 0x80) {
+        *cp = c;
+        *i = k + 1;
+        return true;
+    }
+    size_t need;
+    uint32_t v;
+    uint32_t min;
+    if ((c & 0xe0) == 0xc0) {
+        need = 1;
+        v = c & 0x1f;
+        min = 0x80;
+    } else if ((c & 0xf0) == 0xe0) {
+        need = 2;
+        v = c & 0x0f;
+        min = 0x800;
+    } else if ((c & 0xf8) == 0xf0) {
+        need = 3;
+        v = c & 0x07;
+        min = 0x10000;
+    } else {
+        return false;
+    }
+    if (k + need >= len) {
+        return false;
+    }
+    for (size_t j = 1; j <= need; j++) {
+        uint8_t cc = s[k + j];
+        if ((cc & 0xc0) != 0x80) {
+            return false;
+        }
+        v = (v << 6) | (cc & 0x3f);
+    }
+    if (v < min || v > 0x10ffff || (v >= 0xd800 && v <= 0xdfff)) {
+        return false;
+    }
+    *cp = v;
+    *i = k + need + 1;
+    return true;
+}
