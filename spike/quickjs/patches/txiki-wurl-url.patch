+++ b/deps/wurl/ada_c.h
@@ -0,0 +1,145 @@
+/*
+ * ada_c.h (wurl edition) — plain-C replacement for the subset of ada's C API
+ * that txiki.js src/url.c consumes (58 functions / 79 call sites; see
+ * spike/quickjs/results/ada-ectomy-contract.md in the clode repo).
+ *
+ * Types and signatures are byte-compatible with deps/ada/ada_c.h so that
+ * src/url.c compiles unchanged; everything url.c does not call is omitted.
+ *
+ * Implementation: wurl_url.c / wurl_params.c / wurl_common.c (C11, no C++).
+ */
+#ifndef ADA_C_H
+#define ADA_C_H
+
+#include <stdbool.h>
+#include <stddef.h>
+#include <stdint.h>
+
+/* string view borrowed from an ada_url / ada_url_search_params instance;
+ * valid until the next API call on that instance; need not be
+ * NUL-terminated. data may be anything when length is 0. */
+typedef struct {
+  const char* data;
+  size_t length;
+} ada_string;
+
+/* string owned by the caller; free with ada_free_owned_string. */
+typedef struct {
+  const char* data;
+  size_t length;
+} ada_owned_string;
+
+typedef void* ada_url;
+
+/* parsing: always returns a handle, even on failure; check ada_is_valid.
+ * ada_free accepts (and must be called on) invalid handles too. */
+ada_url ada_parse(const char* input, size_t length);
+ada_url ada_parse_with_base(const char* input, size_t input_length,
+                            const char* base, size_t base_length);
+bool ada_can_parse(const char* input, size_t length);
+bool ada_can_parse_with_base(const char* input, size_t input_length,
+                             const char* base, size_t base_length);
+void ada_free(ada_url result);
+void ada_free_owned_string(ada_owned_string owned);
+bool ada_is_valid(ada_url result);
+
+/* getters (borrowed views) */
+ada_owned_string ada_get_origin(ada_url result);
+ada_string ada_get_href(ada_url result);
+ada_string ada_get_username(ada_url result);
+ada_string ada_get_password(ada_url result);
+ada_string ada_get_port(ada_url result);
+ada_string ada_get_hash(ada_url result);
+ada_string ada_get_host(ada_url result);
+ada_string ada_get_hostname(ada_url result);
+ada_string ada_get_pathname(ada_url result);
+ada_string ada_get_search(ada_url result);
+ada_string ada_get_protocol(ada_url result);
+
+/* setters (forgiving: on invalid input the component is left unchanged) */
+bool ada_set_href(ada_url result, const char* input, size_t length);
+bool ada_set_host(ada_url result, const char* input, size_t length);
+bool ada_set_hostname(ada_url result, const char* input, size_t length);
+bool ada_set_protocol(ada_url result, const char* input, size_t length);
+bool ada_set_username(ada_url result, const char* input, size_t length);
+bool ada_set_password(ada_url result, const char* input, size_t length);
+bool ada_set_port(ada_url result, const char* input, size_t length);
+bool ada_set_pathname(ada_url result, const char* input, size_t length);
+void ada_set_search(ada_url result, const char* input, size_t length);
+void ada_set_hash(ada_url result, const char* input, size_t length);
+void ada_clear_search(ada_url result);
+
+/* URLSearchParams */
+typedef void* ada_url_search_params;
+typedef void* ada_strings;
+typedef void* ada_url_search_params_keys_iter;
+typedef void* ada_url_search_params_values_iter;
+typedef void* ada_url_search_params_entries_iter;
+
+typedef struct {
+  ada_string key;
+  ada_string value;
+} ada_string_pair;
+
+ada_url_search_params ada_parse_search_params(const char* input,
+                                              size_t length);
+void ada_free_search_params(ada_url_search_params result);
+
+size_t ada_search_params_size(ada_url_search_params result);
+void ada_search_params_sort(ada_url_search_params result);
+ada_owned_string ada_search_params_to_string(ada_url_search_params result);
+
+void ada_search_params_append(ada_url_search_params result, const char* key,
+                              size_t key_length, const char* value,
+                              size_t value_length);
+void ada_search_params_set(ada_url_search_params result, const char* key,
+                           size_t key_length, const char* value,
+                           size_t value_length);
+void ada_search_params_remove(ada_url_search_params result, const char* key,
+                              size_t key_length);
+void ada_search_params_remove_value(ada_url_search_params result,
+                                    const char* key, size_t key_length,
+                                    const char* value, size_t value_length);
+bool ada_search_params_has(ada_url_search_params result, const char* key,
+                           size_t key_length);
+bool ada_search_params_has_value(ada_url_search_params result, const char* key,
+                                 size_t key_length, const char* value,
+                                 size_t value_length);
+ada_string ada_search_params_get(ada_url_search_params result, const char* key,
+                                 size_t key_length);
+ada_strings ada_search_params_get_all(ada_url_search_params result,
+                                      const char* key, size_t key_length);
+void ada_search_params_reset(ada_url_search_params result, const char* input,
+                             size_t length);
+ada_url_search_params_keys_iter ada_search_params_get_keys(
+    ada_url_search_params result);
+ada_url_search_params_values_iter ada_search_params_get_values(
+    ada_url_search_params result);
+ada_url_search_params_entries_iter ada_search_params_get_entries(
+    ada_url_search_params result);
+
+void ada_free_strings(ada_strings result);
+size_t ada_strings_size(ada_strings result);
+ada_string ada_strings_get(ada_strings result, size_t index);
+
+void ada_free_search_params_keys_iter(ada_url_search_params_keys_iter result);
+ada_string ada_search_params_keys_iter_next(
+    ada_url_search_params_keys_iter result);
+bool ada_search_params_keys_iter_has_next(
+    ada_url_search_params_keys_iter result);
+
+void ada_free_search_params_values_iter(
+    ada_url_search_params_values_iter result);
+ada_string ada_search_params_values_iter_next(
+    ada_url_search_params_values_iter result);
+bool ada_search_params_values_iter_has_next(
+    ada_url_search_params_values_iter result);
+
+void ada_free_search_params_entries_iter(
+    ada_url_search_params_entries_iter result);
+ada_string_pair ada_search_params_entries_iter_next(
+    ada_url_search_params_entries_iter result);
+bool ada_search_params_entries_iter_has_next(
+    ada_url_search_params_entries_iter result);
+
+#endif /* ADA_C_H */
diff --git a/deps/wurl/gen-idna-allow.mjs b/deps/wurl/gen-idna-allow.mjs
new file mode 100644
index 0000000..a6e5277
--- /dev/null
+++ b/deps/wurl/gen-idna-allow.mjs
@@ -0,0 +1,231 @@
+// gen-idna-allow.mjs — generates idna_allow.h, the IDNA L1' allow-bitmap.
+//
+// Run under the PINNED tjs binary (the golden oracle, vendored ada 3.4.2):
+//
+//   build/tjs/tjs run deps/wurl/gen-idna-allow.mjs > deps/wurl/idna_allow.h
+//
+// (paths relative to the repo/vendor roots; any tjs built with the vendored
+// ada works — the point is that the probe oracle IS the implementation the
+// golden manifest froze, so the bitmap can never be more permissive than it.)
+//
+// A non-ASCII codepoint cp is ALLOWED (kept and punycoded as-is by wurl's
+// L1' domain-to-ASCII) iff full UTS-46 (as implemented by the oracle) treats
+// it as an identity mapping that is valid in every context wurl can present
+// it in. Everything else — mapped, ignored, disallowed, deviation-mapped,
+// context-dependent (joiners, bidi, combining marks), NFC-unstable or
+// NFC-composing — is REJECTED LOUDLY by wurl (TypeError), never mis-parsed.
+// That is the L1' fail-loud contract: below full UTS-46 (L2), the only
+// permitted deviation from the golden is throws-where-golden-succeeds.
+//
+// Conditions (all must hold):
+//   1. NFC-stable alone:            String.fromCodePoint(cp).normalize('NFC')
+//                                   returns the same codepoint.
+//   2. not a trailing composer:     cp never appears as a non-initial
+//                                   codepoint of any canonical (NFD)
+//                                   decomposition — i.e. NFC can never
+//                                   combine it with a preceding allowed
+//                                   codepoint (Hangul jamo, combining marks
+//                                   that compose, etc.).
+//   3. oracle probe, embedded:      new URL('http://a' + cp + 'z/') parses
+//                                   and its hostname equals
+//                                   'xn--' + punycode([a, cp, z]) — i.e.
+//                                   UTS-46 mapped cp to itself and the label
+//                                   is valid between LTR ASCII letters.
+//                                   (Rejects mapped/ignored/disallowed cps,
+//                                   RTL cps via CheckBidi, dot-mapped cps,
+//                                   ASCII-mapped cps, ...)
+//   4. oracle probe, standalone:    new URL('http://' + cp + '/') hostname
+//                                   equals 'xn--' + punycode([cp]) —
+//                                   rejects cps only valid mid-label
+//                                   (combining marks, ContextJ joiners, ...).
+//
+// Multi-codepoint safety argument: a label made only of allowed codepoints
+// (plus ASCII) is NFC-stable as a whole (no member is NFC-unstable, a
+// trailing composer, or a combining mark — marks fail probe 4), is not a
+// bidi domain name (no R/AL/AN members — they fail probe 3), and contains
+// no context-dependent joiners (fail probe 4). So UTS-46 maps the label to
+// itself and validates it, and wurl's naive punycode equals ada's output.
+//
+// L2 TODO seam: at L2 this bitmap is replaced by the full IdnaMappingTable
+// (mapping ranges + status), NFC via quickjs-ng libunicode, and bidi/joiner
+// derived-property tables; the generator then reads Unicode data files
+// instead of probing the oracle.
+
+'use strict';
+
+/* ---- RFC 3492 punycode encoder (codepoint array -> ASCII string) ---- */
+
+function punyDigit(d) {
+    return String.fromCharCode(d < 26 ? 97 + d : 22 + d);
+}
+
+function punyAdapt(delta, numpoints, firsttime) {
+    delta = firsttime ? Math.floor(delta / 700) : Math.floor(delta / 2);
+    delta += Math.floor(delta / numpoints);
+    let k = 0;
+    while (delta > 455) {
+        delta = Math.floor(delta / 35);
+        k += 36;
+    }
+    return k + Math.floor((36 * delta) / (delta + 38));
+}
+
+function punyEncode(cps) {
+    const out = [];
+    let n = 128;
+    let delta = 0;
+    let bias = 72;
+    for (const c of cps) {
+        if (c < 0x80) {
+            out.push(String.fromCharCode(c));
+        }
+    }
+    let h = out.length;
+    const b = h;
+    if (b > 0) {
+        out.push('-');
+    }
+    while (h < cps.length) {
+        let m = 0x110000;
+        for (const c of cps) {
+            if (c >= n && c < m) {
+                m = c;
+            }
+        }
+        delta += (m - n) * (h + 1);
+        n = m;
+        for (const c of cps) {
+            if (c < n) {
+                delta++;
+            } else if (c === n) {
+                let q = delta;
+                for (let k = 36; ; k += 36) {
+                    const t = k <= bias ? 1 : (k >= bias + 26 ? 26 : k - bias);
+                    if (q < t) {
+                        break;
+                    }
+                    out.push(punyDigit(t + ((q - t) % (36 - t))));
+                    q = Math.floor((q - t) / (36 - t));
+                }
+                out.push(punyDigit(q));
+                bias = punyAdapt(delta, h + 1, h === b);
+                delta = 0;
+                h++;
+            }
+        }
+        delta++;
+        n++;
+    }
+    return out.join('');
+}
+
+/* ---- condition 2: trailing composers (via NFD scan of all codepoints) ---- */
+
+const trailing = new Set();
+for (let cp = 0; cp <= 0x10ffff; cp++) {
+    if (cp >= 0xd800 && cp <= 0xdfff) {
+        continue;
+    }
+    const s = String.fromCodePoint(cp);
+    const d = s.normalize('NFD');
+    if (d === s) {
+        continue;
+    }
+    const dcps = [...d];
+    for (let i = 1; i < dcps.length; i++) {
+        trailing.add(dcps[i].codePointAt(0));
+    }
+}
+
+/* ---- main scan ---- */
+
+const allowed = new Uint8Array(0x110000 >> 3);
+let count = 0;
+
+for (let cp = 0x80; cp <= 0x10ffff; cp++) {
+    if (cp >= 0xd800 && cp <= 0xdfff) {
+        continue;
+    }
+    const s = String.fromCodePoint(cp);
+    if (s.normalize('NFC') !== s) {
+        continue;
+    }
+    if (trailing.has(cp)) {
+        continue;
+    }
+    let h;
+    try {
+        h = new URL('http://a' + s + 'z/').hostname;
+    } catch (e) {
+        continue;
+    }
+    if (h !== 'xn--' + punyEncode([0x61, cp, 0x7a])) {
+        continue;
+    }
+    let h2;
+    try {
+        h2 = new URL('http://' + s + '/').hostname;
+    } catch (e) {
+        continue;
+    }
+    if (h2 !== 'xn--' + punyEncode([cp])) {
+        continue;
+    }
+    allowed[cp >> 3] |= 1 << (cp & 7);
+    count++;
+}
+
+/* ---- emit C header: BMP bitmap + astral ranges ---- */
+
+const lines = [];
+lines.push('/* idna_allow.h — IDNA L1\' allow-bitmap. GENERATED, DO NOT EDIT.');
+lines.push(' *');
+lines.push(' * Regenerate with the pinned oracle tjs (vendored ada 3.4.2):');
+lines.push(' *   build/tjs/tjs run deps/wurl/gen-idna-allow.mjs > deps/wurl/idna_allow.h');
+lines.push(' * See gen-idna-allow.mjs for the admission conditions and the');
+lines.push(' * multi-codepoint safety argument.');
+lines.push(` * Allowed codepoints: ${count}.`);
+lines.push(' */');
+lines.push('#ifndef WURL_IDNA_ALLOW_H');
+lines.push('#define WURL_IDNA_ALLOW_H');
+lines.push('');
+lines.push('#include <stdint.h>');
+lines.push('#include <stddef.h>');
+lines.push('');
+lines.push('/* Bit cp&7 of byte cp>>3, for cp in the BMP. */');
+lines.push('static const uint8_t wurl_idna_allow_bmp[8192] = {');
+for (let i = 0; i < 8192; i += 16) {
+    const row = [];
+    for (let j = 0; j < 16; j++) {
+        row.push('0x' + allowed[i + j].toString(16).padStart(2, '0'));
+    }
+    lines.push('    ' + row.join(',') + ',');
+}
+lines.push('};');
+lines.push('');
+
+const ranges = [];
+let start = -1;
+for (let cp = 0x10000; cp <= 0x10ffff + 1; cp++) {
+    const on = cp <= 0x10ffff && (allowed[cp >> 3] & (1 << (cp & 7))) !== 0;
+    if (on && start < 0) {
+        start = cp;
+    } else if (!on && start >= 0) {
+        ranges.push([start, cp - 1]);
+        start = -1;
+    }
+}
+lines.push('/* Inclusive allowed ranges above the BMP, sorted; binary-searchable. */');
+lines.push(`#define WURL_IDNA_ALLOW_ASTRAL_COUNT ${ranges.length}`);
+lines.push('static const uint32_t wurl_idna_allow_astral[][2] = {');
+for (const [a, b] of ranges) {
+    lines.push(`    { 0x${a.toString(16)}, 0x${b.toString(16)} },`);
+}
+if (ranges.length === 0) {
+    lines.push('    { 0, 0 }, /* keep array non-empty */');
+}
+lines.push('};');
+lines.push('');
+lines.push('#endif /* WURL_IDNA_ALLOW_H */');
+
+console.log(lines.join('\n'));
