#!/bin/sh
# clode — run the latest Claude Code under host Node, no Bun runtime.
#
# Locates an upstream `claude` binary (from a provider package or the user's
# install), extracts its JS bundle once (cached per binary under the user's
# cache dir), and runs it under Node. A changed `claude` binary re-extracts on
# next launch, so provider updates are transparent.
set -e

# --- host tool + path defaults -------------------------------------------------
# clode ships as a plain script (npm package or source tree) with no install-time
# path baking: discover tools at runtime, resolve helpers relative to this script,
# read our version from the shipped VERSION file. Each is overridable via CLODE_*.
# `|| :` keeps a not-found result from tripping `set -e` (require_node gives a clean
# error if node is truly absent; CLODE_NODE/CLODE_PYTHON override).
LIBEXEC_BAKED=""                                          # -> $HERE/../libexec
NODE_BAKED="$(command -v node 2>/dev/null || :)"
PYTHON_BAKED="$(command -v python3 2>/dev/null || :)"
CLAUDE_BIN_BAKED=""                                       # -> resolve_claude_bin
CLODE_SELF_VERSION=""                                     # -> read from VERSION below
# --------------------------------------------------------------------------

# Resolve the upstream claude binary to extract from. Precedence:
#   CLODE_CLAUDE_BIN > CLODE_VERSION_DIR > baked provider path >
#   ~/.local/bin/claude (symlink-resolved) > `claude` on PATH.
resolve_claude_bin() {
  if [ -n "$CLODE_CLAUDE_BIN" ];  then printf '%s\n' "$CLODE_CLAUDE_BIN";  return 0; fi
  if [ -n "$CLODE_VERSION_DIR" ]; then printf '%s\n' "$CLODE_VERSION_DIR"; return 0; fi
  if [ -n "$CLAUDE_BIN_BAKED" ] && [ -e "$CLAUDE_BIN_BAKED" ]; then
    printf '%s\n' "$CLAUDE_BIN_BAKED"; return 0
  fi
  link="$HOME/.local/bin/claude"
  if [ -e "$link" ]; then
    real=$(readlink "$link" 2>/dev/null || printf '%s' "$link")
    case "$real" in /*) ;; *) real="$(dirname "$link")/$real" ;; esac
    printf '%s\n' "$real"; return 0
  fi
  if p=$(command -v claude 2>/dev/null); then printf '%s\n' "$p"; return 0; fi
  return 1
}

# Fast size+mtime signature: GNU stat, then BSD stat, then a python fallback.
sig_of() {
  stat -c '%s-%Y' "$1" 2>/dev/null && return 0
  stat -f '%z-%m' "$1" 2>/dev/null && return 0
  "$PYTHON" -c 'import os,sys;s=os.stat(sys.argv[1]);print("%d-%d"%(s.st_size,int(s.st_mtime)))' "$1"
}

# Cache key: reads $BIN, sets $KEY.
# The version is used when the path encodes one (.../versions/<ver>[/...]),
# else <basename>-<size+mtime> so a changed provider binary re-extracts.
cache_key() {
  case "$BIN" in
    */versions/*) KEY=${BIN#*/versions/}; KEY=${KEY%%/*} ;;
    *)            KEY="$(basename "$BIN")-$(sig_of "$BIN")" ;;
  esac
}

# Check that Node is present and meets the minimum version requirement.
require_node() {
  # Minimum Node major. The extracted bundle adopts newer JS over time (today
  # TC39 `using`, needs Node >= 24); this creeps upward. Clear error, not a
  # leaked V8 SyntaxError.
  MIN_NODE_MAJOR=24
  if [ ! -x "$NODE" ]; then
    echo "clode: no usable node at '$NODE' (set CLODE_NODE)" >&2
    exit 1
  fi
  NODE_MAJOR=$("$NODE" -e 'process.stdout.write(process.versions.node.split(".")[0])' 2>/dev/null || echo 0)
  if [ "${NODE_MAJOR:-0}" -lt "$MIN_NODE_MAJOR" ]; then
    echo "clode: node $("$NODE" --version 2>/dev/null) is too old; need >= v$MIN_NODE_MAJOR" >&2
    echo "clode: (the extracted bundle uses newer JS, e.g. 'using' declarations)" >&2
    exit 1
  fi
}

# Extract-on-first-use, cached per key. Runs node --check on the output;
# refuses to cache on any failure.
extract_if_needed() {
  # cli.cjs is a function of BOTH the provider binary (the cache KEY) AND the
  # extractor logic that patches it (the /doctor inject, future patches). The KEY
  # only captures the binary, so fingerprint the extractor too and re-extract when
  # it changes — otherwise an extract-claude-js edit never reaches existing caches
  # until the binary moves. (The shim is handled separately, by cmp below.)
  _extractor_sig=$(sig_of "$LIBEXEC/extract-claude-js")
  if [ -f "$CACHE/cli.cjs" ] && [ -f "$CACHE/bun-shim.cjs" ] \
     && [ "$(cat "$CACHE/.extractor-sig" 2>/dev/null)" = "$_extractor_sig" ]; then
    # Cache hit on the bundle. Still refresh the cached shim if the installed
    # source differs, so a shim fix reaches existing per-version caches without
    # waiting for a provider update to trigger a re-extract. (The cli.cjs prelude
    # require()s bun-shim.cjs from this same dir at every launch.)
    if ! cmp -s "$LIBEXEC/bun-shim.cjs" "$CACHE/bun-shim.cjs"; then
      cp "$LIBEXEC/bun-shim.cjs" "$CACHE/bun-shim.cjs"
      echo "clode: refreshed cached bun-shim for $KEY" >&2
    fi
    return 0
  fi
  if [ -f "$CACHE/cli.cjs" ]; then
    echo "clode: extractor changed; re-extracting JS for $KEY..." >&2
  else
    echo "clode: extracting JS for $KEY..." >&2
  fi
  mkdir -p "$CACHE"
  if ! "$PYTHON" "$LIBEXEC/extract-claude-js" "$BIN" "$CACHE/cli.cjs"; then
    rm -f "$CACHE/cli.cjs"
    echo "clode: extraction failed (see error above); not caching." >&2
    exit 1
  fi
  if ! "$NODE" --check "$CACHE/cli.cjs"; then
    rm -f "$CACHE/cli.cjs"
    echo "clode: extracted JS failed 'node --check'; not caching." >&2
    exit 1
  fi
  cp "$LIBEXEC/bun-shim.cjs" "$CACHE/bun-shim.cjs"
  printf '%s\n' "$_extractor_sig" > "$CACHE/.extractor-sig"
}

# On legacy macOS (no trustd; the old ocspd/CSSM trust stack), evaluating the
# system certificate store does blocking per-cert OCSP fetches — tens of seconds,
# enough to stall the TUI. There, default Claude Code's CA source to the bundled
# Mozilla roots (fast, and sufficient for api.anthropic.com). Overridable; gated to
# macOS so Linux/NetBSD are untouched. Add a private/corporate root via
# NODE_EXTRA_CA_CERTS to keep the bundled (fast) path. CLODE_TRUSTD overrides the
# probe path (for tests).
maybe_default_cert_store() {
  [ "$(uname -s)" = Darwin ] || return 0
  [ -e "${CLODE_TRUSTD:-/usr/libexec/trustd}" ] && return 0   # modern trust stack: leave app default
  : "${CLAUDE_CODE_CERT_STORE:=bundled}"; export CLAUDE_CODE_CERT_STORE
}

# Point Claude Code's internal Grep tool at a real ripgrep when one exists, so it
# uses system rg instead of its embedded copy. The bundle enables system mode when
# USE_BUILTIN_RIPGREP is 0/false/no/off AND it can resolve `rg` on PATH (it does a
# plain PATH lookup — there is no path env var). rg stays OPTIONAL: if none is found
# we leave the config alone and let Claude Code fall back to its embedded search.
# Override the discovered rg with CLODE_RG.
set_ripgrep_env() {
  _rg="${CLODE_RG:-$(command -v rg 2>/dev/null || :)}"
  [ -n "$_rg" ] || return 0
  : "${USE_BUILTIN_RIPGREP:=0}"; export USE_BUILTIN_RIPGREP
  # Ensure the chosen rg is discoverable on PATH (the bundle finds it by name).
  _rgdir=$(dirname "$_rg")
  case ":$PATH:" in
    *":$_rgdir:"*) : ;;
    *) PATH="$_rgdir:$PATH"; export PATH ;;
  esac
}

# Launch the cached bundle under the inherited environment.
# DISABLE_INSTALLATION_CHECKS silences the npm-deprecation nudge (false
# positive for our non-native install).
exec_bundle() {
  : "${DISABLE_INSTALLATION_CHECKS:=1}"; export DISABLE_INSTALLATION_CHECKS
  : "${NODE_USE_ENV_PROXY:=1}"; export NODE_USE_ENV_PROXY
  maybe_default_cert_store
  set_ripgrep_env
  set_node_path
  exec "$NODE" "$CACHE/cli.cjs" "$@"
}

# Make host-installed npm packages (notably `ws`, the WebSocket dependency the
# shim requires for Remote Control / MCP-over-WebSocket) resolvable by the shim,
# which runs from the cache dir and so wouldn't otherwise find a global install.
# npm puts globals under <node-prefix>/lib/node_modules; add that to NODE_PATH,
# preserving any the user set. No-op if the dir doesn't exist.
set_node_path() {
  # Where clode's runtime deps live, most-authoritative first: an npm install ships
  # them in clode's own node_modules ($HERE/../node_modules); else ensure_deps put
  # them in DEPS_ROOT; finally the node prefix's global node_modules. Any NODE_PATH
  # the user set stays ahead of all (their override wins). No-op on absent dirs.
  for _d in "$(cd "$HERE/.." 2>/dev/null && pwd || :)/node_modules" \
            "${DEPS_ROOT:-}/node_modules" \
            "$(cd "$(dirname "$NODE")/../lib/node_modules" 2>/dev/null && pwd || :)"; do
    [ -d "$_d" ] || continue
    case ":${NODE_PATH:-}:" in
      *":$_d:"*) : ;;
      *) NODE_PATH="${NODE_PATH:+$NODE_PATH:}$_d"; export NODE_PATH ;;
    esac
  done
}

# Resolve clode's runtime npm deps (the package.json manifest) into a user-owned dir,
# installing on first run and re-installing when the manifest changes (sig-gated, like
# extract_if_needed). These back the bundle's ext-deps (ws, yaml, string-width, ...).
# User-owned => no sudo; CLODE_DEPS overrides the dir AND, if already populated, opts
# out of auto-install (you manage it). CLODE_NPM overrides the npm binary.
ensure_deps() {
  DEPS_ROOT="${CLODE_DEPS:-${XDG_DATA_HOME:-$HOME/.local/share}/clode}"
  _manifest=""
  for _c in "$LIBEXEC/package.json" "$HERE/../package.json"; do
    [ -f "$_c" ] && { _manifest="$_c"; break; }
  done
  [ -n "$_manifest" ] || return 0            # no manifest shipped -> nothing to ensure
  # An npm install ships clode's deps in its own node_modules -> nothing to install.
  [ -d "$HERE/../node_modules" ] && return 0
  # A CLODE_DEPS dir with node_modules but no clode-written .deps-sig is user-managed:
  # trust it, never auto-install. (Our own managed dir HAS a .deps-sig, so it still
  # falls through to the sig-gate below and re-installs when the manifest changes.)
  [ -n "${CLODE_DEPS:-}" ] && [ -d "$CLODE_DEPS/node_modules" ] && [ ! -f "$CLODE_DEPS/.deps-sig" ] && return 0
  _sig=$(sig_of "$_manifest")
  if [ -d "$DEPS_ROOT/node_modules" ] && \
     [ "$(cat "$DEPS_ROOT/.deps-sig" 2>/dev/null)" = "$_sig" ]; then
    return 0                                 # already fresh for this manifest
  fi
  echo "clode: installing dependencies..." >&2
  _npm="${CLODE_NPM:-$(command -v npm 2>/dev/null || :)}"
  if [ -z "$_npm" ]; then
    echo "clode: need npm to install runtime dependencies (ws, yaml, string-width, ...);" >&2
    echo "       install npm, or set CLODE_DEPS to a node_modules you populate yourself." >&2
    exit 1
  fi
  mkdir -p "$DEPS_ROOT"
  cp "$_manifest" "$DEPS_ROOT/package.json"
  if ! "$_npm" install --prefix "$DEPS_ROOT" --no-audit --no-fund --omit=dev >&2; then
    echo "clode: dependency install failed (see npm output above)." >&2
    exit 1
  fi
  printf '%s\n' "$_sig" > "$DEPS_ROOT/.deps-sig"
}

main() {
  # Resolve this script's real location, following symlinks (so an npm-installed
  # bin symlink works, and the source tree runs in place).
  SELF="$0"
  while [ -h "$SELF" ]; do
    link=$(readlink "$SELF")
    case "$link" in /*) SELF="$link" ;; *) SELF="$(dirname "$SELF")/$link" ;; esac
  done
  HERE=$(cd "$(dirname "$SELF")" && pwd)

  # Our version comes from the shipped VERSION file (next to bin/, both in the source
  # tree and an npm install). `clode --clode-version` reports it without launching the
  # bundle. (`clode --version` still passes through to Claude Code.)
  CLODE_SELF_VERSION=$(cat "$HERE/../VERSION" 2>/dev/null || echo dev)
  if [ "$1" = "--clode-version" ]; then
    echo "clode $CLODE_SELF_VERSION"
    exit 0
  fi

  # Helper files (extractor, shim): `$HERE/../libexec` for the source tree and an npm
  # install alike; a flat layout (bin and helpers in one dir) also works. CLODE_LIBEXEC
  # overrides.
  LIBEXEC="${CLODE_LIBEXEC:-$LIBEXEC_BAKED}"
  if [ -z "$LIBEXEC" ]; then
    if [ -f "$HERE/bun-shim.cjs" ]; then
      LIBEXEC="$HERE"                 # flat layout (e.g. a packaged libexec dir)
    elif [ -f "$HERE/../libexec/bun-shim.cjs" ]; then
      LIBEXEC="$(cd "$HERE/../libexec" && pwd)"   # source tree: bin/ + libexec/
    else
      LIBEXEC="$HERE"
    fi
  fi

  # Host tools. Override per box.
  NODE="${CLODE_NODE:-$NODE_BAKED}"
  PYTHON="${CLODE_PYTHON:-$PYTHON_BAKED}"

  require_node

  BIN=$(resolve_claude_bin) || {
    echo "clode: no Claude Code binary found." >&2
    echo "clode: install the provider package (e.g. claude-code), or set" >&2
    echo "clode: CLODE_CLAUDE_BIN=/path/to/claude" >&2
    exit 1
  }
  if [ ! -e "$BIN" ]; then
    echo "clode: claude binary not found at '$BIN'" >&2
    exit 1
  fi

  cache_key

  CACHE_ROOT="${CLODE_CACHE:-${XDG_CACHE_HOME:-$HOME/.cache}/clode}"
  CACHE="$CACHE_ROOT/$KEY"

  extract_if_needed

  ensure_deps

  exec_bundle "$@"
}

# Allow BATS/tests to source this file and call functions without launching.
[ -n "${CLODE_SOURCED:-}" ] || main "$@"
