#!/bin/sh
# clode — run the latest Claude Code under host Node, no Bun runtime.
#
# Locates an upstream `claude` binary (from a provider package or the user's
# install), extracts its JS bundle once (cached per binary under the user's
# cache dir), and runs it under Node. A changed `claude` binary re-extracts on
# next launch, so provider updates are transparent.
set -e

# --- host tool + path defaults -------------------------------------------------
# clode ships as a plain script (npm package or source tree) with no install-time
# path baking: discover tools at runtime, resolve helpers relative to this script,
# read our version from the shipped VERSION file. Each is overridable via CLODE_*.
# `|| :` keeps a not-found result from tripping `set -e` (require_node gives a clean
# error if node is truly absent; CLODE_NODE/CLODE_PYTHON override).
LIBEXEC_BAKED=""                                          # -> $HERE/../libexec
NODE_BAKED="$(command -v node 2>/dev/null || :)"
PYTHON_BAKED="$(command -v python3 2>/dev/null || :)"
CLAUDE_BIN_BAKED=""                                       # -> resolve_claude_bin
CLODE_SELF_VERSION=""                                     # -> read from VERSION below
# --------------------------------------------------------------------------

# clode's own progress chatter. Silent unless --clode-verbose (or CLODE_VERBOSE=1),
# so a normal launch emits ONLY Claude Code's output. Errors never use this — they
# always print, so a failure is never silent.
clode_log() { if [ -n "${CLODE_VERBOSE:-}" ]; then echo "$@" >&2; fi; }

# Run a noisy helper (the extractor, npm) quietly: stream its output live when
# verbose, else swallow it on success but resurface it on failure (keeping the
# "see error above" diagnostics honest).
run_quiet() {
  if [ -n "${CLODE_VERBOSE:-}" ]; then "$@"; return $?; fi
  _ql=$(mktemp 2>/dev/null || printf '%s' "${TMPDIR:-/tmp}/clode-quiet.$$")
  if "$@" >"$_ql" 2>&1; then
    rm -f "$_ql"; return 0
  else
    _rc=$?                 # in the else, $? is the command's status (not the if's)
    cat "$_ql" >&2; rm -f "$_ql"; return "$_rc"
  fi
}

# Resolve the upstream claude binary to extract from. Precedence:
#   CLODE_CLAUDE_BIN > CLODE_VERSION_DIR > baked provider path >
#   ~/.local/bin/claude (symlink-resolved) > `claude` on PATH.
resolve_claude_bin() {
  if [ -n "$CLODE_CLAUDE_BIN" ];  then printf '%s\n' "$CLODE_CLAUDE_BIN";  return 0; fi
  if [ -n "$CLODE_VERSION_DIR" ]; then printf '%s\n' "$CLODE_VERSION_DIR"; return 0; fi
  _prov="${CLODE_PROVIDERS:-${XDG_DATA_HOME:-$HOME/.local/share}/clode/providers}/current"
  if [ -e "$_prov/claude" ]; then
    printf '%s\n' "$(cd "$_prov" 2>/dev/null && pwd -P)/claude"; return 0
  fi
  if [ -n "$CLAUDE_BIN_BAKED" ] && [ -e "$CLAUDE_BIN_BAKED" ]; then
    printf '%s\n' "$CLAUDE_BIN_BAKED"; return 0
  fi
  link="$HOME/.local/bin/claude"
  if [ -e "$link" ]; then
    real=$(readlink "$link" 2>/dev/null || printf '%s' "$link")
    case "$real" in /*) ;; *) real="$(dirname "$link")/$real" ;; esac
    printf '%s\n' "$real"; return 0
  fi
  if p=$(command -v claude 2>/dev/null); then printf '%s\n' "$p"; return 0; fi
  return 1
}

# Some installs ship `claude` as a tiny shell wrapper that just `exec`s the real
# single-file binary (e.g. Linux distro packaging where /usr/bin/claude is
# `exec /opt/claude-code/bin/claude "$@"`). Extracting JS from the wrapper fails
# with "no @bun-cjs entry marker found" (see GitHub issue #1); follow its exec
# target to the real bundle. Real bundles are >100MB (and test fixtures ~1MB), so
# only files small enough to BE a wrapper are inspected — we never sed the bundle.
# Bounded against exec cycles; only absolute exec targets are followed, so a
# `exec "$@"`/`exec env ...`/relative line leaves the path unchanged.
follow_wrapper() {
  _w="$1"; _n=0
  while [ "$_n" -lt 10 ] && [ -f "$_w" ] && \
        [ "$(wc -c < "$_w" 2>/dev/null || echo 999999)" -lt 65536 ]; do
    _t=$(sed -n 's/^[[:space:]]*exec[[:space:]]\{1,\}\([^[:space:]]\{1,\}\).*/\1/p' "$_w" 2>/dev/null | tail -1)
    case "$_t" in /*) ;; *) break ;; esac        # only follow an absolute target
    [ -e "$_t" ] && [ "$_t" != "$_w" ] || break
    _w="$_t"; _n=$((_n + 1))
  done
  printf '%s\n' "$_w"
}

# Fast size+mtime signature: GNU stat, then BSD stat, then a python fallback.
sig_of() {
  stat -c '%s-%Y' "$1" 2>/dev/null && return 0
  stat -f '%z-%m' "$1" 2>/dev/null && return 0
  "$PYTHON" -c 'import os,sys;s=os.stat(sys.argv[1]);print("%d-%d"%(s.st_size,int(s.st_mtime)))' "$1"
}

# Pick an available SHA-256 tool (linux: sha256sum, macOS/BSD: shasum). Echoes hex digest.
sha256_of() {
  if command -v sha256sum >/dev/null 2>&1; then sha256sum "$1" | cut -d' ' -f1
  elif command -v shasum >/dev/null 2>&1; then shasum -a 256 "$1" | cut -d' ' -f1
  else echo "clode: need sha256sum or shasum to verify downloads" >&2; return 1; fi
}

# GET a URL (curl or wget). $1=url, $2=output file (optional; stdout if omitted).
# $CLODE_DOWNLOADER is set by clode_update; URLs may be https:// or file://.
download_file() {
  if [ "${CLODE_DOWNLOADER:-curl}" = curl ]; then
    if [ -n "${2:-}" ]; then curl -fsSL -o "$2" "$1"; else curl -fsSL "$1"; fi
  else
    if [ -n "${2:-}" ]; then wget -qO "$2" "$1"; else wget -qO - "$1"; fi
  fi
}

# Cache key: reads $BIN, sets $KEY.
# The version is used when the path encodes one (.../versions/<ver>[/...]),
# else <basename>-<size+mtime> so a changed provider binary re-extracts.
cache_key() {
  case "$BIN" in
    */versions/*)  KEY=${BIN#*/versions/}; KEY=${KEY%%/*} ;;
    */providers/*) KEY=${BIN#*/providers/}; KEY=${KEY%%/*} ;;
    *)             KEY="$(basename "$BIN")-$(sig_of "$BIN")" ;;
  esac
}

# Check that Node is present and meets the minimum version requirement.
require_node() {
  # Minimum Node major. The extracted bundle adopts newer JS over time (today
  # TC39 `using`, needs Node >= 24); this creeps upward. Clear error, not a
  # leaked V8 SyntaxError.
  MIN_NODE_MAJOR=24
  if [ ! -x "$NODE" ]; then
    echo "clode: no usable node at '$NODE' (set CLODE_NODE)" >&2
    exit 1
  fi
  NODE_MAJOR=$("$NODE" -e 'process.stdout.write(process.versions.node.split(".")[0])' 2>/dev/null || echo 0)
  if [ "${NODE_MAJOR:-0}" -lt "$MIN_NODE_MAJOR" ]; then
    echo "clode: node $("$NODE" --version 2>/dev/null) is too old; need >= v$MIN_NODE_MAJOR" >&2
    echo "clode: (the extracted bundle uses newer JS, e.g. 'using' declarations)" >&2
    exit 1
  fi
}

# Extract-on-first-use, cached per key. Runs node --check on the output;
# refuses to cache on any failure.
extract_if_needed() {
  # cli.cjs is a function of BOTH the provider binary (the cache KEY) AND the
  # extractor logic that patches it (the /doctor inject, future patches). The KEY
  # only captures the binary, so fingerprint the extractor too and re-extract when
  # it changes — otherwise an extract-claude-js edit never reaches existing caches
  # until the binary moves. (The shim is handled separately, by cmp below.)
  _extractor_sig=$(sig_of "$LIBEXEC/extract-claude-js")
  if [ -f "$CACHE/cli.cjs" ] && [ -f "$CACHE/bun-shim.cjs" ] \
     && [ "$(cat "$CACHE/.extractor-sig" 2>/dev/null)" = "$_extractor_sig" ]; then
    # Cache hit on the bundle. Still refresh the cached shim if the installed
    # source differs, so a shim fix reaches existing per-version caches without
    # waiting for a provider update to trigger a re-extract. (The cli.cjs prelude
    # require()s bun-shim.cjs from this same dir at every launch.)
    if ! cmp -s "$LIBEXEC/bun-shim.cjs" "$CACHE/bun-shim.cjs"; then
      cp "$LIBEXEC/bun-shim.cjs" "$CACHE/bun-shim.cjs"
      clode_log "clode: refreshed cached bun-shim for $KEY"
    fi
    return 0
  fi
  if [ -f "$CACHE/cli.cjs" ]; then
    clode_log "clode: extractor changed; re-extracting JS for $KEY..."
  else
    clode_log "clode: extracting JS for $KEY..."
  fi
  mkdir -p "$CACHE"
  if ! run_quiet "$PYTHON" "$LIBEXEC/extract-claude-js" "$BIN" "$CACHE/cli.cjs"; then
    rm -f "$CACHE/cli.cjs"
    echo "clode: extraction failed (see error above); not caching." >&2
    exit 1
  fi
  if ! "$NODE" --check "$CACHE/cli.cjs"; then
    rm -f "$CACHE/cli.cjs"
    echo "clode: extracted JS failed 'node --check'; not caching." >&2
    exit 1
  fi
  cp "$LIBEXEC/bun-shim.cjs" "$CACHE/bun-shim.cjs"
  printf '%s\n' "$_extractor_sig" > "$CACHE/.extractor-sig"
}

# On legacy macOS (no trustd; the old ocspd/CSSM trust stack), evaluating the
# system certificate store does blocking per-cert OCSP fetches — tens of seconds,
# enough to stall the TUI. There, default Claude Code's CA source to the bundled
# Mozilla roots (fast, and sufficient for api.anthropic.com). Overridable; gated to
# macOS so Linux/NetBSD are untouched. Add a private/corporate root via
# NODE_EXTRA_CA_CERTS to keep the bundled (fast) path. CLODE_TRUSTD overrides the
# probe path (for tests).
maybe_default_cert_store() {
  [ "$(uname -s)" = Darwin ] || return 0
  [ -e "${CLODE_TRUSTD:-/usr/libexec/trustd}" ] && return 0   # modern trust stack: leave app default
  : "${CLAUDE_CODE_CERT_STORE:=bundled}"; export CLAUDE_CODE_CERT_STORE
}

# Point Claude Code's internal Grep tool at a real ripgrep when one exists, so it
# uses system rg instead of its embedded copy. The bundle enables system mode when
# USE_BUILTIN_RIPGREP is 0/false/no/off AND it can resolve `rg` on PATH (it does a
# plain PATH lookup — there is no path env var). rg stays OPTIONAL: if none is found
# we leave the config alone and let Claude Code fall back to its embedded search.
# Override the discovered rg with CLODE_RG.
set_ripgrep_env() {
  _rg="${CLODE_RG:-$(command -v rg 2>/dev/null || :)}"
  [ -n "$_rg" ] || return 0
  : "${USE_BUILTIN_RIPGREP:=0}"; export USE_BUILTIN_RIPGREP
  # Ensure the chosen rg is discoverable on PATH (the bundle finds it by name).
  _rgdir=$(dirname "$_rg")
  case ":$PATH:" in
    *":$_rgdir:"*) : ;;
    *) PATH="$_rgdir:$PATH"; export PATH ;;
  esac
}

# Launch the cached bundle under the inherited environment.
# DISABLE_INSTALLATION_CHECKS silences the npm-deprecation nudge (false
# positive for our non-native install).
# Write a clode-ONLY settings file wiring the PreToolUse update-guard hook, and echo
# its path. Passed via --settings so it MERGES with (never overwrites) the user's
# settings and exists only for clode-launched sessions — upstream claude never sees
# it. MUST NOT be written into any shared settings file (~/.claude/settings.json,
# project .claude/settings.json, .claude/settings.local.json). Absolute node + script
# paths so the hook runs regardless of the session's PATH. No-op (echo nothing) if the
# guard script is missing.
write_update_guard_settings() {
  _guard_script="$LIBEXEC/clode-update-guard.cjs"
  [ -f "$_guard_script" ] || return 0
  _dir="${XDG_CACHE_HOME:-$HOME/.cache}/clode"
  _out="$_dir/update-guard-settings.json"
  mkdir -p "$_dir" || return 0
  printf '{"hooks":{"PreToolUse":[{"matcher":"Bash","hooks":[{"type":"command","command":"%s %s"}]}]}}\n' \
    "$NODE" "$_guard_script" > "$_out" || return 0
  printf '%s\n' "$_out"
}

# Decide whether THIS invocation gets the update-guard hook, and echo the settings
# path if so (else nothing). Print-and-exit invocations (`clode --version`/`--help`)
# run no model, so the PreToolUse(Bash) guard can never fire on them — and passing
# --settings there would make the bundle take the settings/render path, needlessly
# requiring the render ext-deps for a bare `clode --version`. Skip those; every real
# session (interactive, -p) gets the guard. Match the FIRST arg exactly so a prompt
# that merely contains the text "--version" (e.g. `-p "explain --version"`) is not
# mistaken for the flag; the canonical `clode --version`/`--help` lead with it.
guard_settings_for_args() {
  case "$1" in
    --version|-v|--help|-h) return 0 ;;
  esac
  write_update_guard_settings
}

exec_bundle() {
  : "${DISABLE_INSTALLATION_CHECKS:=1}"; export DISABLE_INSTALLATION_CHECKS
  : "${NODE_USE_ENV_PROXY:=1}"; export NODE_USE_ENV_PROXY
  maybe_default_cert_store
  set_ripgrep_env
  set_node_path
  # Hand the bundle's in-TUI autoupdater a way back to this launcher: it spawns
  # "$CLODE_SELF --clode-internal-update" instead of the npm path that fails under clode.
  CLODE_SELF="$SELF"; export CLODE_SELF
  _guard_settings=$(guard_settings_for_args "$@")
  exec "$NODE" "$CACHE/cli.cjs" ${_guard_settings:+--settings "$_guard_settings"} "$@"
}

# Make host-installed npm packages (notably `ws`, the WebSocket dependency the
# shim requires for Remote Control / MCP-over-WebSocket) resolvable by the shim,
# which runs from the cache dir and so wouldn't otherwise find a global install.
# npm puts globals under <node-prefix>/lib/node_modules; add that to NODE_PATH,
# preserving any the user set. No-op if the dir doesn't exist.
set_node_path() {
  # Where clode's runtime deps live, most-authoritative first: an npm install ships
  # them in clode's own node_modules ($HERE/../node_modules); else ensure_deps put
  # them in DEPS_ROOT; finally the node prefix's global node_modules. Any NODE_PATH
  # the user set stays ahead of all (their override wins). No-op on absent dirs.
  for _d in "$(cd "$HERE/.." 2>/dev/null && pwd || :)/node_modules" \
            "${DEPS_ROOT:-}/node_modules" \
            "$(cd "$(dirname "$NODE")/../lib/node_modules" 2>/dev/null && pwd || :)"; do
    [ -d "$_d" ] || continue
    case ":${NODE_PATH:-}:" in
      *":$_d:"*) : ;;
      *) NODE_PATH="${NODE_PATH:+$NODE_PATH:}$_d"; export NODE_PATH ;;
    esac
  done
}

# Resolve clode's runtime npm deps (the package.json manifest) into a user-owned dir,
# installing on first run and re-installing when the manifest changes (sig-gated, like
# extract_if_needed). These back the bundle's ext-deps (ws, yaml, string-width, ...).
# User-owned => no sudo; CLODE_DEPS overrides the dir AND, if already populated, opts
# out of auto-install (you manage it). CLODE_NPM overrides the npm binary.
ensure_deps() {
  DEPS_ROOT="${CLODE_DEPS:-${XDG_DATA_HOME:-$HOME/.local/share}/clode}"
  _manifest=""
  for _c in "$LIBEXEC/package.json" "$HERE/../package.json"; do
    [ -f "$_c" ] && { _manifest="$_c"; break; }
  done
  [ -n "$_manifest" ] || return 0            # no manifest shipped -> nothing to ensure
  # An npm install ships clode's deps in its own node_modules -> nothing to install.
  [ -d "$HERE/../node_modules" ] && return 0
  # A CLODE_DEPS dir with node_modules but no clode-written .deps-sig is user-managed:
  # trust it, never auto-install. (Our own managed dir HAS a .deps-sig, so it still
  # falls through to the sig-gate below and re-installs when the manifest changes.)
  [ -n "${CLODE_DEPS:-}" ] && [ -d "$CLODE_DEPS/node_modules" ] && [ ! -f "$CLODE_DEPS/.deps-sig" ] && return 0
  _sig=$(sig_of "$_manifest")
  if [ -d "$DEPS_ROOT/node_modules" ] && \
     [ "$(cat "$DEPS_ROOT/.deps-sig" 2>/dev/null)" = "$_sig" ]; then
    return 0                                 # already fresh for this manifest
  fi
  clode_log "clode: installing dependencies..."
  _npm="${CLODE_NPM:-$(command -v npm 2>/dev/null || :)}"
  if [ -z "$_npm" ]; then
    echo "clode: need npm to install runtime dependencies (ws, yaml, string-width, ...);" >&2
    echo "       install npm, or set CLODE_DEPS to a node_modules you populate yourself." >&2
    exit 1
  fi
  mkdir -p "$DEPS_ROOT"
  cp "$_manifest" "$DEPS_ROOT/package.json"
  if ! run_quiet "$_npm" install --prefix "$DEPS_ROOT" --no-audit --no-fund --omit=dev; then
    echo "clode: dependency install failed (see npm output above)." >&2
    exit 1
  fi
  printf '%s\n' "$_sig" > "$DEPS_ROOT/.deps-sig"
}

# Fetch the latest upstream Claude Code JS host-agnostically into clode's provider
# store, then leave it for extract-on-change to pick up. We request a FIXED platform
# (linux-x64): the embedded JS is the same program on every platform (it branches on
# process.platform at runtime), so clode runs it under Node on any host -- including
# ones Anthropic ships no binary for. We NEVER run the downloaded binary.
CLODE_RELEASES_URL="${CLODE_RELEASES_URL:-https://downloads.claude.ai/claude-code-releases}"
CLODE_FETCH_PLATFORM="${CLODE_FETCH_PLATFORM:-linux-x64}"
# Release notes live on GitHub (not the downloads server). Used only by the
# warn-only post-update signals digest; override for tests/air-gapped boxes.
CLODE_CHANGELOG_URL="${CLODE_CHANGELOG_URL:-https://raw.githubusercontent.com/anthropics/claude-code/main/CHANGELOG.md}"

# After an update, surface Anthropic's direction-of-travel signals: release-note
# lines and bundle markers that bear on clode's ability to keep running the JS
# under Node (e.g. "upgraded the bundled Bun runtime", "requires the native
# binary"). Prints a digest; in a source checkout also writes a reviewable
# signals/<ver>.json snapshot. STRICTLY best-effort — never affects the update's
# exit status (warn-only by design). No-op when sourced without main() (no LIBEXEC).
clode_signals_report() {
  _ver="$1"; _prev="$2"; _bin="$3"
  _tool="$LIBEXEC/clode-signals"
  [ -n "$LIBEXEC" ] && [ -f "$_tool" ] || return 0
  _cltmp="${TMPDIR:-/tmp}/clode-changelog.$$"; _cl=""
  download_file "$CLODE_CHANGELOG_URL" "$_cltmp" 2>/dev/null && _cl="$_cltmp"
  _sigdir="${CLODE_SIGNALS_DIR:-}"
  if [ -z "$_sigdir" ] && [ -d "$HERE/../.git" ]; then _sigdir="$HERE/../signals"; fi
  "$PYTHON" "$_tool" --version "$_ver" \
    ${_prev:+--prev "$_prev"} ${_bin:+--bundle "$_bin"} \
    ${_cl:+--changelog-file "$_cl"} ${_sigdir:+--snapshot-dir "$_sigdir"} 2>/dev/null || :
  rm -f "$_cltmp" 2>/dev/null || :
}

clode_update() {
  _channel="${1:-stable}"
  if command -v curl >/dev/null 2>&1; then CLODE_DOWNLOADER=curl
  elif command -v wget >/dev/null 2>&1; then CLODE_DOWNLOADER=wget
  else echo "clode: need curl or wget to update" >&2; return 1; fi
  _base="$CLODE_RELEASES_URL"
  case "$_channel" in
    [0-9]*) _ver="$_channel" ;;
    *)      _ver=$(download_file "$_base/$_channel" | tr -d '\r\n') ;;
  esac
  case "$_ver" in
    [0-9]*.[0-9]*.[0-9]*) : ;;
    *) echo "clode: couldn't resolve a version for '$_channel' from $_base" >&2; return 1 ;;
  esac
  _plat="$CLODE_FETCH_PLATFORM"
  _manifest=$(download_file "$_base/$_ver/manifest.json") || { echo "clode: failed to fetch manifest for $_ver" >&2; return 1; }
  _sum=$(printf '%s' "$_manifest" | "$PYTHON" -c \
    "import json,sys;d=json.load(sys.stdin);p=d.get('platforms',d);print(p.get('$_plat',{}).get('checksum',''))" 2>/dev/null)
  case "$_sum" in
    [0-9a-f]*) : ;;
    *) echo "clode: platform $_plat not in manifest for $_ver" >&2; return 1 ;;
  esac
  _providers="${CLODE_PROVIDERS:-${XDG_DATA_HOME:-$HOME/.local/share}/clode/providers}"
  _dest="$_providers/$_ver"; _bin="$_dest/claude"
  if [ -f "$_bin" ] && [ "$(sha256_of "$_bin")" = "$_sum" ]; then
    echo "clode: already have $_ver" >&2
  else
    echo "clode: fetching Claude Code $_ver ($_plat)..." >&2
    mkdir -p "$_dest"; _tmp="$_dest/.claude.partial"
    if ! download_file "$_base/$_ver/$_plat/claude" "$_tmp"; then
      rm -f "$_tmp"; echo "clode: download failed" >&2; return 1
    fi
    if [ "$(sha256_of "$_tmp")" != "$_sum" ]; then
      rm -f "$_tmp"; echo "clode: checksum mismatch for $_ver (corrupt or tampered download)" >&2; return 1
    fi
    mv "$_tmp" "$_bin"; chmod +x "$_bin"
  fi
  _prev_ver=""
  [ -L "$_providers/current" ] && _prev_ver=$(readlink "$_providers/current" 2>/dev/null)
  ln -sfn "$_ver" "$_providers/current"
  echo "clode: updated to $_ver. Relaunch clode to use it." >&2
  clode_signals_report "$_ver" "$_prev_ver" "$_bin" >&2 || :
}

# clode's own help (clode-specific flags only — `clode --help` still passes
# through to Claude Code). Printed to stdout; exits 0.
clode_help() {
  cat <<EOF
clode $CLODE_SELF_VERSION — run the latest Claude Code under a host Node, no Bun runtime.

Usage:
  clode [clode-options] [claude args...]   launch Claude Code (args pass through)
  clode update [channel|version]           fetch a fresh upstream provider, then exit

clode-specific options (consumed by clode; everything else goes to Claude Code):
  --clode-help        show this help and exit
  --clode-version     print clode's own version and exit
  --clode-verbose     show clode's progress (extract/deps/etc.); silent by default,
                      so a normal launch emits only Claude Code's own output

Key environment overrides:
  CLODE_VERBOSE=1     same as --clode-verbose
  CLODE_CLAUDE_BIN    upstream claude binary to extract from
  CLODE_NODE          host node            CLODE_PYTHON   host python3
  CLODE_CACHE         extracted-bundle cache dir
  CLODE_CHANGELOG_URL release-notes source for the post-update signals digest

Run 'clode --help' for Claude Code's own help.
EOF
}

# version_gt A B -> success (0) iff version A is strictly greater than B, using the
# real `semver` ext-dep (the SAME module the bundle uses) -- never a hand-rolled
# shell compare. semver is resolved from clode's dep store; node from the usual
# precedence. Returns non-zero if node/semver is unavailable, so callers stay
# conservative (the watcher then under-alarms rather than false-alarms).
version_gt() {
  _vg_node="${NODE:-${CLODE_NODE:-$NODE_BAKED}}"
  [ -n "$_vg_node" ] || return 1
  _vg_np="${CLODE_DEPS:-${XDG_DATA_HOME:-$HOME/.local/share}/clode}/node_modules"
  NODE_PATH="${NODE_PATH:+$NODE_PATH:}$_vg_np" "$_vg_node" -e \
'try{process.exit(require("semver").gt(process.argv[1],process.argv[2])?0:1)}catch(e){process.exit(2)}' \
    "$1" "$2" 2>/dev/null
}

# Where watcher state lives (throttle + notice). Independent of the bundle cache
# (CLODE_CACHE) so it's stable across versions. CLODE_WATCH_DIR overrides.
watch_dir() {
  printf '%s\n' "${CLODE_WATCH_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/clode}"
}

# Epoch mtime of a file, portably (BSD stat -f, GNU stat -c). 0 if unknown.
file_mtime() {
  stat -f %m "$1" 2>/dev/null || stat -c %Y "$1" 2>/dev/null || echo 0
}

# Write the watch notice. $1 path  $2 latest  $3 current  $4 high(0/1)  $5 epoch.
# key=value lines so the next-launch banner reads it without a JSON parser.
write_watch_notice() {
  printf 'latest=%s\ncurrent=%s\nhigh=%s\nchecked_at=%s\n' \
    "$2" "$3" "$4" "$5" > "$1" 2>/dev/null || :
}

main() {
  # Pull clode's own flags out of the args FIRST (in any position) so the bundle
  # never sees them. --clode-verbose un-silences clode's progress chatter; rotate
  # each original arg to the back unless it's the flag, which we drop.
  _seen_verbose=0; _n=$#
  while [ "$_n" -gt 0 ]; do
    _n=$((_n - 1))
    case "$1" in
      --clode-verbose) _seen_verbose=1; shift ;;
      *) set -- "$@" "$1"; shift ;;
    esac
  done
  if [ "$_seen_verbose" = 1 ]; then CLODE_VERBOSE=1; fi

  # Resolve this script's real location, following symlinks (so an npm-installed
  # bin symlink works, and the source tree runs in place).
  SELF="$0"
  while [ -h "$SELF" ]; do
    link=$(readlink "$SELF")
    case "$link" in /*) SELF="$link" ;; *) SELF="$(dirname "$SELF")/$link" ;; esac
  done
  HERE=$(cd "$(dirname "$SELF")" && pwd)

  # Our version comes from the shipped VERSION file (next to bin/, both in the source
  # tree and an npm install). `clode --clode-version` reports it without launching the
  # bundle. (`clode --version` still passes through to Claude Code.)
  CLODE_SELF_VERSION=$(cat "$HERE/../VERSION" 2>/dev/null || echo dev)
  if [ "$1" = "--clode-version" ]; then
    echo "clode $CLODE_SELF_VERSION"
    exit 0
  fi
  if [ "$1" = "--clode-help" ]; then
    clode_help
    exit 0
  fi

  # Helper files (extractor, shim): `$HERE/../libexec` for the source tree and an npm
  # install alike; a flat layout (bin and helpers in one dir) also works. CLODE_LIBEXEC
  # overrides.
  LIBEXEC="${CLODE_LIBEXEC:-$LIBEXEC_BAKED}"
  if [ -z "$LIBEXEC" ]; then
    if [ -f "$HERE/bun-shim.cjs" ]; then
      LIBEXEC="$HERE"                 # flat layout (e.g. a packaged libexec dir)
    elif [ -f "$HERE/../libexec/bun-shim.cjs" ]; then
      LIBEXEC="$(cd "$HERE/../libexec" && pwd)"   # source tree: bin/ + libexec/
    else
      LIBEXEC="$HERE"
    fi
  fi

  # Host tools. Override per box.
  NODE="${CLODE_NODE:-$NODE_BAKED}"
  PYTHON="${CLODE_PYTHON:-$PYTHON_BAKED}"

  # `clode update [channel]` fetches a fresh provider, then exits — no Node needed.
  if [ "$1" = "update" ]; then
    clode_update "${2:-stable}"; exit $?
  fi

  # `clode --clode-internal-update [channel]` is the non-interactive entry the in-TUI
  # autoupdater spawns (via CLODE_SELF); same fetch as `update`, then exit.
  if [ "$1" = "--clode-internal-update" ]; then
    clode_update "${2:-stable}"; exit $?
  fi

  require_node

  BIN=$(resolve_claude_bin) || {
    echo "clode: no Claude Code binary found." >&2
    echo "clode: install the provider package (e.g. claude-code), or set" >&2
    echo "clode: CLODE_CLAUDE_BIN=/path/to/claude" >&2
    exit 1
  }
  if [ ! -e "$BIN" ]; then
    echo "clode: claude binary not found at '$BIN'" >&2
    exit 1
  fi
  # Resolve through a tiny exec-wrapper to the real single-file bundle, so we
  # extract (and cache_key off) the binary that actually carries the JS.
  BIN=$(follow_wrapper "$BIN")

  cache_key

  CACHE_ROOT="${CLODE_CACHE:-${XDG_CACHE_HOME:-$HOME/.cache}/clode}"
  CACHE="$CACHE_ROOT/$KEY"

  extract_if_needed

  ensure_deps

  exec_bundle "$@"
}

# Allow sourcing (tests) without launching: CLODE_SOURCED suppresses the launch.
case "${CLODE_SOURCED:-}" in "") main "$@" ;; *) : ;; esac
