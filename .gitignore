# build/ is GENERATED OUTPUT ONLY — no manifests live here anymore (see
# deps/clode, deps/claude). Three differently-keyed subtrees (see
# scripts/platform-tag.cjs's file header for the why): build/<artifact-name>/
# (shippable per-host output — naude, clode --self, deps.tar/sig, sea-*),
# build/toolchain/<platform>-node<major>/ (the esbuild/postject tool cache),
# build/bundle/ (the platform-independent esbuilt bundles), plus build/tjs/
# (see below).
build/*
node_modules/
test/.harness/
*.tgz
*.cjs.cache
__pycache__/
*.pyc

# Superpowers working docs (plans, approaches, skill scratch) — not part of the project
docs/

# macOS cruft
.DS_Store
._*

# QuickJS-phase-1 vendor checkouts/builds/tarballs (artifacts; PINS.md records versions)
spike/quickjs/vendor/

# patched-tjs build output (scripts/build-tjs.mjs)
build/tjs/
