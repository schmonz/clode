#!/usr/bin/env python3
"""
extract-claude-js  <claude-native-binary>  <out-cli.cjs>

Pull the Claude Code JS bundle out of a Bun `--compile` standalone binary so it
can run under plain Node. Version-independent: it does NOT depend on hardcoded
offsets or the (private) Bun version — it searches for the Bun CJS entry marker
and carves the bundle up to the next NUL.

What it does:
  1. Find every Bun CJS module block:  `// @bun ... @bun-cjs\n(function(exports,
     require, module, __filename, __dirname) {  ...body...  })`  terminated by a
     NUL byte (minified JS has no raw NULs).
  2. Pick the block named entrypoints/cli.js — refuses to guess if not found.
  3. Strip the marker + CJS wrapper, leaving the bare module body.
  4. Rewrite `import.meta` (illegal in Node CJS) to a CJS-safe shim object.
  5. Prepend a prelude that installs the Bun-global shim and __import_meta.
  6. Verify the output before writing (rejects bad carves, removes partial output).

The result is `require()`-able / runnable by Node >=18.
"""
import re, sys, os

MARKER = re.compile(rb'// @bun\b[^\n]*@bun-cjs\n\(function\(exports, require, module, __filename, __dirname\) \{')

# Tokens that must appear in any legitimate Claude Code CLI bundle.
# Used by main() to catch wrong-block carves before caching.
SENTINELS = (b"commander", b"@anthropic-ai/claude-code")

# The CLI entrypoint is ~17 MB; anything smaller is a bad carve.
# Only enforced by main() — not by verify() so unit tests on synthetic data work.
MIN_OUTPUT_BYTES = 1_000_000


def nearest_name(data, start):
    """The Bun module path (e.g. /$bunfs/root/src/entrypoints/cli.js) is a
    NUL-terminated string just before its @bun-cjs block. Scan back up to 4KB
    for the last `...something.js\\0` ending before `start`."""
    lo = max(0, start - 4096)
    seg = data[lo:start]
    j = seg.rfind(b'.js\x00')
    if j == -1:
        return None
    k = seg.rfind(b'\x00', 0, j)
    return seg[k + 1:j + 3].decode('latin-1', 'replace')


def carve_blocks(data):
    """Find all Bun @bun-cjs module blocks in *data*.

    Returns a list of (offset, size, body, name) tuples where:
      offset  — byte offset of the marker in *data*
      size    — length of the carved body in bytes
      body    — the bare module body (marker + wrapper stripped)
      name    — module path from the preceding NUL-terminated string, or None
    """
    blocks = []
    for m in MARKER.finditer(data):
        body_start = m.end()                     # just past the `{`
        nul = data.find(b'\x00', body_start)
        end = nul if nul != -1 else len(data)
        # body is everything up to the trailing `})` before the NUL
        block = data[body_start:end]
        # trim trailing whitespace then the closing `})`
        block = block.rstrip()
        if block.endswith(b'})'):
            block = block[:-2]
        name = nearest_name(data, m.start())
        blocks.append((m.start(), len(block), block, name))
    return blocks


def pick_entry(blocks):
    """Select the cli.js entry block by name. A bundle with no entrypoints/cli.js
    block means the format changed — refuse to guess, so a bad carve never ships."""
    if not blocks:
        sys.exit("error: no Bun @bun-cjs entry marker found — format may have changed")
    named = next((b for b in blocks if (b[3] or '').endswith('entrypoints/cli.js')), None)
    if named is None:
        by_size = max(blocks, key=lambda b: b[1])
        sys.exit("error: no block named entrypoints/cli.js; bundle format may have changed "
                 "(largest candidate was %d bytes). Refusing to guess." % by_size[1])
    return named


PRELUDE = b"""// ---- mavericks node-host prelude (auto-generated) ----
globalThis.Bun = globalThis.Bun || require(__dirname + '/bun-shim.cjs');
const __import_meta = {
  url: require('url').pathToFileURL(__filename).href,
  dirname: __dirname,
  filename: __filename,
  env: process.env,
  main: require.main === module,
  resolve: (s) => require('url').pathToFileURL(require.resolve(s)).href,
};
// clode's native-autoupdater redirect calls this (when CLODE_SELF is set): spawn
// clode's own host-agnostic fetch instead of upstream's in-process native install,
// then resolve a success-shaped result so the bundle renders "Restart to apply".
globalThis.__clodeNativeUpdate = function () {
  return new Promise(function (resolve) {
    var child = require('child_process').spawn(
      process.env.CLODE_SELF, ['--clode-internal-update'], { stdio: 'inherit' });
    // Report success only when clode's update actually succeeded (exit 0), so a
    // failed fetch doesn't drive the bundle's "Restart to apply" path onto an
    // unchanged version. `--clode-internal-update` propagates clode_update's status.
    child.on('exit', function (code) {
      resolve({ wasUpdated: code === 0, latestVersion: null, lockFailed: false }); });
    child.on('error', function () {
      resolve({ wasUpdated: false, latestVersion: null, lockFailed: false }); });
  });
};
// ------------------------------------------------------
"""


# Contribute clode's applet-skew findings as NATIVE Claude "Installation warnings"
# data, rather than grafting our own /doctor section. The doctor diagnostics
# builder returns an object `{installationType:…,warnings:L,packageManager:…,…}`
# where `L` is the warnings array the "Installation warnings" section renders (each
# {issue,fix} -> an `issue` line + a `fix` line). We splice a contribution that
# pushes one {issue,fix} per skew finding onto L, just before that return.
#
# Anchor: `return{installationType:` is a UNIQUE, unminified marker (object keys are
# not minified); the bounded `.{0,400}?` skips the intervening fields (incl. the
# autoUpdates arrow's own `return`) to capture the warnings var from `,warnings:<id>,
# packageManager:`. Same fail-loud contract as the other doctor patches: inject only
# on an exactly-once match; never brick /doctor (skew still warns on stderr).
#
# The remedy (`fix`) is the applet-specific one bun-shim records on each finding
# (`s.fix`), so the /doctor advice matches the stderr advice exactly (e.g. bfs's
# "install bfs >= 3.3 built with Oniguruma ..."). A generic CLODE_<APPLET> hint is the
# fallback if an older shim recorded a finding without `s.fix`.
# The 400 cap is ~2x the real-bundle gap (~210 chars between installationType: and ,warnings:); a future Claude that grows past it fails the exactly-once match (caught by inspect-claude-bundle --strict), never silently mis-injects.
INSTALL_WARNINGS = re.compile(
    rb'return\{installationType:.{0,400}?,warnings:(?P<arr>[A-Za-z0-9_$]{1,6}),packageManager:',
    re.DOTALL,
)


def _skew_contribution(arr):
    """JS spliced before the diagnostics return: defensively push each clode skew
    finding onto the warnings array `arr`. Safe by construction: cannot throw on
    well-formed findings — bun-shim always records `name`, `applet`, and `why` as
    strings (CLODE_SHADOWS), so the string operations below are always valid. A
    no-op when there is no skew."""
    return (
        b'globalThis.__clodeDoctor&&globalThis.__clodeDoctor.appletSkew&&'
        b'globalThis.__clodeDoctor.appletSkew.forEach(function(s){' + arr + b'.push({'
        b'issue:"host "+s.applet+" rejects flags clode\\u2019s bundled /"+s.name+" uses \\u2014 "+s.why,'
        b'fix:s.fix||("set CLODE_"+s.applet.toUpperCase()+" to a compatible "+s.applet)'
        b'})});'
    )


def patch_doctor_warnings(body):
    """Splice the skew contribution before the doctor diagnostics return. Returns
    (new_body, applied); applied is False (unchanged) unless the anchor matches
    exactly once."""
    m = list(INSTALL_WARNINGS.finditer(body))
    if len(m) != 1:
        return body, False
    inject = _skew_contribution(m[0].group('arr'))
    cut = m[0].start()
    return body[:cut] + inject + body[cut:], True


# Make /doctor show the applet-skew on the FIRST open, not only after a shell
# command. The skew probe (bun-shim's warnAppletSkew) runs when Claude generates
# its shell snapshot, which Claude does lazily on first Bash use — so a fresh
# /doctor is empty. We can't probe eagerly without the snapshot: the embedded flags
# are built dynamically (ARGV0=${...} "$_cc_bin" -S dfs ...), so they only exist once
# the snapshot script is generated. The fix: have /doctor trigger snapshot generation
# (which fires our probe) and await it before rendering.
#
# Two anchors, both best-effort + fail-loud (never brick /doctor):
#   1. SNAPSHOT_GEN — the no-arg generator `async function G(){let h=await S();
#      return{provider:await I(h)}}`. Expose it as globalThis.__clodeEnsureSnapshot,
#      set when its (eagerly-initialized) module body runs.
#   2. DOCTOR_LOAD — the /doctor command's `load:()=>Promise.resolve().then(...)`.
#      Chain an ensure-step before the original so generation completes (and the
#      probe populates __clodeDoctor) before the screen renders.
# If the bridge is unset when /doctor opens (generator module not yet initialized),
# the ensure-step is a no-op and /doctor falls back to today's lazy behavior — no
# regression. We apply BOTH or NEITHER (a half-wired patch is pointless).
SNAPSHOT_GEN = re.compile(
    rb'async function (?P<gen>[A-Za-z0-9_$]{1,6})\(\)\{'
    rb'let (?P<h>[A-Za-z0-9_$]{1,6})=await [A-Za-z0-9_$]{1,6}\(\);'
    rb'return\{provider:await [A-Za-z0-9_$]{1,6}\((?P=h)\)\}\}'
)
DOCTOR_LOAD = re.compile(
    rb'(?P<prefix>name:"doctor".{0,240}?)'
    rb'load:\(\)=>Promise\.resolve\(\)\.then\('
    rb'(?P<cb>\(\) => \([A-Za-z0-9_$]{1,8}\(\),[A-Za-z0-9_$]{1,8}\))'
    rb'\)',
    re.DOTALL,
)
# Defensive ensure-step: never throws (sync throw -> rejection), swallows errors so a
# snapshot failure can never brick /doctor; no-op when the bridge isn't set yet.
_DOCTOR_ENSURE = (
    b'()=>{var g=globalThis.__clodeEnsureSnapshot;'
    b'return g?Promise.resolve().then(g).catch(function(){}):void 0}')


def patch_doctor_eager(body):
    """Wire /doctor to generate the shell snapshot (firing the skew probe) before it
    renders, so the applet-skew section shows on first open. Returns (body, applied);
    applied is False (body unchanged) unless BOTH anchors match exactly once."""
    gens = list(SNAPSHOT_GEN.finditer(body))
    loads = list(DOCTOR_LOAD.finditer(body))
    if len(gens) != 1 or len(loads) != 1:
        return body, False
    g, L = gens[0], loads[0]
    new_load = (b'load:()=>Promise.resolve().then(' + _DOCTOR_ENSURE
                + b').then(' + L.group('cb') + b')')
    # Splice the later offset first so the earlier splice's offsets stay valid.
    expose = b'globalThis.__clodeEnsureSnapshot=' + g.group('gen') + b';'
    edits = sorted([
        (g.end(), g.end(), expose),
        (L.start(), L.end(), L.group('prefix') + new_load),
    ], key=lambda e: e[0], reverse=True)
    for start, end, repl in edits:
        body = body[:start] + repl + body[end:]
    return body, True


# Claude Code's in-TUI autoupdater (the pkg-manager path) spawns an npm/install
# command to fetch a new version, then shows "Update installed · Restart to apply".
# Under clode there is no npm-managed install to update, so that spawn fails. We
# redirect the spawn's argv to `"$CLODE_SELF" --clode-internal-update` (clode's own
# host-agnostic fetch into the provider store) when CLODE_SELF is set, leaving the
# argv untouched otherwise. The override is spliced right after the
# auto_updater_start telemetry call, before the `let[..]=cmd` destructure that
# feeds the spawn — so the spawn sees clode's argv. exit 0 -> the bundle's existing
# success path renders "Restart to apply"; the next clode launch re-extracts the
# freshly-fetched provider. Anchor PROVEN against real 2.1.179; same identifier
# bounding rationale as the doctor anchors (short minified ids, linear scan).
AUTOUPDATER_SPAWN = re.compile(
    rb'(?P<pre>tengu_pkg_manager_auto_updater_start",[A-Za-z0-9_$]{1,6}\);)'
    rb'let\[[A-Za-z0-9_$]{1,6},\.\.\.[A-Za-z0-9_$]{1,6}\]=(?P<cmd>[A-Za-z0-9_$]{1,6}),'
    rb'[A-Za-z0-9_$]{1,6}=await [A-Za-z0-9_$]{1,6}\('
)

def patch_autoupdater(body):
    """Override the pkg-manager autoupdater's spawn argv to call `clode --clode-internal-update`
    (when CLODE_SELF is set). exit 0 -> the bundle's existing success path shows
    "Update installed · Restart to apply"; next launch re-extracts. Returns
    (new_body, applied); applied False unless exactly one match (fail-loud)."""
    m = list(AUTOUPDATER_SPAWN.finditer(body))
    if len(m) != 1:
        return body, False
    cmd = m[0].group('cmd'); pre = m[0].group('pre')
    override = cmd + b'=process.env.CLODE_SELF?[process.env.CLODE_SELF,"--clode-internal-update"]:' + cmd + b';'
    cut = m[0].start() + len(pre)
    return body[:cut] + override + body[cut:], True


# Claude Code's in-TUI NATIVE autoupdater installs in-process: after the
# `tengu_native_auto_updater_start` telemetry it does `try{let T=await <fn>(<arg>),…`
# where <fn> returns {wasUpdated,latestVersion,lockFailed}. Under clode that native
# install is wrong (clode runs extracted JS, not a native install). We replace the
# call with a CLODE_SELF-guarded clode spawn that resolves a success-shaped result,
# so the bundle's existing "Restart to apply" path runs and the next launch
# re-extracts. The `,` after the call bounds <arg>. Same fail-loud contract as the
# pkg-manager redirect. Anchor PROVEN against real 2.1.179.
NATIVE_AUTOUPDATER = re.compile(
    rb'(?P<pre>tengu_native_auto_updater_start",(?:\{\}|[A-Za-z0-9_$]{1,6})\);'
    rb'try\{let [A-Za-z0-9_$]{1,6}=await )'
    rb'(?P<call>[A-Za-z0-9_$]{1,6}\([A-Za-z0-9_$]{1,6}\)),'
)

def patch_native_autoupdater(body):
    """Redirect the in-TUI NATIVE autoupdater to clode's internal fetch (when
    CLODE_SELF is set). Replaces `await <fn>(<arg>)` with
    `await (process.env.CLODE_SELF?globalThis.__clodeNativeUpdate():<fn>(<arg>))`.
    Returns (new_body, applied); applied False unless exactly one match (fail-loud)."""
    m = list(NATIVE_AUTOUPDATER.finditer(body))
    if len(m) != 1:
        return body, False
    pre = m[0].group('pre'); call = m[0].group('call')
    override = (pre + b'(process.env.CLODE_SELF?globalThis.__clodeNativeUpdate():'
                + call + b'),')
    return body[:m[0].start()] + override + body[m[0].end():], True


def transform(body):
    """Rewrite *body* to be Node CJS-compatible and prepend the prelude.

    Replaces all `import.meta` references with `__import_meta` (which is
    defined by the prelude), then contributes the clode applet-skew finding to
    /doctor's installation warnings and wires /doctor to refresh the skew probe
    before rendering.
    Replacing inside strings is harmless.
    """
    body = re.sub(rb'\bimport\.meta\b', b'__import_meta', body)
    body, applied = patch_doctor_warnings(body)
    if not applied:
        sys.stderr.write(
            "clode: /doctor applet-skew hook NOT applied — installation-warnings anchor "
            "(return{installationType:...,warnings:...}) not found exactly once (Claude "
            "version drift?). Skew still warns on stderr at startup; run "
            "inspect-claude-bundle --strict to confirm the surface.\n")
    body, eager = patch_doctor_eager(body)
    if not eager:
        sys.stderr.write(
            "clode: /doctor eager-snapshot hook NOT applied — generator or doctor-load "
            "anchor not found exactly once (Claude version drift?). The applet-skew section "
            "still appears after the first shell command; run inspect-claude-bundle --strict.\n")
    body, au = patch_autoupdater(body)
    if not au:
        sys.stderr.write(
            "clode: in-TUI autoupdater hook NOT applied — pkg-manager apply anchor not found "
            "exactly once (Claude version drift?). `clode update` still works; "
            "run inspect-claude-bundle --strict.\n")
    body, nau = patch_native_autoupdater(body)
    if not nau:
        sys.stderr.write(
            "clode: in-TUI NATIVE autoupdater hook NOT applied — native apply anchor "
            "not found exactly once (Claude version drift?). `clode update` still "
            "works; run inspect-claude-bundle --strict.\n")
    return PRELUDE + body + b'\n'


def verify(out_text):
    """Check *out_text* for structural problems (ALWAYS run).

    Returns a list of human-readable problem strings; an empty list means OK.

    Checks performed (structural only):
      - no residual NUL bytes (would indicate a bad carve boundary)
      - no residual `import.meta` tokens (would indicate a missed rewrite)
    """
    problems = []
    if b"\x00" in out_text:
        problems.append("output contains NUL bytes (bad carve boundary)")
    if b"import.meta" in out_text:
        problems.append("output still contains import.meta (rewrite missed a form)")
    return problems


def content_checks(out_text):
    """Size-floor and sentinel-token checks: a real cli bundle is ~17MB and contains
    known tokens; a tiny or wrong carve fails these.

    Returns a list of human-readable problem strings; an empty list means OK.

    Checks performed:
      - output is at least MIN_OUTPUT_BYTES bytes
      - at least one sentinel token from SENTINELS is present
    """
    problems = []
    if len(out_text) < MIN_OUTPUT_BYTES:
        problems.append("output too small: %d bytes (< %d size floor)"
                        % (len(out_text), MIN_OUTPUT_BYTES))
    if not any(s in out_text for s in SENTINELS):
        problems.append("no expected sentinel token found (not the cli bundle?)")
    return problems


def main(argv):
    pos = [a for a in argv if not a.startswith('-')]
    if len(pos) != 2:
        sys.exit(__doc__)
    binpath, out = pos
    data = open(binpath, 'rb').read()
    off, size, body, name = pick_entry(carve_blocks(data))
    text = transform(body)
    open(out, 'wb').write(text)
    problems = verify(text) + content_checks(text)
    if problems:
        try: os.remove(out)
        except OSError: pass
        sys.exit("error: extraction failed verification:\n  - " + "\n  - ".join(problems))
    sys.stderr.write("entry=%s\nwrote %s (%d bytes)\n" % (name or '<unknown>', out, len(text)))


if __name__ == '__main__':
    main(sys.argv[1:])
